layout {
  tab name="__AOC_TAB_NAME__" focus=true {
    pane split_direction="horizontal" {

      pane split_direction="vertical" {
        // LEFT: Yazi (tree + preview). Starts in project root.
        pane size="16%" name="Explorer" command="bash" {
          args "--noprofile" "--norc" "-c" "export PATH=\"$HOME/.local/bin:/usr/local/bin:$HOME/.cargo/bin:$PATH\"; theme_env=\"${XDG_CONFIG_HOME:-$HOME/.config}/aoc/theme.env\"; if [[ -f \"$theme_env\" ]]; then source \"$theme_env\"; fi; export EDITOR=micro; export VISUAL=$EDITOR; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; if command -v aoc-tab-metadata >/dev/null 2>&1; then aoc-tab-metadata sync >/dev/null 2>&1 || true; fi; cd \"__AOC_PROJECT_ROOT__\" && exec ${AOC_FILETREE_CMD:-aoc-yazi} ."
        }

        // RIGHT COLUMN: agent stack (Agent, Terminal, Taskmaster)
        pane split_direction="horizontal" stacked=true {
          pane expanded=true focus=true command="bash" {
            args "-lc" "export PATH=\"$HOME/.local/bin:/usr/local/bin:$HOME/.cargo/bin:$PATH\"; theme_env=\"${XDG_CONFIG_HOME:-$HOME/.config}/aoc/theme.env\"; if [[ -f \"$theme_env\" ]]; then source \"$theme_env\"; fi; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; if command -v aoc-tab-metadata >/dev/null 2>&1; then aoc-tab-metadata sync >/dev/null 2>&1 || true; fi; export AOC_PANE_ID=\"${ZELLIJ_PANE_ID:-}\"; export AOC_AGENT_TMUX_ID=\"__AOC_SESSION_ID__:__AOC_TAB_NAME__:pi\"; export AOC_PI_USE_WRAP_RS=0; export AOC_PI_USE_PTY=1; export AOC_AGENT_PTY=1; export AOC_PI_USE_BOOTLOADER=1; export AOC_PI_USE_TMUX=\"${AOC_PI_USE_TMUX:-1}\"; cd \"__AOC_PROJECT_ROOT__\" && AOC_AGENT_RUN=1 exec ${AOC_AGENT_CMD:-aoc-agent-wrap pi pi 'PI Agent'}"
          }

          pane command="bash" {
            args "-lc" "export PATH=\"$HOME/.local/bin:/usr/local/bin:$HOME/.cargo/bin:$PATH\"; theme_env=\"${XDG_CONFIG_HOME:-$HOME/.config}/aoc/theme.env\"; if [[ -f \"$theme_env\" ]]; then source \"$theme_env\"; fi; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; if command -v aoc-tab-metadata >/dev/null 2>&1; then aoc-tab-metadata sync >/dev/null 2>&1 || true; fi; cd \"__AOC_PROJECT_ROOT__\" && exec ${AOC_TERMINAL_CMD:-$SHELL}"
          }

          pane name="Taskmaster" command="bash" {
            args "-lc" "export PATH=\"$HOME/.local/bin:/usr/local/bin:$HOME/.cargo/bin:$PATH\"; theme_env=\"${XDG_CONFIG_HOME:-$HOME/.config}/aoc/theme.env\"; if [[ -f \"$theme_env\" ]]; then source \"$theme_env\"; fi; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; if command -v aoc-tab-metadata >/dev/null 2>&1; then aoc-tab-metadata sync >/dev/null 2>&1 || true; fi; export AOC_TASKMASTER_NATIVE=1; cd \"__AOC_PROJECT_ROOT__\" && exec ${AOC_TASKMASTER_CMD:-aoc-taskmaster}"
          }
        }
      }
    }
  }
}
