#!/usr/bin/env python3
import argparse
import fcntl
import hashlib
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

ROOT = Path.cwd()


def resolve_service_root():
    env_root = os.environ.get("AOC_SERVICES_ROOT") or os.environ.get("AOC_CONTROL_ROOT")
    candidates = []
    if env_root:
        candidates.append(Path(env_root))
    candidates.append(ROOT)
    candidates.append(ROOT / "agent-ops-cockpit")
    try:
        candidates.extend(sorted(p for p in ROOT.iterdir() if p.is_dir()))
    except Exception:
        pass
    for candidate in candidates:
        try:
            resolved = candidate.expanduser().resolve()
        except Exception:
            resolved = candidate
        if (resolved / ".aoc/search.toml").exists() or (resolved / "bin/aoc-search").exists():
            return resolved
    return ROOT


SERVICE_ROOT = resolve_service_root()
DEFAULT_WATCH_INTERVAL = float(os.environ.get("AOC_SERVICES_WATCH_INTERVAL", "30"))
HEALTH_CACHE_TTL = float(os.environ.get("AOC_SERVICES_HEALTH_CACHE_TTL", "20"))


def service_state_dir():
    base = os.environ.get("XDG_STATE_HOME")
    root = Path(base).expanduser() if base else Path.home() / ".local" / "state"
    key = hashlib.sha256(str(SERVICE_ROOT).encode("utf-8")).hexdigest()[:16]
    path = root / "aoc" / "services" / key
    path.mkdir(parents=True, exist_ok=True)
    return path


def cache_path():
    return service_state_dir() / "health.json"


def lock_path():
    return service_state_dir() / "watch.lock"


def read_cached_status(max_age=None):
    path = cache_path()
    try:
        payload = json.loads(path.read_text())
    except Exception:
        return None
    if max_age is not None:
        ts = float(payload.get("cachedAt", 0) or 0)
        if time.time() - ts > max_age:
            return None
    return payload


def write_cached_status(payload):
    payload = dict(payload)
    payload["cachedAt"] = time.time()
    tmp = cache_path().with_suffix(".tmp")
    tmp.write_text(json.dumps(payload, indent=2))
    tmp.replace(cache_path())
    return payload


def acquire_watch_lock():
    handle = lock_path().open("w")
    try:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        handle.close()
        return None
    handle.write(f"pid={os.getpid()}\nroot={SERVICE_ROOT}\n")
    handle.flush()
    return handle


def run(cmd, timeout=12, cwd=None):
    try:
        if isinstance(cmd, str):
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=timeout, check=False, cwd=cwd)
        else:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, check=False, cwd=cwd)
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except subprocess.TimeoutExpired as exc:
        stdout = exc.stdout.decode(errors="replace") if isinstance(exc.stdout, bytes) else (exc.stdout or "")
        stderr = exc.stderr.decode(errors="replace") if isinstance(exc.stderr, bytes) else (exc.stderr or "")
        return 124, stdout.strip(), (stderr.strip() or f"timed out after {timeout}s")


def json_cmd(cmd, timeout=12, cwd=None):
    code, out, err = run(cmd, timeout, cwd=cwd)
    payload = None
    if out:
        try:
            payload = json.loads(out)
        except Exception:
            payload = None
    return code, payload, out, err


def search_status():
    if not shutil.which("aoc-search") and not Path("bin/aoc-search").exists():
        return {"name": "search", "kind": "server", "state": "missing", "healthy": False, "message": "aoc-search not found"}
    cmd = "aoc-search health --json" if shutil.which("aoc-search") else "bin/aoc-search health --json"
    code, payload, out, err = json_cmd(cmd, timeout=20, cwd=SERVICE_ROOT)
    healthy = code == 0 and isinstance(payload, dict) and bool(payload.get("healthy"))
    return {"name": "search", "kind": "server", "state": "healthy" if healthy else "down", "healthy": healthy, "requiredFor": ["aoc-search"], "details": payload or {"stdout": out, "stderr": err}}


def render_status():
    cmd = "aoc-render status --json" if shutil.which("aoc-render") else "bin/aoc-render status --json"
    if not shutil.which("aoc-render") and not Path("bin/aoc-render").exists():
        return {"name": "render", "kind": "oneshot", "state": "missing", "healthy": False, "serverRequired": False, "message": "aoc-render not found"}
    code, payload, out, err = json_cmd(cmd, timeout=8, cwd=SERVICE_ROOT)
    available = code == 0 and isinstance(payload, dict) and bool(payload.get("available"))
    return {"name": "render", "kind": "oneshot", "state": "available" if available else "unavailable", "healthy": available, "serverRequired": False, "requiredFor": ["aoc-render"], "details": payload or {"stdout": out, "stderr": err}}


def browser_status():
    if not shutil.which("agent-browser"):
        return {"name": "browser", "kind": "daemon", "state": "missing", "healthy": False, "requiredFor": ["agent-browser"], "message": "agent-browser not found"}
    code, out, err = run("agent-browser get url", timeout=3, cwd=SERVICE_ROOT)
    ready = code == 0
    return {"name": "browser", "kind": "daemon", "state": "ready" if ready else "cold", "healthy": ready, "requiredFor": ["agent-browser"], "details": {"stdout": out, "stderr": err}}


def mind_status():
    if not shutil.which("aoc-mind-service"):
        return {"name": "mind", "kind": "daemon-or-cold", "state": "missing", "healthy": False, "requiredFor": ["mind", "context-pack"], "message": "aoc-mind-service not found"}
    code, payload, out, err = json_cmd(f"aoc-mind-service status --project-root {quote(str(SERVICE_ROOT))} --json", timeout=10, cwd=SERVICE_ROOT)
    state = "healthy" if code == 0 else "cold"
    raw_state = (((payload or {}).get("service_status") or {}).get("state")) if isinstance(payload, dict) else None
    if raw_state:
        state = raw_state
    return {"name": "mind", "kind": "daemon-or-cold", "state": state, "healthy": code == 0, "requiredFor": ["mind", "context-pack", "provenance"], "details": payload or {"stdout": out, "stderr": err}}


def quote(value):
    return "'" + value.replace("'", "'\\''") + "'"


def all_status():
    services = [search_status(), render_status(), browser_status(), mind_status()]
    return {"schemaVersion": 1, "projectRoot": str(ROOT), "serviceRoot": str(SERVICE_ROOT), "services": services, "healthy": all(s.get("healthy") or s.get("kind") in {"oneshot", "daemon-or-cold"} for s in services)}


def all_status_cached(max_age=HEALTH_CACHE_TTL):
    cached = read_cached_status(max_age=max_age)
    if cached is not None:
        cached["cacheHit"] = True
        return cached
    payload = all_status()
    payload["cacheHit"] = False
    return write_cached_status(payload)


def print_status(payload, as_json=False):
    if as_json:
        print(json.dumps(payload, indent=2))
        return
    print(f"AOC services: {payload['projectRoot']}")
    if payload.get("serviceRoot") and payload.get("serviceRoot") != payload.get("projectRoot"):
        print(f" service root: {payload['serviceRoot']}")
    for svc in payload["services"]:
        marker = "✓" if svc.get("healthy") else ("·" if svc.get("kind") in {"oneshot", "daemon-or-cold"} else "✗")
        extra = " no-server" if svc.get("serverRequired") is False else ""
        print(f" {marker} {svc['name']:<8} {svc['state']:<12} {svc['kind']}{extra}")


def start_service(name):
    if name == "search":
        cmd = "aoc-search start --wait" if shutil.which("aoc-search") else "bin/aoc-search start --wait"
        return run(cmd, timeout=90, cwd=SERVICE_ROOT)
    if name == "render":
        return 0, "render is one-shot; no server to start", ""
    if name == "browser":
        return 0, "browser starts lazily via agent-browser open; no default page launched", ""
    if name == "mind":
        return 0, "mind service is cold/lazy by default; use aoc-mind-service commands for warm mode", ""
    raise SystemExit(f"unknown service: {name}")


def stop_service(name):
    if name == "search":
        cmd = "aoc-search stop" if shutil.which("aoc-search") else "bin/aoc-search stop"
        return run(cmd, timeout=60, cwd=SERVICE_ROOT)
    if name in {"render", "browser", "mind"}:
        return 0, f"{name} has no managed default stop action", ""
    raise SystemExit(f"unknown service: {name}")


def main():
    parser = argparse.ArgumentParser(prog="aoc-services", description="Centralized AOC project service supervisor for Mission Control.")
    sub = parser.add_subparsers(dest="command", required=True)
    p = sub.add_parser("status"); p.add_argument("--json", action="store_true"); p.add_argument("--watch", action="store_true"); p.add_argument("--interval", type=float, default=DEFAULT_WATCH_INTERVAL)
    p = sub.add_parser("up"); p.add_argument("--watch", action="store_true"); p.add_argument("--interval", type=float, default=DEFAULT_WATCH_INTERVAL); p.add_argument("--no-search", action="store_true")
    p = sub.add_parser("start"); p.add_argument("service", choices=["search", "render", "browser", "mind"])
    p = sub.add_parser("stop"); p.add_argument("service", choices=["search", "render", "browser", "mind"])
    p = sub.add_parser("doctor"); p.add_argument("--json", action="store_true")
    args = parser.parse_args()

    if args.command == "status":
        lock_handle = acquire_watch_lock() if args.watch else None
        if args.watch and lock_handle is None:
            print(f"AOC services watcher already active for {SERVICE_ROOT}; not starting duplicate poller.")
            cached = read_cached_status(max_age=None)
            if cached:
                print_status(cached, args.json)
            return 0
        while True:
            if args.watch and not args.json:
                print("\033[2J\033[H", end="")
            payload = all_status_cached(max_age=max(1.0, min(args.interval, HEALTH_CACHE_TTL))) if args.watch else all_status()
            print_status(payload, args.json)
            if not args.watch: break
            time.sleep(max(1.0, args.interval))
        return 0
    if args.command == "up":
        lock_handle = acquire_watch_lock() if args.watch else None
        if args.watch and lock_handle is None:
            print(f"AOC services watcher already active for {SERVICE_ROOT}; not starting duplicate poller.")
            cached = read_cached_status(max_age=None)
            if cached:
                print_status(cached, False)
            return 0
        if not args.no_search:
            code, out, err = start_service("search")
            if code != 0:
                print(err or out, file=sys.stderr)
        if args.watch:
            args.command = "status"; args.json = False
            while True:
                print("\033[2J\033[H", end="")
                payload = all_status_cached(max_age=max(1.0, min(args.interval, HEALTH_CACHE_TTL)))
                print_status(payload, False)
                time.sleep(max(1.0, args.interval))
        return 0
    if args.command in {"start", "stop"}:
        code, out, err = (start_service if args.command == "start" else stop_service)(args.service)
        if out: print(out)
        if err: print(err, file=sys.stderr)
        return code
    if args.command == "doctor":
        payload = all_status(); print_status(payload, args.json); return 0 if payload["healthy"] else 2


if __name__ == "__main__":
    raise SystemExit(main())
