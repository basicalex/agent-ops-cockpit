#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
local_release="$script_dir/../crates/target/release/aoc-yazi-mermaid"
local_debug="$script_dir/../crates/target/debug/aoc-yazi-mermaid"
project_release=""
project_debug=""
manifest_path=""

if [[ -n "${AOC_PROJECT_ROOT:-}" && -f "${AOC_PROJECT_ROOT}/crates/Cargo.toml" ]]; then
  manifest_path="${AOC_PROJECT_ROOT}/crates/Cargo.toml"
  project_release="${AOC_PROJECT_ROOT}/crates/target/release/aoc-yazi-mermaid"
  project_debug="${AOC_PROJECT_ROOT}/crates/target/debug/aoc-yazi-mermaid"
elif [[ -f "$script_dir/../crates/Cargo.toml" ]]; then
  manifest_path="$script_dir/../crates/Cargo.toml"
fi

if [[ -n "${AOC_YAZI_MERMAID_BIN:-}" ]]; then
  exec "$AOC_YAZI_MERMAID_BIN" "$@"
fi

if command -v aoc-yazi-mermaid-native >/dev/null 2>&1; then
  exec aoc-yazi-mermaid-native "$@"
fi

if [[ -n "$project_release" && -x "$project_release" ]]; then
  exec "$project_release" "$@"
fi

if [[ -n "$project_debug" && -x "$project_debug" ]]; then
  exec "$project_debug" "$@"
fi

if [[ -x "$local_release" ]]; then
  exec "$local_release" "$@"
fi

if [[ -x "$local_debug" ]]; then
  exec "$local_debug" "$@"
fi

if command -v cargo >/dev/null 2>&1 && [[ -n "$manifest_path" ]]; then
  exec cargo run --manifest-path "$manifest_path" -p aoc-yazi-mermaid -- "$@"
fi

echo "aoc-yazi-mermaid: binary not found (build crates/aoc-yazi-mermaid)." >&2
exit 1
