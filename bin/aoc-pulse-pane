#!/usr/bin/env bash
set -euo pipefail

export AOC_MISSION_CONTROL_MODE="${AOC_MISSION_CONTROL_MODE:-pulse-pane}"
export AOC_PULSE_LIGHT_PANE="${AOC_PULSE_LIGHT_PANE:-1}"
export AOC_MISSION_CONTROL_LAYOUT_REFRESH_MS="${AOC_MISSION_CONTROL_LAYOUT_REFRESH_MS:-6000}"
export AOC_MISSION_CONTROL_SNAPSHOT_REFRESH_SECS="${AOC_MISSION_CONTROL_SNAPSHOT_REFRESH_SECS:-4}"

exec aoc-mission-control "$@"
