      [data-composition-id="brand-campaign-board"] h1 { font-size: 118px; line-height: .92; letter-spacing: -.065em; margin: 0; max-width: 1180px; }
      [data-composition-id="brand-campaign-board"] .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 20px; }
      [data-composition-id="brand-campaign-board"] article { border: 1px solid rgba(131,247,229,.38); border-radius: 30px; padding: 30px; background: rgba(255,255,255,.05); }
