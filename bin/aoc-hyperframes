      const tl = gsap.timeline({ paused: true });
      tl.from('[data-composition-id="brand-campaign-board"] .eyebrow', { y: 24, opacity: 0, duration: 0.45, ease: 'power2.out' }, 0.2);
      tl.from('[data-composition-id="brand-campaign-board"] h1', { y: 58, opacity: 0, duration: 0.7, ease: 'power3.out' }, 0.35);
      tl.from('[data-composition-id="brand-campaign-board"] article', { y: 34, opacity: 0, stagger: 0.08, duration: 0.55, ease: 'back.out(1.3)' }, 0.7);
      tl.from('[data-composition-id="brand-campaign-board"] .note', { y: 24, opacity: 0, duration: 0.5, ease: 'power2.out' }, 1.05);
      window.__timelines["brand-campaign-board"] = tl;
    </script>
  </div>
</template>
EOF
  log "Refreshed $target_dir/docs/campaign-review-board.md"
  log "Refreshed $target_dir/compositions/_playgrounds/brand-campaign-board.html"
}

run_brand_board() {
  local write=0 a
  for a in "${args[@]:1}"; do
    case "$a" in
      --write) write=1 ;;
      *) fail "Unknown brand board option: $a" ;;
    esac
  done
  ensure_brand_content_system ""
  if (( write != 1 )); then
    log "Brand board not written. Re-run with: aoc-hyperframes brand board --write"
    return 0
  fi
  write_brand_review_board
  catalog_write >/dev/null || true
}

append_brand_links_to_shotlist() {
  local base="$1" campaign="$2" audience="$3" concept="$4" shot="$root/$target_dir/docs/shotlists/$base.md"
  [[ -f "$shot" ]] || return 0
  if grep -Fq '<!-- AOC-BRAND-CONTENT-LINKS -->' "$shot"; then
    return 0
  fi
  cat >> "$shot" <<EOF

<!-- AOC-BRAND-CONTENT-LINKS -->
## Brand content pipeline links

- Campaign plan: \`hyperframes/docs/content-campaign-plan.md\`
- Image review board: \`hyperframes/docs/image-review-board.md\`
- SVG asset manifest: \`hyperframes/docs/svg-asset-manifest.md\`
- Campaign: $campaign
- Audience: $audience
- Concept: $concept
EOF
}

record_brand_campaign() {
  local slug="$1" audience="$2" concept="$3" channels="$4" durations="$5" plan="$root/$target_dir/docs/content-campaign-plan.md"
  mkdir -p "$(dirname "$plan")"
  [[ -f "$plan" ]] || seed_doc_template content-campaign-plan.md docs/content-campaign-plan.md
  if grep -Fq "## Campaign: $slug" "$plan"; then
    log "Campaign plan already records $slug"
    return 0
  fi
  cat >> "$plan" <<EOF

## Campaign: $slug

Prism-compatible manifest seam:

\`\`\`yaml
campaign: $slug
audience: $audience
concept: $concept
channels: [$channels]
durations: [$durations]
brand_strategy: hyperframes/docs/brand-strategy.md
human_review: hyperframes/docs/image-review-board.md
svg_manifest: hyperframes/docs/svg-asset-manifest.md
hyperframes_catalog: hyperframes/docs/composition-catalog.md
html_video_manifest: hyperframes/generated/html-video/$slug/project.json
\`\`\`

Operator gates:

- [ ] Campaign beats approved
- [ ] Approved concept IDs referenced in image review board
- [ ] SVG assets linked from svg-asset-manifest
- [ ] HyperFrames or html-video preview reviewed before render
EOF
  log "Linked campaign in $target_dir/docs/content-campaign-plan.md"
}

run_brand_campaign() {
  local slug="${args[1]:-}" audience="general" channels="meta,reel" durations="15s,6s" concept="demo" i=2 a
  [[ -n "$slug" ]] || fail "Usage: aoc-hyperframes brand campaign <slug> [--audience NAME --channels LIST --durations LIST --concept NAME]"
  while (( i < ${#args[@]} )); do
    a="${args[$i]}"
    case "$a" in
      --audience) i=$((i + 1)); audience="${args[$i]:-general}" ;;
      --channels) i=$((i + 1)); channels="${args[$i]:-meta,reel}" ;;
      --durations) i=$((i + 1)); durations="${args[$i]:-15s,6s}" ;;
      --concept) i=$((i + 1)); concept="${args[$i]:-demo}" ;;
      *) fail "Unknown brand campaign option: $a" ;;
    esac
    i=$((i + 1))
  done
  require_safe_slug "campaign slug" "$slug"
  require_safe_slug "audience" "$audience"
  require_safe_slug "concept" "$concept"
  require_safe_slug_list "channel" "$channels"
  require_safe_slug_list "duration" "$durations"

  ensure_brand_content_system ""
  local old_args=("${args[@]}")
  args=("create" "$slug" "--audience" "$audience" "--channels" "$channels" "--durations" "$durations" "--concept" "$concept")
  run_campaign
  args=("${old_args[@]}")
  record_brand_campaign "$slug" "$audience" "$concept" "$channels" "$durations"

  IFS=',' read -r -a _aoc_brand_channels <<< "$channels"
  IFS=',' read -r -a _aoc_brand_durations <<< "$durations"
  local idx=0 ch dur base
  for ch in "${_aoc_brand_channels[@]}"; do
    dur="${_aoc_brand_durations[$idx]:-${_aoc_brand_durations[0]}}"
    base="$ch-$dur-$concept-v1"
    append_brand_links_to_shotlist "$base" "$slug" "$audience" "$concept"
    idx=$((idx + 1))
  done
  write_brand_review_board
  catalog_write >/dev/null || true
  log "Brand campaign created: $slug"
}

run_brand_export() {
  local output="$target_dir/generated/brand-content/manifest.json" i=1 a
  while (( i < ${#args[@]} )); do
    a="${args[$i]}"
    case "$a" in
      --output)
        i=$((i + 1))
        output="${args[$i]:-}"
        ;;
      *)
        fail "Unknown brand export option: $a"
        ;;
    esac
    i=$((i + 1))
  done
  [[ -n "$output" ]] || fail "brand export --output requires a path"
  [[ "$output" != *".."* ]] || fail "Invalid brand export output path: parent traversal is not allowed"
  local dest="$root/$target_dir" output_abs
  [[ -d "$dest" ]] || fail "Missing branded content workspace: $target_dir. Run: aoc-hyperframes brand init"
  if [[ "$output" = /* ]]; then
    output_abs="$output"
  else
    output_abs="$root/$output"
  fi
  mkdir -p "$(dirname "$output_abs")"
  python3 - "$root" "$target_dir" "$output_abs" <<'PY'
import hashlib
import json
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

root = Path(sys.argv[1]).resolve()
target_dir = sys.argv[2]
target = root / target_dir
output = Path(sys.argv[3]).resolve()

if not target.is_dir():
    raise SystemExit(f"HyperFrames workspace missing: {target_dir}")

def rel(path: Path) -> str:
    try:
        return path.resolve().relative_to(root).as_posix()
    except ValueError:
        return path.as_posix()

def stable_id(prefix: str, *parts: str) -> str:
    base = "|".join(part for part in parts if part)
    digest = hashlib.sha1(base.encode("utf-8")).hexdigest()[:12]
    safe = re.sub(r"[^a-z0-9]+", "-", "-".join(parts).lower()).strip("-")[:48]
    return f"{prefix}-{safe}-{digest}" if safe else f"{prefix}-{digest}"

def add_artifact(collection: list[dict], *, kind: str, engine: str, path: str, status: str, title: str = "", campaign_id: str = "", metadata: dict | None = None) -> dict:
    artifact = {
        "id": stable_id("artifact", kind, engine, path),
        "type": kind,
        "engine": engine,
        "path": path,
        "status": status,
        "metadata": metadata or {},
    }
    if title:
        artifact["title"] = title
    if campaign_id:
        artifact["campaignId"] = campaign_id
    collection.append(artifact)
    return artifact

def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="replace") if path.is_file() else ""

def parse_table_rows(text: str) -> list[list[str]]:
    rows: list[list[str]] = []
    for raw in text.splitlines():
        line = raw.strip()
        if not line.startswith("|") or "---" in line:
            continue
        cells = [cell.strip().strip("`") for cell in line.strip("|").split("|")]
        if cells:
            rows.append(cells)
    return rows

def parse_campaigns(plan: Path) -> list[dict]:
    text = read_text(plan)
    campaigns: list[dict] = []
    matches = list(re.finditer(r"^## Campaign:\s*([A-Za-z0-9][A-Za-z0-9-]*)\s*$", text, re.MULTILINE))
    for idx, match in enumerate(matches):
        slug = match.group(1)
        section_end = matches[idx + 1].start() if idx + 1 < len(matches) else len(text)
        section = text[match.end():section_end]
        seam: dict[str, str] = {}
        block_match = re.search(r"```yaml\s*(.*?)```", section, re.DOTALL)
        if block_match:
            for raw in block_match.group(1).splitlines():
                if ":" not in raw:
                    continue
                key, value = raw.split(":", 1)
                seam[key.strip()] = value.strip()
        audience = seam.get("audience", "")
        concept = seam.get("concept", "")
        html_manifest = seam.get("html_video_manifest") or f"{target_dir}/generated/html-video/{slug}/project.json"
        campaigns.append({
            "id": slug,
            "audience": audience,
            "concept": concept,
            "campaignPlanPath": rel(plan),
            "imageReviewPath": seam.get("human_review") or f"{target_dir}/docs/image-review-board.md",
            "svgManifestPath": seam.get("svg_manifest") or f"{target_dir}/docs/svg-asset-manifest.md",
            "hyperframesCatalogPath": seam.get("hyperframes_catalog") or f"{target_dir}/docs/composition-catalog.md",
            "htmlVideoManifestPath": html_manifest,
            "metadata": {
                "channels": seam.get("channels", ""),
                "durations": seam.get("durations", ""),
            },
        })
    return campaigns

def html_video_manifests() -> list[Path]:
    base = target / "generated" / "html-video"
    if not base.is_dir():
        return []
    return sorted(base.glob("*/project.json"))

campaigns = parse_campaigns(target / "docs" / "content-campaign-plan.md")
known_campaigns = {campaign["id"]: campaign for campaign in campaigns}
for manifest in html_video_manifests():
    try:
        payload = json.loads(manifest.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        continue
    project_id = str(payload.get("projectId") or manifest.parent.name)
    campaign_id = str(payload.get("campaign") or project_id)
    if campaign_id not in known_campaigns:
        campaign = {
            "id": campaign_id,
            "audience": str(payload.get("audience") or ""),
            "concept": str(payload.get("concept") or ""),
            "campaignPlanPath": str(payload.get("sourcePlan") or f"{target_dir}/docs/content-campaign-plan.md"),
            "imageReviewPath": str(payload.get("imageReview") or f"{target_dir}/docs/image-review-board.md"),
            "svgManifestPath": str(payload.get("svgManifest") or f"{target_dir}/docs/svg-asset-manifest.md"),
            "hyperframesCatalogPath": f"{target_dir}/docs/composition-catalog.md",
            "htmlVideoManifestPath": rel(manifest),
            "metadata": {"htmlVideoProjectId": project_id},
        }
        campaigns.append(campaign)
        known_campaigns[campaign_id] = campaign
    elif not known_campaigns[campaign_id].get("htmlVideoManifestPath"):
        known_campaigns[campaign_id]["htmlVideoManifestPath"] = rel(manifest)

artifacts: list[dict] = []
doc_specs = [
    ("strategy", "aoc", "docs/brand-strategy.md", "Brand strategy", "draft"),
    ("concept", "omp", "docs/concept-directions.md", "Concept directions", "draft"),
    ("image_prompt", "gpt_image", "docs/image-generation-board.md", "GPT Image prompt board", "pending_review"),
    ("doc", "operator", "docs/image-review-board.md", "Human image review board", "pending_review"),
    ("doc", "omp", "docs/svg-asset-manifest.md", "SVG asset manifest", "pending_review"),
    ("doc", "aoc", "docs/content-campaign-plan.md", "Content campaign plan", "draft"),
    ("doc", "operator", "docs/campaign-review-board.md", "Campaign review board", "pending_review"),
    ("manifest", "hyperframes", "docs/composition-catalog.md", "HyperFrames composition catalog", "generated"),
]
for kind, engine, doc_rel, title, status in doc_specs:
    path = target / doc_rel
    if path.is_file():
        add_artifact(artifacts, kind=kind, engine=engine, path=rel(path), status=status, title=title)

asset_dirs = [
    ("concept_image", "gpt_image", target / "assets" / "generated" / "concepts", "generated"),
    ("approved_image", "operator", target / "assets" / "generated" / "approved", "approved"),
    ("region", "operator", target / "assets" / "generated" / "sections", "generated"),
    ("svg_asset", "omp", target / "assets" / "generated" / "svg", "generated"),
]
for kind, engine, directory, status in asset_dirs:
    if not directory.is_dir():
        continue
    for file in sorted(path for path in directory.rglob("*") if path.is_file()):
        add_artifact(
            artifacts,
            kind=kind,
            engine=engine,
            path=rel(file),
            status=status,
            title=file.name,
            metadata={"bytes": file.stat().st_size},
        )

composition_root = target / "compositions"
if composition_root.is_dir():
    for file in sorted(composition_root.rglob("*.html")):
        text = read_text(file)
        comp_id_match = re.search(r'data-composition-id="([^"]+)"', text)
        add_artifact(
            artifacts,
            kind="composition",
            engine="hyperframes",
            path=rel(file),
            status="generated",
            title=comp_id_match.group(1) if comp_id_match else file.stem,
            metadata={"compositionId": comp_id_match.group(1) if comp_id_match else ""},
        )

render_roots = [target / "renders", target / "generated" / "html-video"]
for render_root in render_roots:
    if not render_root.is_dir():
        continue
    for file in sorted(path for path in render_root.rglob("*") if path.is_file() and path.suffix.lower() in {".mp4", ".webm", ".mov"}):
        engine = "html_video" if "generated/html-video" in rel(file) else "hyperframes"
        add_artifact(artifacts, kind="render", engine=engine, path=rel(file), status="rendered", title=file.name, metadata={"bytes": file.stat().st_size})
    for file in sorted(path for path in render_root.rglob("*") if path.is_file() and path.suffix.lower() in {".png", ".jpg", ".jpeg", ".webp"}):
        engine = "html_video" if "generated/html-video" in rel(file) else "hyperframes"
        add_artifact(artifacts, kind="preview", engine=engine, path=rel(file), status="generated", title=file.name, metadata={"bytes": file.stat().st_size})

content_graphs: list[dict] = []
for manifest in html_video_manifests():
    try:
        payload = json.loads(manifest.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        continue
    manifest_rel = rel(manifest)
    project_id = str(payload.get("projectId") or manifest.parent.name)
    campaign_id = str(payload.get("campaign") or project_id)
    graph = payload.get("contentGraph") or {}
    nodes = graph.get("nodes") if isinstance(graph, dict) else []
    edges = graph.get("edges") if isinstance(graph, dict) else []
    if not isinstance(nodes, list):
        nodes = []
    if not isinstance(edges, list):
        edges = []
    add_artifact(artifacts, kind="manifest", engine="html_video", path=manifest_rel, status="generated", title=f"html-video project {project_id}", campaign_id=campaign_id, metadata={"projectId": project_id})
    add_artifact(artifacts, kind="storyboard", engine="html_video", path=manifest_rel, status="generated", title=f"Storyboard {project_id}", campaign_id=campaign_id, metadata={"nodeCount": len(nodes), "edgeCount": len(edges)})
    assets_manifest = manifest.parent / "assets.json"
    if assets_manifest.is_file():
        add_artifact(artifacts, kind="manifest", engine="html_video", path=rel(assets_manifest), status="generated", title=f"html-video assets {project_id}", campaign_id=campaign_id, metadata={"projectId": project_id})
    content_graphs.append({
        "id": stable_id("content-graph", project_id, manifest_rel),
        "engine": "html_video",
        "projectId": project_id,
        "campaignId": campaign_id,
        "manifestPath": manifest_rel,
        "nodeCount": len(nodes),
        "edgeCount": len(edges),
        "nodes": [{"id": str(node.get("id", "")), "kind": str(node.get("kind", "")), "durationSec": node.get("durationSec")} for node in nodes if isinstance(node, dict)],
        "edges": [{"from": str(edge.get("from", "")), "to": str(edge.get("to", "")), "kind": str(edge.get("kind", ""))} for edge in edges if isinstance(edge, dict)],
    })

def gates_from_doc(path: Path) -> list[dict]:
    text = read_text(path)
    gates: list[dict] = []
    for idx, match in enumerate(re.finditer(r"^- \[([ xX])\]\s+(.+)$", text, re.MULTILINE), start=1):
        checked = match.group(1).lower() == "x"
        label = match.group(2).strip()
        gates.append({
            "id": stable_id("gate", rel(path), str(idx), label),
            "sourcePath": rel(path),
            "label": label,
            "status": "approved" if checked else "pending_review",
        })
    return gates

operator_gates = []
for gate_path in [target / "docs" / "campaign-review-board.md", target / "docs" / "content-campaign-plan.md", target / "docs" / "image-review-board.md", target / "docs" / "svg-asset-manifest.md"]:
    if gate_path.is_file():
        operator_gates.extend(gates_from_doc(gate_path))

bundle = {
    "schema": "aoc.brand_content.bundle.v1",
    "projectRoot": str(root),
    "generatedAt": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
    "brand": {"strategyPath": f"{target_dir}/docs/brand-strategy.md"},
    "campaigns": campaigns,
    "artifacts": artifacts,
    "contentGraphs": content_graphs,
    "operatorGates": operator_gates,
}

output.write_text(json.dumps(bundle, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
print(rel(output))
PY
  log "Exported AOC branded content manifest: ${output_abs#$root/}"
}

run_brand() {
  case "${args[0]:-}" in
    init)
      run_brand_init
      ;;
    check)
      run_brand_check
      ;;
    board)
      run_brand_board
      ;;
    campaign)
      run_brand_campaign
      ;;
    export)
      run_brand_export
      ;;
    *)
      fail "Usage: aoc-hyperframes brand <init|check|board|campaign|export> [options]"
      ;;
  esac
}

append_inventory_row() {
  local src="$1" dest_rel="$2" kind="$3" inv="$root/$target_dir/docs/asset-inventory.md"
  mkdir -p "$(dirname "$inv")"
  [[ -f "$inv" ]] || printf '# Asset Inventory\n\n' > "$inv"
  grep -Fq "$src" "$inv" && return 0
  if ! grep -Fq '## AOC seeded assets' "$inv"; then
    cat >> "$inv" <<'EOF'

## AOC seeded assets

| Status | Kind | Source | Workspace path | Notes |
| --- | --- | --- | --- | --- |
EOF
  fi
  printf '| seeded | %s | `%s` | `%s` | copied/symlinked by `aoc-hyperframes seed-assets` |\n' "$kind" "$src" "$dest_rel" >> "$inv"
}

classify_asset() {
  local file="$1" lower
  lower="$(basename "$file" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    *logo*|*icon*|*glyph*|*brand*|*compass*) echo brand ;;
    *map*|*route*|*atlas*) echo maps ;;
    *screen*|*screenshot*|*.webp|*.png) echo screens ;;
    *.mp3|*.wav|*.m4a|*.aac) echo audio ;;
    *.txt|*.md|*.json|*.csv) echo copy ;;
    *.jpg|*.jpeg) echo photo ;;
    *.svg) echo ui ;;
    *) echo ui ;;
  esac
}

run_seed_assets() {
  local mode="dry-run" max_size=2097152 i=0 a
  while (( i < ${#args[@]} )); do
    a="${args[$i]}"
    case "$a" in
      --dry-run) mode="dry-run" ;;
      --copy) mode="copy" ;;
      --symlink) mode="symlink" ;;
      --max-size) i=$((i + 1)); max_size="${args[$i]:-2097152}" ;;
      *) fail "Unknown seed-assets option: $a" ;;
    esac
    i=$((i + 1))
  done
  local roots=(public assets src/assets)
  while IFS= read -r app_public; do roots+=("${app_public#$root/}"); done < <(find "$root/apps" -maxdepth 3 -type d -name public 2>/dev/null || true)
  local r file size kind dest_dir dest dest_rel count=0
  for r in "${roots[@]}"; do
    [[ -d "$root/$r" ]] || continue
    while IFS= read -r file; do
      size="$(wc -c < "$file" | tr -d ' ')"
      (( size <= max_size )) || continue
      kind="$(classify_asset "$file")"
      dest_dir="$root/$target_dir/assets/$kind"
      dest="$dest_dir/$(basename "$file")"
      dest_rel="assets/$kind/$(basename "$file")"
      if [[ "$mode" == "dry-run" ]]; then
        printf '%s -> %s\n' "${file#$root/}" "$target_dir/$dest_rel"
      else
        mkdir -p "$dest_dir"
        if [[ -e "$dest" ]]; then
          warn "Skip existing: $target_dir/$dest_rel"
          continue
        fi
        if [[ "$mode" == "copy" ]]; then cp "$file" "$dest"; else ln -s "$(realpath --relative-to="$dest_dir" "$file")" "$dest"; fi
        append_inventory_row "${file#$root/}" "$target_dir/$dest_rel" "$kind"
        log "Seeded asset: $target_dir/$dest_rel"
      fi
      count=$((count + 1))
    done < <(find "$root/$r" -type f \( -iname '*.svg' -o -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.mp3' -o -iname '*.wav' -o -iname '*.m4a' -o -iname '*.txt' -o -iname '*.md' -o -iname '*.json' -o -iname '*.csv' \) 2>/dev/null)
  done
  [[ "$mode" == "dry-run" ]] && log "Dry-run complete: $count candidate asset(s). Re-run with --copy or --symlink to apply."
}

run_check() {
  local dest="$root/$target_dir" errors=0 warnings=0 no_lint=0 allow_npx=0 a hf_bin=""
  for a in "${args[@]}"; do
    case "$a" in
      --no-lint) no_lint=1 ;;
      --allow-npx) allow_npx=1 ;;
    esac
  done
  [[ -d "$dest" ]] || { warn "Missing workspace: $target_dir"; return 1; }
  check_err() { warn "$1"; errors=$((errors + 1)); }
  check_warn() { warn "$1"; warnings=$((warnings + 1)); }

  [[ -f "$root/DESIGN.md" ]] || check_err "Missing root DESIGN.md"
  [[ -f "$dest/docs/DESIGN.md" ]] || check_err "Missing $target_dir/docs/DESIGN.md"
  if [[ -f "$dest/docs/DESIGN.md" ]] && ! grep -Eq '\.\./\.\./DESIGN\.md|root .*DESIGN\.md|Root .*DESIGN\.md' "$dest/docs/DESIGN.md"; then
    check_warn "$target_dir/docs/DESIGN.md should reference ../../DESIGN.md"
  fi
  local req_dirs=(compositions/_playgrounds compositions/components assets/brand assets/maps assets/generated/concepts assets/generated/approved assets/generated/sections assets/generated/svg docs/shotlists renders/exports)
  local req_docs=(docs/asset-inventory.md docs/brand-motion-brief.md docs/campaign-message-matrix.md docs/export-naming.md docs/composition-catalog.md docs/brand-strategy.md docs/concept-directions.md docs/image-generation-board.md docs/image-review-board.md docs/svg-asset-manifest.md docs/content-campaign-plan.md)
  local item
  for item in "${req_dirs[@]}"; do [[ -d "$dest/$item" ]] || check_err "Missing dir: $target_dir/$item"; done
  for item in "${req_docs[@]}"; do [[ -f "$dest/$item" ]] || check_err "Missing doc: $target_dir/$item"; done

  if [[ -f "$root/.gitignore" ]]; then
    if grep -Fqx "$target_dir/" "$root/.gitignore" && ! grep -Fqx "!/$target_dir/" "$root/.gitignore"; then
      check_err ".gitignore ignores $target_dir/ without AOC source unignore policy"
    fi
    grep -Fqx "/$target_dir/renders/**" "$root/.gitignore" || check_warn ".gitignore should ignore /$target_dir/renders/**"
  fi

  if [[ -f "$dest/index.html" ]] && grep -q 'AOC-HYPERFRAMES-WORKBENCH' "$dest/index.html"; then
    local src
    src="$(grep -Eo 'data-composition-src="[^"]+"' "$dest/index.html" | head -n1 | sed 's/data-composition-src="//;s/"$//' || true)"
    [[ -z "$src" || -f "$dest/$src" ]] || check_err "Workbench target missing: $target_dir/$src"
  fi

  local file rel id type base
  while IFS= read -r file; do
    rel="${file#$dest/}"
    id="$(composition_id_for_file "$file")"
    [[ -n "$id" ]] || check_err "Missing data-composition-id: $target_dir/$rel"
    composition_has_timeline "$file" "$id" || check_err "Missing timeline registration: $target_dir/$rel"
    type="${rel#compositions/}"; type="${type%%/*}"
    if [[ "$type" == "ads" || "$type" == "social" || "$type" == "landing" ]]; then
      base="$(basename "$file" .html)"
      [[ -f "$dest/docs/shotlists/$base.md" ]] || check_warn "Missing shotlist for $target_dir/$rel"
    fi
  done < <(find "$dest/compositions" -type f -name '*.html' 2>/dev/null | sort)

  if (( no_lint == 1 )); then
    check_warn "Skipped HyperFrames lint (--no-lint)"
  elif command -v node >/dev/null 2>&1; then
    if hf_bin="$(hyperframes_local_bin || true)" && [[ -n "$hf_bin" ]]; then
      (cd "$dest" && "$hf_bin" lint) || errors=$((errors + 1))
    elif (( allow_npx == 1 )); then
      warn "Using npx fallback for HyperFrames lint because --allow-npx was provided. This may install packages."
      (cd "$dest" && npx hyperframes lint) || errors=$((errors + 1))
    else
      check_warn "Skipped HyperFrames lint; local CLI missing. Run bun install in $target_dir or use --allow-npx."
    fi
  else
    check_warn "Skipped HyperFrames lint; node not found"
  fi

  if (( errors > 0 )); then
    warn "AOC HyperFrames check failed: errors=$errors warnings=$warnings"
    return 1
  fi
  log "AOC HyperFrames check passed: warnings=$warnings"
}

run_doctor() {
  check_toolchain || true
  local dest="$root/$target_dir" hf_bin=""
  if hf_bin="$(hyperframes_local_bin || true)" && [[ -n "$hf_bin" ]]; then
    (cd "$dest" && "$hf_bin" doctor) || true
  else
    warn "Skipped HyperFrames doctor; local CLI missing. Run bun install in $target_dir."
  fi
}

project_slug() { basename "$root" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//'; }

run_render() {
  local input="${args[0]:-}" fmt="mp4" quality="standard" fps="" version="" skip_check=0 i=1 a
  [[ -n "$input" ]] || fail "Usage: aoc-hyperframes render <composition> [--format mp4|webm --quality draft|standard|high --fps N --version vN --skip-check]"
  while (( i < ${#args[@]} )); do
    a="${args[$i]}"
    case "$a" in
      --format) i=$((i + 1)); fmt="${args[$i]:-mp4}" ;;
      --quality) i=$((i + 1)); quality="${args[$i]:-standard}" ;;
      --fps) i=$((i + 1)); fps="${args[$i]:-}" ;;
      --version) i=$((i + 1)); version="${args[$i]:-}" ;;
      --skip-check) skip_check=1 ;;
      *) fail "Unknown render option: $a" ;;
    esac
    i=$((i + 1))
  done
  [[ "$fmt" == "mp4" || "$fmt" == "webm" ]] || fail "Invalid render format: $fmt"
  [[ "$quality" == "draft" || "$quality" == "standard" || "$quality" == "high" ]] || fail "Invalid render quality: $quality"
  [[ -z "$fps" || "$fps" =~ ^[0-9]+$ ]] || fail "Invalid fps: $fps"
  [[ -z "$version" || "$version" =~ ^v[0-9]+$ ]] || fail "Invalid version: $version"
  (( skip_check == 1 )) || run_check
  local file dest rel type base name output hf_bin
  file="$(resolve_composition "$input")" || fail "Composition not found: $input"
  dest="$root/$target_dir"
  rel="${file#$dest/}"
  type="${rel#compositions/}"; type="${type%%/*}"
  base="$(basename "$file" .html)"
  [[ -n "$version" ]] && base="$(echo "$base" | sed -E "s/-v[0-9]+$/-$version/")"
  name="$(project_slug)-$base.$fmt"
  mkdir -p "$dest/renders/$type"
  output="$dest/renders/$type/$name"
  set_workbench_target "$rel"
  hf_bin="$(hyperframes_local_bin || true)"
  [[ -n "$hf_bin" ]] || fail "Local HyperFrames CLI missing. Run bun install in $target_dir before render."
  local cmd=("$hf_bin" render --output "$output" --quality "$quality" --format "$fmt")
  [[ -n "$fps" ]] && cmd+=(--fps "$fps")
  log "Rendering $rel -> $target_dir/renders/$type/$name"
  (cd "$dest" && "${cmd[@]}")
}

root="$(find_root)"
ensure_aoc

case "$command" in
  init)
    init_workspace
    ensure_hyperframes_git_policy
    seed_skills
    sync_skills
    bootstrap_asset_system
    run_check || true
    log "HyperFrames campaign factory ready. Use Alt+X -> AOC HyperFrames."
    ;;
  bootstrap-asset-system|bootstrap)
    bootstrap_asset_system
    ;;
  sync-skills)
    seed_skills
    sync_skills
    log "HyperFrames skills synced."
    ;;
  doctor)
    run_doctor
    ;;
  check)
    run_check
    ;;
  catalog)
    run_catalog
    ;;
  workbench)
    run_workbench
    ;;
  campaign)
    run_campaign
    ;;
  brand)
    run_brand
    ;;
  seed-assets)
    run_seed_assets
    ;;
  render)
    run_render
    ;;
  *) usage; exit 1 ;;
esac
