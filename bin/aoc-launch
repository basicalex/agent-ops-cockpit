#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/aoc-utils.sh"

if [[ "${AOC_SMOKE_TEST:-0}" == "1" ]]; then
  exit 0
fi

layout=""
local_layout="$HOME/.config/zellij/layouts/aoc.local.kdl"
aoc_config="$HOME/.config/zellij/aoc.config.kdl"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/aoc"
default_layout_file="${state_dir}/layout_default"

if [[ "${AOC_CLEANUP:-1}" != "0" ]]; then
  if command -v aoc-cleanup >/dev/null 2>&1; then
    cleanup_log="$state_dir/cleanup.log"
    cleanup_lock="$state_dir/cleanup.lock"
    mkdir -p "$state_dir"
    cleanup_delay_secs="${AOC_CLEANUP_LAUNCH_DELAY_SECS:-6}"
    cleanup_min_age_secs="${AOC_CLEANUP_LAUNCH_MIN_AGE_SECS:-300}"
    (
      sleep "$cleanup_delay_secs"
      if command -v flock >/dev/null 2>&1; then
        (
          flock -n 9 || exit 0
          AOC_CLEANUP_INTERACTIVE=0 \
          AOC_CLEANUP_SESSIONS=current \
          AOC_CLEANUP_PANE_STRICT=0 \
          AOC_CLEANUP_REQUIRE_ACTIVE_SIGNALS=1 \
          AOC_CLEANUP_SKIP_IF_NO_SESSIONS=1 \
          AOC_CLEANUP_MIN_PROCESS_AGE_SECS="$cleanup_min_age_secs" \
          aoc-cleanup >>"$cleanup_log" 2>&1
        ) 9>"$cleanup_lock"
      else
        AOC_CLEANUP_INTERACTIVE=0 \
        AOC_CLEANUP_SESSIONS=current \
        AOC_CLEANUP_PANE_STRICT=0 \
        AOC_CLEANUP_REQUIRE_ACTIVE_SIGNALS=1 \
        AOC_CLEANUP_SKIP_IF_NO_SESSIONS=1 \
        AOC_CLEANUP_MIN_PROCESS_AGE_SECS="$cleanup_min_age_secs" \
        aoc-cleanup >>"$cleanup_log" 2>&1
      fi
    ) &
  fi
fi

if [[ -n "${AOC_LAYOUT:-}" ]]; then
  layout="$AOC_LAYOUT"
elif [[ -f "$default_layout_file" ]]; then
  layout="$(cat "$default_layout_file")"
elif [[ -f "$local_layout" ]]; then
  layout="aoc.local"
else
  layout="aoc"
fi

project_session_key() {
  local project_root="${1:-$PWD}"
  if command -v python3 >/dev/null 2>&1; then
    python3 - <<'PY' "$project_root"
import hashlib, os, sys
root = os.path.realpath(sys.argv[1])
print(hashlib.sha1(root.encode()).hexdigest()[:16])
PY
    return
  fi
  sanitize_name "$project_root"
}

persist_project_session_id() {
  local project_root="${1:-$PWD}"
  local session_id="$2"
  local session_dir="$state_dir/project-sessions"
  local session_file="$session_dir/$(project_session_key "$project_root")"
  mkdir -p "$session_dir"
  printf '%s\n' "$session_id" > "$session_file"
}

is_deprecated_project_prefixed_session_id() {
  local project_root="${1:-$PWD}"
  local session_id="$2"
  local project_slug
  project_slug="$(sanitize_name "$(basename "$project_root")")"
  [[ -n "$project_slug" && "$project_slug" != "tab" && "$session_id" == "aoc-${project_slug}-"* ]]
}

resolve_session_id() {
  local project_root="${1:-$PWD}"
  local session_dir="$state_dir/project-sessions"
  local session_file="$session_dir/$(project_session_key "$project_root")"
  local saved_session=""

  if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    printf '%s' "$ZELLIJ_SESSION_NAME"
    return
  fi
  if [[ -n "${ZELLIJ:-}" && -n "${AOC_SESSION_ID:-}" ]]; then
    printf '%s' "$AOC_SESSION_ID"
    return
  fi
  if [[ -n "${AOC_FORCE_SESSION_ID:-}" ]]; then
    persist_project_session_id "$project_root" "$AOC_FORCE_SESSION_ID"
    printf '%s' "$AOC_FORCE_SESSION_ID"
    return
  fi

  # Outside Zellij, default to a fresh engineering session. Reattaching old
  # sessions resurrects stale tabs/process state too often; operators can opt in
  # to legacy attach/reuse behavior with AOC_ATTACH_EXISTING=1.
  if [[ "${AOC_ATTACH_EXISTING:-0}" == "1" && "${AOC_NEW_SESSION:-0}" != "1" && -f "$session_file" ]]; then
    saved_session="$(head -n 1 "$session_file" 2>/dev/null || true)"
    if [[ -n "$saved_session" ]] \
      && ! is_deprecated_project_prefixed_session_id "$project_root" "$saved_session" \
      && session_name_exists "$saved_session"; then
      printf '%s' "$saved_session"
      return
    fi
  fi

  local new_session
  new_session="$(generate_unique_session_id "$project_root")"
  persist_project_session_id "$project_root" "$new_session"
  printf '%s' "$new_session"
}

cleanup_state() {
  local dir="$1"
  # Clean up old temp layout files
  find "$dir" -maxdepth 1 -type f -name 'aoc-layout-*' -mtime +30 -delete 2>/dev/null || true
  # Clean up deprecated root files (legacy)
  find "$dir" -maxdepth 1 -type f -name 'project_root.*' -delete 2>/dev/null || true
}

normalize_layout_name() {
  case "${1:-}" in
    "" ) printf 'aoc' ;;
    unstat|minimal|aoc-zjstatus-single|aoc-zjstatus-test|aoc.hybrid) printf 'aoc' ;;
    *) printf '%s' "$1" ;;
  esac
}

resolve_layout_path() {
  local layout_name="$1"
  local layout_root="${2:-}"
  layout_name="$(normalize_layout_name "$layout_name")"
  if [[ "$layout_name" == /* || "$layout_name" == *.kdl ]]; then
    printf '%s' "$layout_name"
    return
  fi

  if [[ -n "$layout_root" ]]; then
    local project_layout="$layout_root/.aoc/layouts/${layout_name}.kdl"
    if [[ -f "$project_layout" ]]; then
      printf '%s' "$project_layout"
      return
    fi
  fi

  printf '%s' "$HOME/.config/zellij/layouts/${layout_name}.kdl"
}

aoc_config_workspace_root() {
  local config_file="${AOC_CONFIG_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/aoc/config.toml}"
  [[ -f "$config_file" ]] || return 1
  python3 - <<'PY' "$config_file" 2>/dev/null
import re, sys
text=open(sys.argv[1], encoding='utf-8').read()
match=re.search(r'(?m)^\s*workspace_root\s*=\s*["\']([^"\']+)["\']\s*$', text)
if not match:
    raise SystemExit(1)
print(match.group(1))
PY
}

resolve_mission_control_layout_path() {
  local project_root="${1:-$PWD}"
  local workspace_root="${2:-}"
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  local candidates=(
    "$project_root/.aoc/layouts/mission-control.kdl"
    "$PWD/.aoc/layouts/mission-control.kdl"
    "$workspace_root/agent-ops-cockpit/.aoc/layouts/mission-control.kdl"
    "$script_dir/../.aoc/layouts/mission-control.kdl"
    "$HOME/.config/zellij/layouts/mission-control.kdl"
  )
  local candidate
  for candidate in "${candidates[@]}"; do
    if [[ -f "$candidate" ]]; then
      realpath "$candidate" 2>/dev/null || printf '%s' "$candidate"
      return 0
    fi
  done
  return 1
}

resolve_workspace_root() {
  local project_root="${1:-$PWD}"
  if [[ -n "${AOC_WORKSPACE_ROOT:-}" ]]; then
    realpath "$AOC_WORKSPACE_ROOT" 2>/dev/null || printf '%s' "$AOC_WORKSPACE_ROOT"
    return
  fi
  local configured_root
  configured_root="$(aoc_config_workspace_root || true)"
  if [[ -n "$configured_root" ]]; then
    realpath "$configured_root" 2>/dev/null || printf '%s' "$configured_root"
    return
  fi
  local real_project parent base grand
  real_project="$(realpath "$project_root" 2>/dev/null || printf '%s' "$project_root")"
  parent="$(dirname "$real_project")"
  base="$(basename "$parent")"
  case "$base" in
    dev|code|projects|workspaces|src)
      printf '%s' "$parent"
      return
      ;;
  esac
  grand="$(dirname "$parent")"
  case "$(basename "$grand")" in
    dev|code|projects|workspaces|src)
      printf '%s' "$grand"
      return
      ;;
  esac
  printf '%s' "$parent"
}

session_has_mission_control_tab() {
  local session_id="$1"
  command -v zellij >/dev/null 2>&1 || return 1
  local tabs_json
  tabs_json="$(zellij --session "$session_id" action list-tabs --json 2>/dev/null || true)"
  [[ -n "$tabs_json" ]] || return 1
  python3 - "$tabs_json" <<'PY'
import json, sys
try:
    payload=json.loads(sys.argv[1])
except Exception:
    raise SystemExit(1)
items = payload if isinstance(payload, list) else payload.get('tabs') or payload.get('data') or payload.get('items') or []
for tab in items:
    if not isinstance(tab, dict):
        continue
    name = tab.get('name') or tab.get('tab_name') or tab.get('title') or ''
    if str(name).strip().lower() == 'mission control':
        raise SystemExit(0)
raise SystemExit(1)
PY
}

open_project_tab_in_session() {
  local session_id="$1"
  local project_root="$2"
  [[ "${AOC_OPEN_PROJECT_TAB_ON_ATTACH:-1}" != "0" ]] || return 0
  if command -v aoc-new-tab >/dev/null 2>&1; then
    AOC_TARGET_SESSION="$session_id" \
    AOC_LAYOUT="$layout" \
    ZELLIJ_PROJECT_ROOT="$project_root" \
    AOC_PROJECT_ROOT="$project_root" \
    aoc-new-tab --cwd "$project_root" >/dev/null 2>&1 || true
  fi
}

ensure_mission_control_tab() {
  local session_id="$1"
  local workspace_root="$2"
  local mc_layout_path="$3"
  [[ "${AOC_MC_REPAIR:-1}" != "0" ]] || return 0
  [[ "${AOC_MC_FIRST:-1}" != "0" ]] || return 0
  session_has_mission_control_tab "$session_id" && return 0
  if command -v aoc-new-tab >/dev/null 2>&1 && [[ -f "$mc_layout_path" ]]; then
    AOC_TARGET_SESSION="$session_id" \
    ZELLIJ_PROJECT_ROOT="$workspace_root" \
    AOC_PROJECT_ROOT="$workspace_root" \
    aoc-new-tab --layout "$mc_layout_path" --name "Mission Control" --cwd "$workspace_root" >/dev/null 2>&1 || true
  fi
}

sync_aoc_theme_profile() {
  local script_dir theme_env preferred_name=()
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  theme_env="${XDG_CONFIG_HOME:-$HOME/.config}/aoc/theme.env"

  if [[ -f "$theme_env" ]]; then
    local from_profile
    from_profile="$(awk -F '"' '/^[[:space:]]*export[[:space:]]+AOC_THEME_NAME=/{print $2; exit}' "$theme_env")"
    if [[ -n "$from_profile" ]]; then
      preferred_name=(--name "$from_profile")
    fi
  fi

  if [[ -x "$HOME/.local/bin/aoc-theme" ]]; then
    "$HOME/.local/bin/aoc-theme" sync "${preferred_name[@]}" >/dev/null 2>&1 || true
  elif command -v aoc-theme >/dev/null 2>&1; then
    aoc-theme sync "${preferred_name[@]}" >/dev/null 2>&1 || true
  elif [[ -x "$script_dir/aoc-theme" ]]; then
    "$script_dir/aoc-theme" sync "${preferred_name[@]}" >/dev/null 2>&1 || true
  fi
}

load_aoc_theme_values() {
  AOC_THEME_BLUE="#89B4FA"
  AOC_THEME_GREEN="#A6E3A1"
  AOC_THEME_RED="#F38BA8"
  AOC_THEME_ORANGE="#FAB387"
  AOC_THEME_YELLOW="#F9E2AF"
  AOC_THEME_CYAN="#94E2D5"
  AOC_THEME_MAGENTA="#CBA6F7"
  AOC_THEME_BLACK="#6C7086"
  AOC_THEME_WHITE="#9399B2"

  AOC_THEME_UI_PRIMARY="$AOC_THEME_WHITE"
  AOC_THEME_UI_MUTED="$AOC_THEME_BLACK"
  AOC_THEME_UI_ACCENT="$AOC_THEME_BLUE"
  AOC_THEME_BG_BASE="#1E1E2E"
  AOC_THEME_BG_ELEVATED="$AOC_THEME_BLACK"
  AOC_THEME_BG_SUBTLE="$AOC_THEME_BLACK"
  AOC_THEME_BG_ACCENT="$AOC_THEME_BLUE"

  local theme_env="${XDG_CONFIG_HOME:-$HOME/.config}/aoc/theme.env"
  if [[ -f "$theme_env" ]]; then
    # shellcheck disable=SC1090
    source "$theme_env"
  fi
}


layout="$(normalize_layout_name "$layout")"
if [[ -z "$layout" ]]; then
  layout="aoc"
fi

config_arg=()
if [[ -n "${AOC_ZELLIJ_CONFIG:-}" ]]; then
  config_arg=(--config "$AOC_ZELLIJ_CONFIG")
elif [[ -f "$aoc_config" ]]; then
  config_arg=(--config "$aoc_config")
fi

project_root="${ZELLIJ_PROJECT_ROOT:-$PWD}"
workspace_root="$(resolve_workspace_root "$project_root")"
launch_agent="${AOC_LAUNCH_AGENT_ID:-${AOC_AGENT_ID:-}}"

background_task() {
  (
    "$@"
  ) >/dev/null 2>&1 &
}

mkdir -p "$state_dir"
cleanup_state "$state_dir"
load_aoc_theme_values

session_root="$project_root"
if [[ -z "${ZELLIJ:-}" && "${AOC_MC_FIRST:-1}" != "0" ]]; then
  session_root="$workspace_root"
fi
session_id="$(resolve_session_id "$session_root")"
if ! session_name_exists "$session_id" && command -v aoc-session-state >/dev/null 2>&1; then
  restore_env="$(aoc-session-state initial-env "$session_id" 2>/dev/null || true)"
  if [[ -n "$restore_env" ]]; then
    eval "$restore_env"
    layout="${AOC_RESTORE_LAYOUT:-$layout}"
    project_root="${AOC_RESTORE_PROJECT_ROOT:-$project_root}"
  fi
fi
hub_addr="$(resolve_hub_addr "$session_id")"
hub_url="$(resolve_hub_url "$hub_addr")"
background_task ensure_hub_running "$session_id" "$hub_addr" "$state_dir"
background_task sync_aoc_theme_profile

# Default to a short plain tab label. Operators can opt into grouping later by
# renaming tabs to a numeric-prefix form like "2 Review".
raw_name="$(basename "$project_root")"
tab_name="${AOC_RESTORE_TAB_NAME:-$(aoc_build_tab_name "$project_root" "$(aoc_default_tab_label "$project_root")")}"

# Agent ID is the raw repo name used for launch metadata and session context.
agent_id="$raw_name"

layout_path="$(resolve_layout_path "$layout" "$project_root")"
layout_arg="$layout"

if [[ -f "$layout_path" ]]; then
  layout_label="$(sanitize_name "$(basename "$layout")")"
  layout_tmp="$state_dir/aoc-layout-${layout_label}-${agent_id}.kdl"
  
  # Inject tab name, agent id, and project root into layout template
  awk -v tab_name="$tab_name" \
      -v agent_id="$agent_id" \
      -v launch_agent="$launch_agent" \
      -v proj_root="$project_root" \
      -v session_id="$session_id" \
      -v hub_addr="$hub_addr" \
      -v hub_url="$hub_url" \
      -v theme_blue="$AOC_THEME_BLUE" \
      -v theme_green="$AOC_THEME_GREEN" \
      -v theme_red="$AOC_THEME_RED" \
      -v theme_orange="$AOC_THEME_ORANGE" \
      -v theme_yellow="$AOC_THEME_YELLOW" \
      -v theme_cyan="$AOC_THEME_CYAN" \
      -v theme_magenta="$AOC_THEME_MAGENTA" \
      -v theme_black="$AOC_THEME_BLACK" \
      -v theme_white="$AOC_THEME_WHITE" \
      -v theme_ui_primary="$AOC_THEME_UI_PRIMARY" \
      -v theme_ui_muted="$AOC_THEME_UI_MUTED" \
      -v theme_ui_accent="$AOC_THEME_UI_ACCENT" \
      -v theme_bg_base="$AOC_THEME_BG_BASE" \
      -v theme_bg_elevated="$AOC_THEME_BG_ELEVATED" \
      -v theme_bg_subtle="$AOC_THEME_BG_SUBTLE" \
      -v theme_bg_accent="$AOC_THEME_BG_ACCENT" \
      -v home_dir="$HOME" '
  {
    gsub(/\{\{HOME\}\}/, home_dir)
    gsub(/__AOC_TAB_NAME__/, tab_name)
    gsub(/__AOC_AGENT_ID__/, agent_id)
    gsub(/__AOC_PROJECT_ROOT__/, proj_root)
    gsub(/__AOC_SESSION_ID__/, session_id)
    gsub(/__AOC_HUB_ADDR__/, hub_addr)
    gsub(/__AOC_HUB_URL__/, hub_url)
    gsub(/__AOC_THEME_BLUE__/, theme_blue)
    gsub(/__AOC_THEME_GREEN__/, theme_green)
    gsub(/__AOC_THEME_RED__/, theme_red)
    gsub(/__AOC_THEME_ORANGE__/, theme_orange)
    gsub(/__AOC_THEME_YELLOW__/, theme_yellow)
    gsub(/__AOC_THEME_CYAN__/, theme_cyan)
    gsub(/__AOC_THEME_MAGENTA__/, theme_magenta)
    gsub(/__AOC_THEME_BLACK__/, theme_black)
    gsub(/__AOC_THEME_WHITE__/, theme_white)
    gsub(/__AOC_THEME_UI_PRIMARY__/, theme_ui_primary)
    gsub(/__AOC_THEME_UI_MUTED__/, theme_ui_muted)
    gsub(/__AOC_THEME_UI_ACCENT__/, theme_ui_accent)
    gsub(/__AOC_THEME_BG_BASE__/, theme_bg_base)
    gsub(/__AOC_THEME_BG_ELEVATED__/, theme_bg_elevated)
    gsub(/__AOC_THEME_BG_SUBTLE__/, theme_bg_subtle)
    gsub(/__AOC_THEME_BG_ACCENT__/, theme_bg_accent)
    if (launch_agent != "") {
      gsub(/AOC_AGENT_RUN=1 exec /, "AOC_AGENT_ID=" launch_agent " AOC_AGENT_RUN=1 exec ")
    }
    print
  }
' "$layout_path" > "$layout_tmp"
  layout_arg="$layout_tmp"

fi

# Project identification exported for layout template substitution
export AOC_ROOT_TAG="$agent_id"

pulse_cmd="${AOC_PULSE_CMD:-}"
if [[ -z "$pulse_cmd" ]]; then
  if [[ "$layout" == "mission-control" ]]; then
    pulse_cmd="aoc-mission-control"
  else
    pulse_cmd="aoc-pulse-pane"
  fi
fi

# If running inside Zellij, launch a new tab in the current session
if [[ -n "${ZELLIJ:-}" ]]; then
  AOC_SESSION_ID="$session_id" \
    AOC_HUB_ADDR="$hub_addr" \
    AOC_HUB_URL="$hub_url" \
    AOC_PROJECT_ROOT="$project_root" \
    AOC_PULSE_CMD="$pulse_cmd" \
    zellij action new-tab --layout "$layout_arg"
  aoc_focus_agent_after_new_tab "$layout"
  exit 0
fi

# Otherwise, attach to a stable project session when possible.
# - active session: attach
# - serialized/dead session: resurrect via attach
# - missing session: create with the configured layout
attach_env=(
  ZELLIJ_PROJECT_ROOT="$project_root"
  AOC_PROJECT_ROOT="$project_root"
  AOC_SESSION_ID="$session_id"
  AOC_HUB_ADDR="$hub_addr"
  AOC_HUB_URL="$hub_url"
  AOC_ROOT_TAG="$agent_id"
  AOC_PULSE_CMD="$pulse_cmd"
)

if session_name_exists "$session_id"; then
  if [[ -z "${ZELLIJ:-}" && "$layout" != "mission-control" ]]; then
    mc_layout_path="$(resolve_mission_control_layout_path "$project_root" "$workspace_root" || true)"
    ensure_mission_control_tab "$session_id" "$workspace_root" "$mc_layout_path"
    open_project_tab_in_session "$session_id" "$project_root"
  fi
  # -f/--force-run-commands makes Zellij re-run layout commands when attaching
  # to a serialized dead session, avoiding resurrected panes that only show
  # "dead terminal" for yazi, PI agent, Taskmaster, etc.
  env "${attach_env[@]}" zellij "${config_arg[@]}" attach --force-run-commands "$session_id"
  exit 0
fi

session_arg=(--session "$session_id")

if [[ "${AOC_MC_FIRST:-1}" != "0" && "$layout" != "mission-control" ]]; then
  mc_layout_path="$(resolve_mission_control_layout_path "$project_root" "$workspace_root" || true)"
  if [[ -f "$mc_layout_path" && -f "$layout_arg" ]]; then
    mc_agent_id="$(basename "$workspace_root")"
    mc_tmp="$state_dir/aoc-layout-mission-control-${mc_agent_id}.kdl"
    awk -v tab_name="Mission Control" \
        -v agent_id="$mc_agent_id" \
        -v launch_agent="" \
        -v proj_root="$workspace_root" \
        -v session_id="$session_id" \
        -v hub_addr="$hub_addr" \
        -v hub_url="$hub_url" \
        -v theme_blue="$AOC_THEME_BLUE" \
        -v theme_green="$AOC_THEME_GREEN" \
        -v theme_red="$AOC_THEME_RED" \
        -v theme_orange="$AOC_THEME_ORANGE" \
        -v theme_yellow="$AOC_THEME_YELLOW" \
        -v theme_cyan="$AOC_THEME_CYAN" \
        -v theme_magenta="$AOC_THEME_MAGENTA" \
        -v theme_black="$AOC_THEME_BLACK" \
        -v theme_white="$AOC_THEME_WHITE" \
        -v theme_ui_primary="$AOC_THEME_UI_PRIMARY" \
        -v theme_ui_muted="$AOC_THEME_UI_MUTED" \
        -v theme_ui_accent="$AOC_THEME_UI_ACCENT" \
        -v theme_bg_base="$AOC_THEME_BG_BASE" \
        -v theme_bg_elevated="$AOC_THEME_BG_ELEVATED" \
        -v theme_bg_subtle="$AOC_THEME_BG_SUBTLE" \
        -v theme_bg_accent="$AOC_THEME_BG_ACCENT" \
        -v home_dir="$HOME" '
    {
      gsub(/\{\{HOME\}\}/, home_dir)
      gsub(/__AOC_TAB_NAME__/, tab_name)
      gsub(/__AOC_AGENT_ID__/, agent_id)
      gsub(/__AOC_PROJECT_ROOT__/, proj_root)
      gsub(/__AOC_SESSION_ID__/, session_id)
      gsub(/__AOC_HUB_ADDR__/, hub_addr)
      gsub(/__AOC_HUB_URL__/, hub_url)
      gsub(/__AOC_THEME_BLUE__/, theme_blue)
      gsub(/__AOC_THEME_GREEN__/, theme_green)
      gsub(/__AOC_THEME_RED__/, theme_red)
      gsub(/__AOC_THEME_ORANGE__/, theme_orange)
      gsub(/__AOC_THEME_YELLOW__/, theme_yellow)
      gsub(/__AOC_THEME_CYAN__/, theme_cyan)
      gsub(/__AOC_THEME_MAGENTA__/, theme_magenta)
      gsub(/__AOC_THEME_BLACK__/, theme_black)
      gsub(/__AOC_THEME_WHITE__/, theme_white)
      gsub(/__AOC_THEME_UI_PRIMARY__/, theme_ui_primary)
      gsub(/__AOC_THEME_UI_MUTED__/, theme_ui_muted)
      gsub(/__AOC_THEME_UI_ACCENT__/, theme_ui_accent)
      gsub(/__AOC_THEME_BG_BASE__/, theme_bg_base)
      gsub(/__AOC_THEME_BG_ELEVATED__/, theme_bg_elevated)
      gsub(/__AOC_THEME_BG_SUBTLE__/, theme_bg_subtle)
      gsub(/__AOC_THEME_BG_ACCENT__/, theme_bg_accent)
      print
    }
' "$mc_layout_path" > "$mc_tmp"
    bootstrap_tmp="$state_dir/aoc-layout-bootstrap-${agent_id}.kdl"
    python3 - <<'PY' "$mc_tmp" "$layout_arg" "$bootstrap_tmp"
import re
import sys

def body(path):
    text=open(path).read()
    start=text.find('{')
    end=text.rfind('}')
    if start == -1 or end == -1 or end <= start:
        raise SystemExit(f'invalid layout: {path}')
    return text[start+1:end].strip()

def defocus_tabs(kdl):
    # Zellij allows only one focused tab in a layout. Keep Mission Control focused
    # and defocus all tabs from the appended project layout.
    return re.sub(r'(\btab\b[^{}\n]*?)\s+focus=true(\s*\{)', r'\1\2', kdl)

mc, project, out = sys.argv[1:]
open(out, 'w').write('layout {\n' + body(mc) + '\n\n' + defocus_tabs(body(project)) + '\n}\n')
PY
    layout_arg="$bootstrap_tmp"
  fi
fi

env "${attach_env[@]}" zellij "${config_arg[@]}" "${session_arg[@]}" --new-session-with-layout "$layout_arg"
