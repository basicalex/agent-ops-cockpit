#!/usr/bin/env bash
set -euo pipefail

UA_REPO_URL="${AOC_UNDERSTAND_REPO_URL:-https://github.com/Lum1104/Understand-Anything.git}"
UA_REF="${AOC_UNDERSTAND_REF:-main}"
UA_HOME="${AOC_UNDERSTAND_HOME:-$HOME/.local/share/aoc/tools/understand-anything}"
UA_SOURCE="${AOC_UNDERSTAND_SOURCE:-$UA_HOME/source}"
UA_PLUGIN_DIR="${AOC_UNDERSTAND_PLUGIN_DIR:-$UA_SOURCE/understand-anything-plugin}"

usage() {
  cat <<'EOF'
Usage: aoc-understand <command> [options]

AOC bridge for Understand-Anything: repo knowledge graph, dashboard, explain/chat/onboard flows.

Commands:
  install              Clone/update global Understand-Anything checkout and build packages
  status               Show install and project graph status (read-only)
  doctor               Check prerequisites and install health (read-only)
  analyze [args...]    Print Pi /skill:understand analysis guidance
  dashboard [--open]   Start the UA dashboard for this project's graph
  chat QUERY           Print graph-aware /skill:understand-chat guidance
  explain TARGET       Print graph-aware /skill:understand-explain guidance
  onboard              Print graph-aware /skill:understand-onboard guidance
  domain [args...]     Print Pi /skill:understand-domain guidance
  diff [args...]       Print Pi /skill:understand-diff guidance
  gaps [direction...]  Print Pi /skill:aoc-gaps gap-audit guidance
  map-sync             Create/update an AOC Map overview page from UA graph metadata
  refresh              Refresh generated graph artifacts and optionally commit them
  hook install         Install project-local post-commit graph refresh hook
  hook uninstall       Remove the project-local post-commit graph refresh hook
  hook status          Show project-local post-commit graph refresh hook status
  open                 Alias for dashboard --open

Options:
  --root PATH          Project root (default: nearest .aoc/.git)
  --home PATH          Global tool home (default: ~/.local/share/aoc/tools/understand-anything)
  --source PATH        Global Understand-Anything source checkout path
  --ref REF            Git ref for install/update (default: main)
  --repo URL           Git repo URL for install/update
  --open               Open browser after dashboard start
  -h, --help           Show this help

Notes:
  install is explicit; status/doctor never clone, install dependencies, or run analysis.
  analyze/domain/diff/gaps are agent-skill powered; this wrapper makes the correct
  project-root and Pi /skill:<name> flow explicit until UA exposes stable noninteractive CLIs.
  hook install is opt-in and project-local; it enqueues refresh in the background after commits.
EOF
}

log() { echo ">> $*"; }
warn() { echo "!! $*" >&2; }
fail() { warn "$*"; exit 1; }

resolve_root() {
  local dir="${1:-$PWD}"
  dir="$(cd "$dir" 2>/dev/null && pwd)" || return 1
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.aoc" || -d "$dir/.git" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

open_url() {
  local url="$1"
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 || warn "Could not open $url"
  elif command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1 || warn "Could not open $url"
  else
    log "Open: $url"
  fi
}

require_plugin() {
  [[ -f "$UA_PLUGIN_DIR/package.json" ]] || fail "Understand-Anything not installed at $UA_PLUGIN_DIR. Run: aoc-understand install"
}

exclude_project_understand_skill_links() {
  local root="$1" exclude_path
  exclude_path="$(git -C "$root" rev-parse --git-path info/exclude 2>/dev/null || true)"
  [[ -n "$exclude_path" ]] || return 0
  mkdir -p "$(dirname "$exclude_path")"
  touch "$exclude_path"
  grep -qxF '# AOC Understand local skill links' "$exclude_path" 2>/dev/null || echo '# AOC Understand local skill links' >>"$exclude_path"
  grep -qxF '.agents/skills/understand' "$exclude_path" 2>/dev/null || echo '.agents/skills/understand' >>"$exclude_path"
  grep -qxF '.agents/skills/understand-*' "$exclude_path" 2>/dev/null || echo '.agents/skills/understand-*' >>"$exclude_path"
  grep -qxF '.agents/skills/aoc-gaps' "$exclude_path" 2>/dev/null || echo '.agents/skills/aoc-gaps' >>"$exclude_path"
}

sync_project_understand_skills() {
  local root="$1"
  require_plugin
  local project_skills="$root/.agents/skills"
  mkdir -p "$project_skills"
  local skill_dir skill_name
  for skill_dir in "$UA_PLUGIN_DIR"/skills/*; do
    [[ -d "$skill_dir" && -f "$skill_dir/SKILL.md" ]] || continue
    skill_name="$(basename "$skill_dir")"
    ln -sfn "$skill_dir" "$project_skills/$skill_name"
  done
  exclude_project_understand_skill_links "$root"
}

sync_project_aoc_gaps_skill() {
  local root="$1"
  local script_dir source_dir candidate project_skills
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  if [[ -f "$root/.pi/skills/aoc-gaps/SKILL.md" ]]; then
    exclude_project_understand_skill_links "$root"
    return 0
  fi
  for candidate in \
    "${AOC_GAPS_SKILL_SOURCE:-}" \
    "$script_dir/../.pi/skills/aoc-gaps" \
    "$HOME/dev/agent-ops-cockpit/.pi/skills/aoc-gaps"; do
    if [[ -n "$candidate" && -f "$candidate/SKILL.md" ]]; then
      source_dir="$candidate"
      break
    fi
  done
  [[ -n "${source_dir:-}" ]] || return 0
  project_skills="$root/.agents/skills/aoc-gaps"
  mkdir -p "$project_skills"
  cp -f "$source_dir/SKILL.md" "$project_skills/SKILL.md"
  exclude_project_understand_skill_links "$root"
}

project_graph_path() { printf '%s/.understand-anything/knowledge-graph.json\n' "$1"; }
project_domain_graph_path() { printf '%s/.understand-anything/domain-graph.json\n' "$1"; }
project_hook_path() { printf '%s/.git/hooks/post-commit\n' "$1"; }
project_refresh_log_path() { printf '%s/.aoc/logs/understand-refresh.log\n' "$1"; }

is_allowed_refresh_artifact() {
  case "$1" in
    .understand-anything/*|.aoc/map/index.html|.aoc/map/manifest.json|.aoc/map/assets/*|.aoc/map/pages/understand-overview.html|.aoc/map/diagrams/understand-overview.mmd)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

repo_has_unrelated_dirty() {
  local root="$1" path
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    if ! is_allowed_refresh_artifact "$path"; then
      return 0
    fi
  done < <(git -C "$root" status --porcelain=v1 -uall | sed -E 's/^...//; s/^.* -> //')
  return 1
}

refresh_artifacts_changed() {
  local root="$1" path
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    if is_allowed_refresh_artifact "$path"; then
      return 0
    fi
  done < <(git -C "$root" status --porcelain=v1 -uall | sed -E 's/^...//; s/^.* -> //')
  return 1
}

stage_refresh_artifacts() {
  local root="$1" path staged=0
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    if is_allowed_refresh_artifact "$path"; then
      git -C "$root" add -- "$path"
      staged=1
    fi
  done < <(git -C "$root" status --porcelain=v1 -uall | sed -E 's/^...//; s/^.* -> //')
  [[ "$staged" == "1" ]]
}

print_skill_command() {
  local root="$1" slash="$2"
  shift 2
  echo "projectRoot: $root"
  echo "understandAnythingInstalled: $([[ -f "$UA_PLUGIN_DIR/package.json" ]] && echo true || echo false)"
  echo "Run in Pi chat from the project root (not in a shell):"
  printf '  %s' "$slash"
  if [[ $# -gt 0 && -n "${*// }" ]]; then
    printf ' %s' "$*"
  fi
  printf '\n'
}

start_dashboard() {
  local root="$1" open_after="$2"
  require_plugin
  local graph
  graph="$(project_graph_path "$root")"
  [[ -f "$graph" ]] || fail "No knowledge graph found at $graph. Run /skill:understand --full in Pi, or aoc-understand analyze first."
  command -v pnpm >/dev/null 2>&1 || fail "pnpm missing. Install Node.js/pnpm before launching the dashboard."
  local dashboard_dir="$UA_PLUGIN_DIR/packages/dashboard"
  [[ -d "$dashboard_dir" ]] || fail "Dashboard package missing: $dashboard_dir"
  (cd "$UA_PLUGIN_DIR" && pnpm install --frozen-lockfile 2>/dev/null || pnpm install)
  (cd "$UA_PLUGIN_DIR" && pnpm --filter @understand-anything/core build)
  log "Starting Understand-Anything dashboard for $root"
  if [[ "$open_after" == "1" ]]; then
    (cd "$dashboard_dir" && GRAPH_DIR="$root" npx vite --host 127.0.0.1 --open)
  else
    (cd "$dashboard_dir" && GRAPH_DIR="$root" npx vite --host 127.0.0.1)
  fi
}

map_sync() {
  local root="$1"
  local graph="$root/.understand-anything/knowledge-graph.json"
  [[ -f "$graph" ]] || fail "No knowledge graph found at $graph. Run /skill:understand --full first."
  mkdir -p "$root/.aoc/map/pages" "$root/.aoc/map/diagrams"
  python3 - "$root" "$graph" <<'PY'
import json, sys
from datetime import datetime, timezone
from pathlib import Path
root = Path(sys.argv[1])
graph_path = Path(sys.argv[2])
graph = json.loads(graph_path.read_text(encoding='utf-8'))
project = graph.get('project', {})
nodes = graph.get('nodes') or []
edges = graph.get('edges') or []
layers = graph.get('layers') or []
tour = graph.get('tour') or []
name = project.get('name') or root.name
languages = ', '.join(project.get('languages') or []) or 'unknown'
frameworks = ', '.join(project.get('frameworks') or []) or 'none detected'
updated = datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z')

diagram = root / '.aoc/map/diagrams/understand-overview.mmd'
layer_lines = ['flowchart LR', '  graph["Understand-Anything graph"]']
for i, layer in enumerate(layers[:10], 1):
    lid = f'L{i}'
    title = str(layer.get('name') or layer.get('id') or f'Layer {i}').replace('"', "'")
    count = len(layer.get('nodeIds') or [])
    layer_lines.append(f'  graph --> {lid}["{title}<br/>{count} nodes"]')
if not layers:
    layer_lines.append('  graph --> nodes["Graph nodes"]')
diagram.write_text('\n'.join(layer_lines) + '\n', encoding='utf-8')

page = root / '.aoc/map/pages/understand-overview.html'
layer_items = '\n'.join(
    f'<li><strong>{(l.get("name") or l.get("id") or "Layer")}</strong>: {len(l.get("nodeIds") or [])} nodes — {(l.get("description") or "")}</li>'
    for l in layers[:12]
) or '<li>No layers recorded in the graph.</li>'
tour_items = '\n'.join(
    f'<li><strong>{t.get("order", i+1)}. {t.get("title", "Tour step")}</strong>: {t.get("description", "")}</li>'
    for i, t in enumerate(tour[:8])
) or '<li>No guided tour recorded in the graph.</li>'
html = f'''<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Understand Overview</title>
  <meta name="aoc-map:summary" content="Understand-Anything graph overview for {name}">
  <meta name="aoc-map:section" content="architecture">
  <meta name="aoc-map:kind" content="topology">
  <meta name="aoc-map:status" content="active">
  <meta name="aoc-map:diagram" content="diagrams/understand-overview.mmd">
  <meta name="aoc-map:tags" content="understand,knowledge-graph,onboarding">
  <script defer src="../assets/mermaid.min.js"></script>
  <script defer src="../assets/render-mermaid.js"></script>
  <style>body{{font-family:system-ui,sans-serif;margin:2rem;line-height:1.5}}.panel{{border:1px solid #ddd;border-radius:12px;padding:1rem;margin:1rem 0}}code{{background:#f4f4f4;padding:.1rem .25rem;border-radius:4px}}</style>
</head>
<body>
  <h1>Understand Overview</h1>
  <p>Generated from <code>.understand-anything/knowledge-graph.json</code> for <strong>{name}</strong>.</p>
  <div class="panel">
    <script type="text/plain" data-aoc-map-mermaid-src="../diagrams/understand-overview.mmd"></script>
  </div>
  <div class="panel">
    <h2>Graph metrics</h2>
    <ul>
      <li>Nodes: {len(nodes)}</li>
      <li>Edges: {len(edges)}</li>
      <li>Layers: {len(layers)}</li>
      <li>Tour steps: {len(tour)}</li>
      <li>Languages: {languages}</li>
      <li>Frameworks: {frameworks}</li>
      <li>Synced: {updated}</li>
    </ul>
  </div>
  <div class="panel"><h2>Layers</h2><ul>{layer_items}</ul></div>
  <div class="panel"><h2>Guided tour</h2><ol>{tour_items}</ol></div>
  <p>Run <code>aoc-understand dashboard --open</code> for the full interactive graph.</p>
</body>
</html>
'''
page.write_text(html, encoding='utf-8')
print(page.relative_to(root).as_posix())
PY
  if command -v aoc-map >/dev/null 2>&1; then
    (cd "$root" && aoc-map build >/dev/null) || warn "aoc-map build failed; page was still written."
  fi
}

install_refresh_hook() {
  local root="$1" hook log_path
  [[ -d "$root/.git" ]] || fail "Refresh hook install requires a normal .git directory: $root"
  hook="$(project_hook_path "$root")"
  log_path="$(project_refresh_log_path "$root")"
  mkdir -p "$(dirname "$hook")" "$(dirname "$log_path")"
  if [[ -f "$hook" ]] && ! grep -q 'AOC Understand graph refresh hook' "$hook" 2>/dev/null; then
    fail "Refusing to overwrite non-AOC post-commit hook: $hook"
  fi
  cat >"$hook" <<'HOOK'
#!/usr/bin/env bash
# AOC Understand graph refresh hook
set -euo pipefail

[[ "${AOC_UNDERSTAND_REFRESH:-0}" == "1" ]] && exit 0
root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
sha="$(git rev-parse --verify HEAD 2>/dev/null || true)"
log="$root/.aoc/logs/understand-refresh.log"
mkdir -p "$(dirname "$log")"
{
  printf '\n[%s] queued graph refresh for %s\n' "$(date -Iseconds)" "$sha"
  if command -v aoc-understand >/dev/null 2>&1; then
    nohup env AOC_UNDERSTAND_REFRESH=1 aoc-understand --root "$root" refresh --source-commit "$sha" --commit >>"$log" 2>&1 &
  else
    printf '[%s] aoc-understand not found; skipping\n' "$(date -Iseconds)"
  fi
} >>"$log" 2>&1
HOOK
  chmod +x "$hook"
  log "Installed post-commit Understand refresh hook: $hook"
  log "Refresh log: $log_path"
}

uninstall_refresh_hook() {
  local root="$1" hook
  hook="$(project_hook_path "$root")"
  if [[ -f "$hook" ]] && grep -q 'AOC Understand graph refresh hook' "$hook" 2>/dev/null; then
    rm -f "$hook"
    log "Removed Understand refresh hook: $hook"
  elif [[ -f "$hook" ]]; then
    fail "Refusing to remove non-AOC post-commit hook: $hook"
  else
    log "No post-commit hook installed at $hook"
  fi
}

status_refresh_hook() {
  local root="$1" hook log_path
  hook="$(project_hook_path "$root")"
  log_path="$(project_refresh_log_path "$root")"
  echo "projectRoot: $root"
  echo "hookPath: $hook"
  if [[ -f "$hook" ]] && grep -q 'AOC Understand graph refresh hook' "$hook" 2>/dev/null; then
    echo "hookInstalled: true"
  else
    echo "hookInstalled: false"
  fi
  echo "logPath: $log_path"
  echo "logPresent: $([[ -f "$log_path" ]] && echo true || echo false)"
}

refresh_generated_artifacts() {
  local root="$1" source_commit="$2" do_commit="$3" lock_dir message
  [[ -n "$source_commit" ]] || source_commit="$(git -C "$root" rev-parse --verify HEAD 2>/dev/null || true)"
  lock_dir="$(git -C "$root" rev-parse --git-path aoc-understand-refresh.lock)"
  if ! mkdir "$lock_dir" 2>/dev/null; then
    log "Understand refresh already running; skipping."
    return 0
  fi
  trap 'rm -rf "$lock_dir"' RETURN

  if repo_has_unrelated_dirty "$root"; then
    warn "Repo has unrelated dirty files; refusing automatic graph refresh commit."
    warn "Run from a clean worktree or refresh manually with aoc-understand map-sync."
    return 0
  fi

  if [[ -n "${AOC_UNDERSTAND_REFRESH_CMD:-}" ]]; then
    log "Running configured graph refresh command."
    (cd "$root" && eval "$AOC_UNDERSTAND_REFRESH_CMD")
  else
    log "No noninteractive Understand analyzer configured; syncing existing graph into AOC Map."
  fi

  if [[ -f "$(project_graph_path "$root")" ]]; then
    map_sync "$root"
  else
    warn "No Understand graph found at $(project_graph_path "$root"); nothing to sync."
    return 0
  fi

  if ! refresh_artifacts_changed "$root"; then
    log "No generated graph artifact changes detected."
    return 0
  fi

  if [[ "$do_commit" != "1" ]]; then
    log "Generated graph artifacts changed; leaving them unstaged because --commit was not requested."
    return 0
  fi

  stage_refresh_artifacts "$root" || return 0
  if git -C "$root" diff --cached --quiet --; then
    log "No staged graph artifact changes detected."
    return 0
  fi
  message="chore(graph): refresh repository knowledge graph"
  git -C "$root" -c user.useConfigOnly=false commit \
    -m "$message" \
    -m "Refresh generated graph artifacts after source commit ${source_commit:-unknown}." \
    -m "AOC-Source-Commit: ${source_commit:-unknown}" \
    -m "AOC-Intent: Keep project graph/map artifacts aligned with the committed repository state." \
    -m "Tests: aoc-understand refresh --source-commit ${source_commit:-unknown} --commit" \
    -m "Risk: low; stages only generated Understand/AOC Map graph artifacts."
}

root=""
open_after=0
do_commit=0
source_commit=""
command=""
args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --root) [[ $# -ge 2 ]] || fail "--root requires a value"; root="$2"; shift 2 ;;
    --home) [[ $# -ge 2 ]] || fail "--home requires a value"; UA_HOME="$2"; UA_SOURCE="${AOC_UNDERSTAND_SOURCE:-$UA_HOME/source}"; UA_PLUGIN_DIR="${AOC_UNDERSTAND_PLUGIN_DIR:-$UA_SOURCE/understand-anything-plugin}"; shift 2 ;;
    --source) [[ $# -ge 2 ]] || fail "--source requires a value"; UA_SOURCE="$2"; UA_PLUGIN_DIR="${AOC_UNDERSTAND_PLUGIN_DIR:-$UA_SOURCE/understand-anything-plugin}"; shift 2 ;;
    --ref) [[ $# -ge 2 ]] || fail "--ref requires a value"; UA_REF="$2"; shift 2 ;;
    --repo) [[ $# -ge 2 ]] || fail "--repo requires a value"; UA_REPO_URL="$2"; shift 2 ;;
    --source-commit) [[ $# -ge 2 ]] || fail "--source-commit requires a value"; source_commit="$2"; shift 2 ;;
    --commit) do_commit=1; shift ;;
    --no-commit) do_commit=0; shift ;;
    --open) open_after=1; shift ;;
    --help|-h) usage; exit 0 ;;
    *) if [[ -z "$command" ]]; then command="$1"; else args+=("$1"); fi; shift ;;
  esac
done
command="${command:-status}"

case "$command" in
  install)
    command -v git >/dev/null 2>&1 || fail "git missing"
    command -v node >/dev/null 2>&1 || fail "node missing; Understand-Anything requires Node.js"
    command -v corepack >/dev/null 2>&1 || warn "corepack missing; pnpm may need manual install"
    mkdir -p "$UA_HOME"
    if [[ -d "$UA_SOURCE/.git" ]]; then
      log "Updating Understand-Anything at $UA_SOURCE"
      (cd "$UA_SOURCE" && git fetch --tags origin && git checkout "$UA_REF" && git pull --ff-only || true)
    else
      log "Cloning Understand-Anything $UA_REF into $UA_SOURCE"
      git clone --branch "$UA_REF" "$UA_REPO_URL" "$UA_SOURCE"
    fi
    if command -v corepack >/dev/null 2>&1; then corepack enable || true; fi
    command -v pnpm >/dev/null 2>&1 || fail "pnpm missing after corepack. Install pnpm and rerun."
    (cd "$UA_PLUGIN_DIR" && pnpm install && pnpm --filter @understand-anything/core build)
    root="${root:-$(resolve_root "$PWD" 2>/dev/null || true)}"
    if [[ -n "$root" ]]; then
      sync_project_understand_skills "$root"
      sync_project_aoc_gaps_skill "$root"
      log "Understand-Anything installed for project $root. In Pi, use: /skill:understand"
    else
      log "Understand-Anything installed. Run from an AOC/git project to sync project-local Pi skills."
    fi
    ;;
  status)
    root="${root:-$(resolve_root "$PWD" 2>/dev/null || true)}"
    echo "understandSource: $UA_SOURCE"
    echo "understandPluginDir: $UA_PLUGIN_DIR"
    echo "understandInstalled: $([[ -f "$UA_PLUGIN_DIR/package.json" ]] && echo true || echo false)"
    if [[ -n "$root" ]]; then
      echo "projectRoot: $root"
      echo "knowledgeGraph: $(project_graph_path "$root")"
      echo "knowledgeGraphPresent: $([[ -f "$(project_graph_path "$root")" ]] && echo true || echo false)"
      echo "domainGraphPresent: $([[ -f "$(project_domain_graph_path "$root")" ]] && echo true || echo false)"
    else
      echo "projectRoot: <not found>"
    fi
    ;;
  doctor)
    echo "git: $(command -v git || true)"
    echo "node: $(node --version 2>/dev/null || echo missing)"
    echo "pnpm: $(pnpm --version 2>/dev/null || echo missing)"
    echo "corepack: $(command -v corepack || true)"
    echo "source: $UA_SOURCE"
    echo "pluginDir: $UA_PLUGIN_DIR"
    [[ -f "$UA_PLUGIN_DIR/package.json" ]] && echo "installed: true" || echo "installed: false"
    [[ -d "$UA_PLUGIN_DIR/packages/dashboard" ]] && echo "dashboard: present" || echo "dashboard: missing"
    [[ -f "$UA_PLUGIN_DIR/packages/core/dist/index.js" ]] && echo "coreBuild: present" || echo "coreBuild: missing"
    ;;
  analyze)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    sync_project_understand_skills "$root" 2>/dev/null || true
    print_skill_command "$root" "/skill:understand" "${args[*]:-}"
    ;;
  domain)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    sync_project_understand_skills "$root" 2>/dev/null || true
    print_skill_command "$root" "/skill:understand-domain" "${args[*]:-}"
    ;;
  diff)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    sync_project_understand_skills "$root" 2>/dev/null || true
    print_skill_command "$root" "/skill:understand-diff" "${args[*]:-}"
    ;;
  gaps)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    sync_project_understand_skills "$root" 2>/dev/null || true
    sync_project_aoc_gaps_skill "$root" 2>/dev/null || true
    print_skill_command "$root" "/skill:aoc-gaps" "${args[*]:-}"
    ;;
  chat)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    [[ ${#args[@]} -gt 0 ]] || fail "chat requires a query"
    sync_project_understand_skills "$root" 2>/dev/null || true
    print_skill_command "$root" "/skill:understand-chat" "${args[*]}"
    ;;
  explain)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    [[ ${#args[@]} -gt 0 ]] || fail "explain requires a target"
    sync_project_understand_skills "$root" 2>/dev/null || true
    print_skill_command "$root" "/skill:understand-explain" "${args[*]}"
    ;;
  onboard)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    sync_project_understand_skills "$root" 2>/dev/null || true
    print_skill_command "$root" "/skill:understand-onboard"
    ;;
  dashboard)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    start_dashboard "$root" "$open_after"
    ;;
  open)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    start_dashboard "$root" "1"
    ;;
  map-sync)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    out="$(map_sync "$root")"
    log "Synced Understand graph into AOC Map: $out"
    ;;
  refresh)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    refresh_generated_artifacts "$root" "$source_commit" "$do_commit"
    ;;
  hook)
    root="${root:-$(resolve_root "$PWD")}" || fail "No AOC/git project root found"
    subcommand="${args[0]:-status}"
    case "$subcommand" in
      install) install_refresh_hook "$root" ;;
      uninstall) uninstall_refresh_hook "$root" ;;
      status) status_refresh_hook "$root" ;;
      *) fail "Unknown hook subcommand: $subcommand" ;;
    esac
    ;;
  *)
    usage >&2
    fail "Unknown command: $command"
    ;;
esac
