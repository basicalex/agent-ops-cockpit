#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
config_src="$repo_root/herdr/config.toml"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/herdr"
config_dst="$config_dir/config.toml"
hypr_bindings="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/bindings.lua"
omp_extension_dir="${AOC_OMP_AGENT_DIR:-$HOME/.omp/agent}/extensions"
omp_agent_dir="${AOC_OMP_AGENT_DIR:-$HOME/.omp/agent}/agents"
omp_skill_dir="${AOC_OMP_AGENT_DIR:-$HOME/.omp/agent}/skills"
read_omp_manifest_list() {
  local key="$1"
  python3 - "$repo_root/.omp/manifest.toml" "$key" <<'PY'
import sys
import tomllib
from pathlib import Path

manifest = Path(sys.argv[1])
key = sys.argv[2]
try:
    data = tomllib.loads(manifest.read_text())
    values = data[key]
    if not isinstance(values, list) or not all(isinstance(value, str) for value in values):
        raise TypeError(f"{key} must be a list of strings")
except Exception as exc:
    print(f"invalid OMP manifest {manifest}: {exc}", file=sys.stderr)
    sys.exit(2)
for value in values:
    print(value)
PY
}

read_omp_active_list() {
  local kind="$1"
  local manifest="$repo_root/.omp/manifest.toml"
  if [[ -x "$repo_root/bin/aoc-profile" ]]; then
    "$repo_root/bin/aoc-profile" active --kind "$kind" --root "$repo_root" --manifest "$manifest"
  else
    read_omp_manifest_list "$kind"
  fi
}

load_omp_active_array() {
  local array_name="$1"
  local kind="$2"
  local tmp
  tmp="$(mktemp)"
  read_omp_active_list "$kind" > "$tmp"
  mapfile -t "$array_name" < "$tmp"
  rm -f "$tmp"
}

load_omp_manifest_array() {
  local array_name="$1"
  local kind="$2"
  local tmp
  tmp="$(mktemp)"
  read_omp_manifest_list "$kind" > "$tmp"
  mapfile -t "$array_name" < "$tmp"
  rm -f "$tmp"
}

array_contains() {
  local needle="$1"
  shift
  local item=""
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

load_omp_active_array omp_extensions extensions
load_omp_active_array omp_agents agents
load_omp_active_array omp_skills skills


sync_omp_extension_config() {
  local omp_config="${AOC_OMP_AGENT_CONFIG:-$HOME/.omp/agent/config.yml}"
  python3 - "$omp_config" "$omp_extension_dir" "${omp_extensions[@]}" <<'PY'
import sys
from pathlib import Path

config = Path(sys.argv[1])
extension_dir = Path(sys.argv[2])
extensions = [str(extension_dir / name) for name in sys.argv[3:]]
if not config.exists():
    sys.exit(0)

lines = config.read_text().splitlines()
block = ["extensions: "] + [f"  - {value}" for value in extensions]
start = None
for index, line in enumerate(lines):
    if line.startswith("extensions:"):
        start = index
        break
if start is None:
    lines.extend(block)
else:
    end = start + 1
    while end < len(lines) and (lines[end].startswith(" ") or lines[end].strip() == ""):
        end += 1
    lines[start:end] = block
config.write_text("\n".join(lines) + "\n")
PY
}

sync_omp_agent_disable_config() {
  local omp_config="${AOC_OMP_AGENT_CONFIG:-$HOME/.omp/agent/config.yml}"
  python3 - "$omp_config" "${omp_agents[@]}" -- "${omp_manifest_agents[@]}" <<'PY'
import sys
from pathlib import Path

config = Path(sys.argv[1])
if "--" not in sys.argv[2:]:
    raise SystemExit("missing separator")
sep = sys.argv.index("--")
active = {Path(name).stem for name in sys.argv[2:sep]}
disabled = [Path(name).stem for name in sys.argv[sep + 1:] if Path(name).stem not in active]
if not config.exists():
    raise SystemExit(0)

lines = config.read_text().splitlines()
task_start = None
for index, line in enumerate(lines):
    if line.startswith("task:"):
        task_start = index
        break
if task_start is None:
    lines.extend(["task:"])
    task_start = len(lines) - 1

task_end = task_start + 1
while task_end < len(lines) and (lines[task_end].startswith(" ") or lines[task_end].strip() == ""):
    task_end += 1

disabled_start = None
for index in range(task_start + 1, task_end):
    if lines[index].startswith("  disabledAgents:"):
        disabled_start = index
        break
if disabled_start is not None:
    disabled_end = disabled_start + 1
    while disabled_end < task_end and (lines[disabled_end].startswith("    ") or lines[disabled_end].strip() == ""):
        disabled_end += 1
    del lines[disabled_start:disabled_end]

block = ["  disabledAgents: []"] if not disabled else ["  disabledAgents:"] + [f"    - {name}" for name in disabled]
lines[task_start + 1:task_start + 1] = block
config.write_text("\n".join(lines) + "\n")
PY
}

sync_omp_extension_disable_config() {
  local omp_config="${AOC_OMP_AGENT_CONFIG:-$HOME/.omp/agent/config.yml}"
  python3 - "$omp_config" "${omp_extensions[@]}" -- "${omp_manifest_extensions[@]}" <<'PY'
import sys
from pathlib import Path

config = Path(sys.argv[1])
if "--" not in sys.argv[2:]:
    raise SystemExit("missing separator")
sep = sys.argv.index("--")
def ext_id(name: str) -> str:
    return f"extension-module:{Path(name).stem}"
active = {ext_id(name) for name in sys.argv[2:sep]}
manifest = [ext_id(name) for name in sys.argv[sep + 1:]]
manifest_set = set(manifest)
profile_disabled = [name for name in manifest if name not in active]
if not config.exists():
    raise SystemExit(0)

lines = config.read_text().splitlines()
start = None
for index, line in enumerate(lines):
    if line.startswith("disabledExtensions:"):
        start = index
        break
existing = []
if start is not None:
    end = start + 1
    if lines[start].strip() != "disabledExtensions: []":
        while end < len(lines) and (lines[end].startswith(" ") or lines[end].strip() == ""):
            stripped = lines[end].strip()
            if stripped.startswith("- "):
                existing.append(stripped[2:])
            end += 1
    else:
        end = start + 1
    del lines[start:end]

preserved = [name for name in existing if name not in manifest_set]
final = preserved + [name for name in profile_disabled if name not in preserved]
block = ["disabledExtensions: []"] if not final else ["disabledExtensions:"] + [f"  - {name}" for name in final]
insert_at = start if start is not None else 0
lines[insert_at:insert_at] = block
config.write_text("\n".join(lines) + "\n")
PY
}

install_voxtype_lexicon() {
  local voxtype_bin="aoc-voxtype-setup"
  if [[ -x "$repo_root/bin/aoc-voxtype-setup" ]]; then
    voxtype_bin="$repo_root/bin/aoc-voxtype-setup"
  fi
  if ! "$voxtype_bin" --quiet; then
    echo "Warning: aoc-voxtype-setup failed; continuing without VoxType lexicon setup" >&2
  fi
}


install_hypr_empty_workspace_fallback() {
  [[ -f "$hypr_bindings" ]] || return 0

  local needle='Herdr new workspace'
  if [[ "$( <"$hypr_bindings" )" == *"$needle"* ]]; then
    return 0
  fi

  cat >>"$hypr_bindings" <<'EOF'

-- Herdr empty-state fallback: when the AOC Herdr session has no workspace,
-- Herdr does not receive its in-app Alt+Shift+N binding until the empty screen
-- is clicked. Catch the same chord at Hyprland level so the first workspace
-- opens with the same AOC shortcut.
o.bind("ALT + SHIFT + N", "Herdr new workspace", "herdr --session aoc workspace create --cwd \"$HOME\" --focus")
EOF
  echo "Installed Herdr empty-workspace Hyprland fallback to $hypr_bindings"

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi
}


usage() {
  cat <<'EOF'
Usage: aoc-herdr-install [--force]

Install the lean Herdr-first AOC workspace config and OMP-native AOC tools.

This installs the Herdr config baseline, Herdr OMP integration, AOC OMP
extensions such as CodeGraph, /commit, /brand-content, and AOC OMP specialist
agent templates. It installs the read-only AOC Mind OMP extension, but does not
install legacy Mind cockpit/runtime assets, Zellij layouts, the AOC top bar, or
AOC subagent/Mission Control assets.
EOF
}

force=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) force=1 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage; exit 2 ;;
  esac
  shift
done

if ! command -v herdr >/dev/null 2>&1; then
  cat >&2 <<'EOF'
aoc-herdr-install: herdr is not installed or not on PATH.
Install Herdr first, then rerun this command.
EOF
  exit 1
fi
if [[ -f "$config_dst" && "$force" != "1" ]]; then
  backup="$config_dst.bak.$(date +%Y%m%d%H%M%S)"
  cp "$config_dst" "$backup"
  echo "Backed up existing Herdr config to $backup"
fi

cp "$config_src" "$config_dst"
echo "Installed Herdr config to $config_dst"
install_hypr_empty_workspace_fallback

if herdr status server >/dev/null 2>&1; then
  herdr server reload-config >/dev/null || true
  echo "Reloaded running Herdr server"
fi

if command -v omp >/dev/null 2>&1 || command -v omp-raw >/dev/null 2>&1; then
  if command -v herdr >/dev/null 2>&1 && herdr integration install omp >/dev/null 2>&1; then
    echo "Installed/updated Herdr OMP integration"
  else
    echo "Warning: Herdr OMP integration install failed; continuing" >&2
  fi

  omp_shim_installer="aoc-omp-shim-install"
  if [[ -x "$repo_root/bin/aoc-omp-shim-install" ]]; then
    omp_shim_installer="$repo_root/bin/aoc-omp-shim-install"
  fi
  if command -v "$omp_shim_installer" >/dev/null 2>&1 || [[ -x "$omp_shim_installer" ]]; then
    if "$omp_shim_installer" >/dev/null; then
      echo "Installed/updated AOC-aware OMP shim"
    else
      echo "Warning: AOC OMP shim install failed; continuing" >&2
    fi
  else
    echo "Warning: aoc-omp-shim-install not on PATH; plain omp will not auto-load AOC context" >&2
  fi
else
  echo "Warning: omp is not on PATH; skipping Herdr OMP integration and AOC OMP shim" >&2
fi

for extension_name in "${omp_extensions[@]}"; do
  extension_src="$repo_root/.omp/extensions/$extension_name"
  extension_dst="$omp_extension_dir/$extension_name"
  if [[ -f "$extension_src" ]]; then
    mkdir -p "$omp_extension_dir"
    cp "$extension_src" "$extension_dst"
    echo "Installed AOC OMP extension to $extension_dst"
  else
    echo "Warning: missing $extension_src; skipping AOC OMP extension" >&2
  fi
done

load_omp_manifest_array omp_manifest_extensions extensions
for extension_name in "${omp_manifest_extensions[@]}"; do
  if ! array_contains "$extension_name" "${omp_extensions[@]}"; then
    rm -f "$omp_extension_dir/$extension_name"
  fi
done
sync_omp_extension_disable_config
sync_omp_extension_config
echo "Updated OMP extension config in ${AOC_OMP_AGENT_CONFIG:-$HOME/.omp/agent/config.yml}"
rm -f "$omp_extension_dir/aoc-openai-stt.ts" "$omp_extension_dir/ponytail.ts" "$omp_extension_dir/aoc-jj-init.ts"


for skill_name in "${omp_skills[@]}"; do
  skill_src="$repo_root/.omp/skills/$skill_name"
  skill_dst="$omp_skill_dir/$skill_name"
  if [[ -d "$skill_src" ]]; then
    mkdir -p "$omp_skill_dir"
    rm -rf "$skill_dst"
    cp -R "$skill_src" "$skill_dst"
    echo "Installed AOC OMP skill to $skill_dst"
  else
    echo "Warning: missing $skill_src; skipping AOC OMP skill" >&2
  fi
done
load_omp_manifest_array omp_manifest_skills skills
for skill_name in "${omp_manifest_skills[@]}"; do
  if ! array_contains "$skill_name" "${omp_skills[@]}"; then
    rm -rf "$omp_skill_dir/$skill_name"
  fi
done
rm -rf "$omp_skill_dir/ponytail-review" "$omp_skill_dir/ponytail-audit" "$omp_skill_dir/ponytail-debt" "$omp_skill_dir/ponytail-help"

for agent_name in "${omp_agents[@]}"; do
  agent_src="$repo_root/.omp/agents/$agent_name"
  agent_dst="$omp_agent_dir/$agent_name"
  if [[ -f "$agent_src" ]]; then
    mkdir -p "$omp_agent_dir"
    cp "$agent_src" "$agent_dst"
    echo "Installed AOC OMP agent template to $agent_dst"
  else
    echo "Warning: missing $agent_src; skipping AOC OMP agent template" >&2
  fi
done

load_omp_manifest_array omp_manifest_agents agents
for agent_name in "${omp_manifest_agents[@]}"; do
  if ! array_contains "$agent_name" "${omp_agents[@]}"; then
    rm -f "$omp_agent_dir/$agent_name"
  fi
done
sync_omp_agent_disable_config
install_voxtype_lexicon



if command -v aoc-omp-context >/dev/null 2>&1 && command -v aoc-omp >/dev/null 2>&1; then
  echo "AOC OMP context capsule available via: aoc-omp-context"
  echo "AOC OMP launcher available via: aoc omp"
  echo "Plain omp auto-loads AOC context in directories initialized with aoc-init"
else
  echo "Warning: aoc-omp-context/aoc-omp not on PATH; ensure AOC bin directory is installed" >&2
fi

cat <<'EOF'

Herdr-first AOC baseline installed.
Key UX:
  Alt+W        workspace picker
  j/k          move in workspace picker
  Alt+Shift+N  new workspace (also works from Herdr's empty state on Hyprland)
  Alt+Shift+Q  close workspace
  Alt+Shift+J/K  next/previous workspace
  Ctrl+B Shift+R  rename workspace
  Alt+N        new tab
  Alt+Shift+R  rename tab
  Alt+R        rename pane
  Alt+Q        close pane
  Alt+H/J/K/L  focus panes
  Alt+U/P      reserved for tab move left/right when Herdr supports it
  Alt+I/O      previous/next tab
  Alt+?        keybindings
EOF
