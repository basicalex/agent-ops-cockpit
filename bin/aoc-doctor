#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: aoc-doctor [--quiet]

Checks for required and optional dependencies used by Agent Ops Cockpit.
Exit codes:
  0  All required tools are present.
  1  One or more required tools are missing.
EOF
}

quiet=0
case "${1:-}" in
  --quiet) quiet=1 ;;
  -h|--help) usage; exit 0 ;;
  "") ;;
  *) echo "Unknown option: $1" >&2; usage; exit 1 ;;
esac

project_root="$PWD"
aoc_project_dir="$project_root/.aoc"
aoc_init_state_file="$aoc_project_dir/init-state.json"
pi_settings_file="$project_root/.pi/settings.json"
pi_multi_auth_package_dir="$project_root/.pi/packages/pi-multi-auth-aoc"
local_multi_auth_package_ref="./packages/pi-multi-auth-aoc"

have() { command -v "$1" >/dev/null 2>&1; }
have_bat() { have bat || have batcat; }
sha256_file() {
  local path="$1"
  [[ -f "$path" ]] || return 1
  if have sha256sum; then
    sha256sum "$path" | awk '{print $1}'
    return 0
  fi
  if have shasum; then
    shasum -a 256 "$path" | awk '{print $1}'
    return 0
  fi
  if have openssl; then
    openssl dgst -sha256 "$path" | awk '{print $NF}'
    return 0
  fi
  return 1
}

version_ge() {
  [[ "$1" == "$2" ]] && return 0
  local first
  first="$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n1)"
  [[ "$first" == "$2" ]]
}

read_project_aoc_version() {
  python3 - "$aoc_init_state_file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
if not path.exists():
    print(0)
    raise SystemExit(0)

try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print(0)
    raise SystemExit(0)

if not isinstance(data, dict):
    print(0)
    raise SystemExit(0)

value = data.get("projectAocVersion", data.get("version", 0))
print(value if isinstance(value, int) and value >= 0 else 0)
PY
}

compute_project_pi_runtime_contract_status() {
  python3 - "$pi_settings_file" "$pi_multi_auth_package_dir" "$local_multi_auth_package_ref" <<'PY'
import json
import sys
from pathlib import Path

settings_path = Path(sys.argv[1])
package_path = Path(sys.argv[2])
local_package = sys.argv[3]

if not settings_path.exists():
    print("missing_settings")
    raise SystemExit(0)

try:
    data = json.loads(settings_path.read_text(encoding="utf-8"))
except Exception:
    print("invalid_settings")
    raise SystemExit(0)

packages = data.get("packages")
if not isinstance(packages, list):
    packages = []

normalized = []
for entry in packages:
    if isinstance(entry, str):
        normalized.append(entry)
    elif isinstance(entry, dict) and isinstance(entry.get("source"), str):
        normalized.append(entry["source"])

references_local = local_package in normalized
package_exists = package_path.is_dir()

if references_local and not package_exists:
    print("invalid_missing_local_package")
elif package_exists and not references_local:
    print("warning_missing_local_package_reference")
else:
    print("ok")
PY
}

zellij_version() {
  have zellij || return 1
  zellij --version 2>/dev/null | awk '{print $2}' | head -n1
}

detect_task_control_backend() {
  if have aoc-task; then
    echo "aoc-task"
    return 0
  fi
  if have aoc-cli && aoc-cli task --help >/dev/null 2>&1; then
    echo "aoc-cli task"
    return 0
  fi
  if have tm && (tm help >/dev/null 2>&1 || tm --help >/dev/null 2>&1); then
    echo "tm"
    return 0
  fi
  if have aoc-taskmaster-native; then
    echo "aoc-taskmaster-native"
    return 0
  fi
  if have aoc-taskmaster; then
    echo "aoc-taskmaster"
    return 0
  fi
  if have task-master; then
    echo "task-master"
    return 0
  fi
  if have task-master-ai; then
    echo "task-master-ai"
    return 0
  fi
  return 1
}

detect_pm() {
  if have apt-get; then echo "apt"; return; fi
  if have dnf; then echo "dnf"; return; fi
  if have pacman; then echo "pacman"; return; fi
  if have brew; then echo "brew"; return; fi
  if have apk; then echo "apk"; return; fi
  echo "unknown"
}

pm="$(detect_pm)"
task_control_backend="$(detect_task_control_backend || true)"

hint_for() {
  local tool="$1"
  case "$tool" in
    zellij)
      case "$pm" in
        apt) echo "sudo apt-get install -y zellij" ;;
        dnf) echo "sudo dnf install -y zellij" ;;
        pacman) echo "sudo pacman -S zellij" ;;
        brew) echo "brew install zellij" ;;
        apk) echo "sudo apk add zellij" ;;
        *) echo "Install zellij via your package manager." ;;
      esac
      ;;
    yazi)
      echo "cargo install --locked --force yazi-build"
      ;;
    fzf)
      case "$pm" in
        apt) echo "sudo apt-get install -y fzf" ;;
        dnf) echo "sudo dnf install -y fzf" ;;
        pacman) echo "sudo pacman -S fzf" ;;
        brew) echo "brew install fzf" ;;
        apk) echo "sudo apk add fzf" ;;
        *) echo "Install fzf via your package manager." ;;
      esac
      ;;
    tmux)
      case "$pm" in
        apt) echo "sudo apt-get install -y tmux" ;;
        dnf) echo "sudo dnf install -y tmux" ;;
        pacman) echo "sudo pacman -S tmux" ;;
        brew) echo "brew install tmux" ;;
        apk) echo "sudo apk add tmux" ;;
        *) echo "Install tmux via your package manager." ;;
      esac
      ;;
    pi)
      echo "Install the PI Agent CLI and ensure it is in PATH (or set AOC_PI_BIN)."
      ;;
    chafa)
      case "$pm" in
        apt) echo "sudo apt-get install -y chafa" ;;
        dnf) echo "sudo dnf install -y chafa" ;;
        pacman) echo "sudo pacman -S chafa" ;;
        brew) echo "brew install chafa" ;;
        apk) echo "sudo apk add chafa" ;;
        *) echo "Install chafa via your package manager." ;;
      esac
      ;;
    ffmpeg)
      case "$pm" in
        apt) echo "sudo apt-get install -y ffmpeg" ;;
        dnf) echo "sudo dnf install -y ffmpeg" ;;
        pacman) echo "sudo pacman -S ffmpeg" ;;
        brew) echo "brew install ffmpeg" ;;
        apk) echo "sudo apk add ffmpeg" ;;
        *) echo "Install ffmpeg via your package manager." ;;
      esac
      ;;
    resvg)
      case "$pm" in
        apt) echo "sudo apt-get install -y resvg" ;;
        dnf) echo "sudo dnf install -y resvg" ;;
        pacman) echo "sudo pacman -S resvg" ;;
        brew) echo "brew install resvg" ;;
        apk) echo "sudo apk add resvg" ;;
        *) echo "Install resvg via your package manager." ;;
      esac
      ;;
    file)
      case "$pm" in
        apt) echo "sudo apt-get install -y file" ;;
        dnf) echo "sudo dnf install -y file" ;;
        pacman) echo "sudo pacman -S file" ;;
        brew) echo "brew install file-formula" ;;
        apk) echo "sudo apk add file" ;;
        *) echo "Install file(1) via your package manager." ;;
      esac
      ;;
    pdftoppm)
      case "$pm" in
        apt) echo "sudo apt-get install -y poppler-utils" ;;
        dnf) echo "sudo dnf install -y poppler-utils" ;;
        pacman) echo "sudo pacman -S poppler" ;;
        brew) echo "brew install poppler" ;;
        apk) echo "sudo apk add poppler-utils" ;;
        *) echo "Install poppler-utils (pdftoppm) via your package manager." ;;
      esac
      ;;
    rg)
      case "$pm" in
        apt) echo "sudo apt-get install -y ripgrep" ;;
        dnf) echo "sudo dnf install -y ripgrep" ;;
        pacman) echo "sudo pacman -S ripgrep" ;;
        brew) echo "brew install ripgrep" ;;
        apk) echo "sudo apk add ripgrep" ;;
        *) echo "Install ripgrep via your package manager." ;;
      esac
      ;;
    bat)
      case "$pm" in
        apt) echo "sudo apt-get install -y bat # binary is batcat on Ubuntu" ;;
        dnf) echo "sudo dnf install -y bat" ;;
        pacman) echo "sudo pacman -S bat" ;;
        brew) echo "brew install bat" ;;
        apk) echo "sudo apk add bat" ;;
        *) echo "Install bat via your package manager." ;;
      esac
      ;;
    tectonic)
      case "$pm" in
        apt) echo "sudo apt-get install -y tectonic" ;;
        dnf) echo "sudo dnf install -y tectonic" ;;
        pacman) echo "sudo pacman -S tectonic" ;;
        brew) echo "brew install tectonic" ;;
        apk) echo "sudo apk add tectonic" ;;
        *) echo "cargo binstall tectonic (or cargo +1.78.0 install --locked tectonic --version 0.14.1)" ;;
      esac
      ;;
    task-master)
      echo "Install task control backend (task-master) or use built-in 'tm'/'aoc-task'."
      ;;
    python3)
      case "$pm" in
        apt) echo "sudo apt-get install -y python3" ;;
        dnf) echo "sudo dnf install -y python3" ;;
        pacman) echo "sudo pacman -S python" ;;
        brew) echo "brew install python" ;;
        apk) echo "sudo apk add python3" ;;
        *) echo "Install python3 via your package manager." ;;
      esac
      ;;
    git)
      case "$pm" in
        apt) echo "sudo apt-get install -y git" ;;
        dnf) echo "sudo dnf install -y git" ;;
        pacman) echo "sudo pacman -S git" ;;
        brew) echo "brew install git" ;;
        apk) echo "sudo apk add git" ;;
        *) echo "Install git via your package manager." ;;
      esac
      ;;
    *)
      echo "Install $tool via your package manager."
      ;;
  esac
}

required=(zellij yazi fzf pi)
optional=(tmux chafa ffmpeg resvg file pdftoppm rg bat tectonic task-master python3 git)

missing_required=()
missing_optional=()
managed_runtime_issues=()
managed_runtime_warnings=()
project_runtime_issues=()
project_runtime_warnings=()
stale_layout_paths=()
zellij_ver="$(zellij_version || true)"
zellij_recommended="0.44.0"
zellij_native_inventory="unknown"
managed_plugin_dest="${ZELLIJ_CONFIG_DIR:-$HOME/.config/zellij}/plugins/zjstatus-aoc.wasm"
managed_plugin_cache="${XDG_CONFIG_HOME:-$HOME/.config}/aoc/zellij/plugins/zjstatus-aoc.wasm"
default_layout_file="${XDG_STATE_HOME:-$HOME/.local/state}/aoc/layout_default"
if [[ -n "$zellij_ver" ]]; then
  if version_ge "$zellij_ver" "$zellij_recommended"; then
    zellij_native_inventory="yes"
  else
    zellij_native_inventory="fallback-only"
  fi
fi

for tool in "${required[@]}"; do
  if ! have "$tool"; then
    missing_required+=("$tool")
  fi
done

for tool in "${optional[@]}"; do
  if [[ "$tool" == "bat" ]]; then
    if ! have_bat; then
      missing_optional+=("$tool")
    fi
  elif [[ "$tool" == "task-master" ]]; then
    if [[ -z "$task_control_backend" ]]; then
      missing_optional+=("$tool")
    fi
  elif ! have "$tool"; then
    missing_optional+=("$tool")
  fi
done

managed_plugin_dest_sha="$(sha256_file "$managed_plugin_dest" || true)"
managed_plugin_cache_sha="$(sha256_file "$managed_plugin_cache" || true)"
if [[ ! -f "$managed_plugin_dest" ]]; then
  managed_runtime_issues+=("managed plugin missing: $managed_plugin_dest")
elif [[ -f "$managed_plugin_cache" ]]; then
  if ! cmp -s "$managed_plugin_cache" "$managed_plugin_dest"; then
    managed_runtime_issues+=("managed plugin stale/diverged: run 'aoc-zellij-plugin install' to restore $managed_plugin_dest")
  fi
fi

project_aoc_version="$(read_project_aoc_version)"
project_pi_runtime_status="$(compute_project_pi_runtime_contract_status)"

if [[ -d "$project_root/.aoc" ]]; then
  [[ -f "$project_root/.aoc/context.md" ]] || project_runtime_issues+=("missing project context: .aoc/context.md")
  [[ -f "$project_root/.aoc/memory.md" ]] || project_runtime_issues+=("missing project memory: .aoc/memory.md")
  [[ -f "$project_root/.aoc/stm/current.md" ]] || project_runtime_issues+=("missing project STM draft: .aoc/stm/current.md")
  [[ -f "$project_root/.aoc/rtk.toml" ]] || project_runtime_warnings+=("missing RTK config: .aoc/rtk.toml")
  [[ -f "$aoc_init_state_file" ]] || project_runtime_warnings+=("missing init state: .aoc/init-state.json (run 'aoc-init' to record project AOC version)")
else
  if [[ -d "$project_root/.gemini" ]]; then
    project_runtime_warnings+=("legacy .gemini/ detected; run 'aoc-init' to migrate to .aoc/")
  else
    project_runtime_issues+=("missing project control plane: .aoc/")
  fi
fi

case "$project_pi_runtime_status" in
  ok)
    ;;
  warning_missing_local_package_reference)
    project_runtime_warnings+=("local PI package exists but settings are not wired to ./packages/pi-multi-auth-aoc")
    ;;
  invalid_missing_local_package)
    project_runtime_issues+=(".pi/settings.json references ./packages/pi-multi-auth-aoc but .pi/packages/pi-multi-auth-aoc is missing")
    ;;
  missing_settings)
    project_runtime_issues+=("missing PI settings: .pi/settings.json")
    ;;
  invalid_settings)
    project_runtime_issues+=("invalid PI settings: .pi/settings.json")
    ;;
  *)
    project_runtime_warnings+=("unexpected PI runtime status: $project_pi_runtime_status")
    ;;
esac

if [[ -d "$HOME/.config/zellij/layouts" ]]; then
  while IFS= read -r layout_path; do
    [[ -n "$layout_path" ]] || continue
    case "$(basename "$layout_path")" in
      unstat.kdl|minimal.kdl|aoc-zjstatus-single.kdl|aoc-zjstatus-test.kdl|aoc.hybrid.kdl)
        stale_layout_paths+=("$layout_path")
        continue
        ;;
    esac
    if grep -Eq 'zjstatus\.wasm|zjstatus-aoc\.wasm[^\n]*command_cwd_interval|aoc-zjstatus-single|aoc-zjstatus-test' "$layout_path" 2>/dev/null; then
      stale_layout_paths+=("$layout_path")
    fi
  done < <(find "$HOME/.config/zellij/layouts" -maxdepth 1 -type f -name '*.kdl' | sort)
fi

if [[ -f "$default_layout_file" ]]; then
  current_default_layout="$(cat "$default_layout_file" 2>/dev/null || true)"
  case "$current_default_layout" in
    unstat|minimal|aoc-zjstatus-single|aoc-zjstatus-test|aoc.hybrid)
      managed_runtime_warnings+=("default layout '$current_default_layout' is deprecated; switch to 'aoc'")
      ;;
  esac
fi

if ((${#stale_layout_paths[@]} > 0)); then
  managed_runtime_warnings+=("stale global Zellij layouts detected under ~/.config/zellij/layouts")
fi

if [[ "$quiet" -eq 0 ]]; then
  echo "AOC Doctor"
  echo "=========="
  
  echo "Project Integrity:"
  if [[ -d ".aoc" ]]; then
    echo "  [ok] .aoc/ directory found"
  elif [[ -d ".gemini" ]]; then
    echo "  [warn] .gemini/ found (legacy). Run 'aoc-init' to migrate to .aoc/"
  else
    echo "  [missing] .aoc/ directory. Run 'aoc-init' to initialize."
  fi

  if [[ -f ".aoc/context.md" ]]; then
    echo "    [ok] context.md present"
  else
    echo "    [missing] context.md"
  fi
  if [[ -f ".aoc/memory.md" ]]; then
    echo "    [ok] memory.md present"
  else
    echo "    [missing] memory.md"
  fi
  if [[ -f ".aoc/stm/current.md" ]]; then
    echo "    [ok] stm/current.md present"
  else
    echo "    [missing] stm/current.md"
  fi
  if [[ -f ".aoc/rtk.toml" ]]; then
    echo "    [ok] rtk.toml present"
  else
    echo "    [warn] rtk.toml missing"
  fi
  if [[ -f ".aoc/init-state.json" ]]; then
    echo "    [ok] init-state.json present"
    echo "    Project AOC version: $project_aoc_version"
  else
    echo "    [warn] init-state.json missing"
    echo "    Project AOC version: 0 (legacy/unversioned)"
  fi

  if [[ -f ".pi/settings.json" ]]; then
    echo "    [ok] .pi/settings.json present"
  else
    echo "    [missing] .pi/settings.json"
  fi
  if [[ -d ".pi/packages/pi-multi-auth-aoc" ]]; then
    echo "    [ok] .pi/packages/pi-multi-auth-aoc present"
  else
    echo "    [warn] .pi/packages/pi-multi-auth-aoc missing"
  fi
  case "$project_pi_runtime_status" in
    ok)
      echo "    [ok] PI runtime package wiring"
      ;;
    warning_missing_local_package_reference)
      echo "    [warn] PI package exists but .pi/settings.json is not wired to ./packages/pi-multi-auth-aoc"
      ;;
    invalid_missing_local_package)
      echo "    [missing] .pi/settings.json references ./packages/pi-multi-auth-aoc but the package directory is missing"
      ;;
    missing_settings)
      echo "    [missing] PI runtime settings missing (.pi/settings.json)"
      ;;
    invalid_settings)
      echo "    [missing] PI runtime settings invalid (.pi/settings.json)"
      ;;
    *)
      echo "    [warn] PI runtime status unknown: $project_pi_runtime_status"
      ;;
  esac

  if ((${#project_runtime_issues[@]} > 0)); then
    for issue in "${project_runtime_issues[@]}"; do
      echo "    [missing] $issue"
    done
  fi
  if ((${#project_runtime_warnings[@]} > 0)); then
    for warning in "${project_runtime_warnings[@]}"; do
      echo "    [warn] $warning"
    done
  fi
  if (( ${#project_runtime_issues[@]} > 0 )) || (( ${#project_runtime_warnings[@]} > 0 )); then
    echo "    Remediation:"
    if [[ ! -d ".aoc" ]] || [[ ! -f ".aoc/init-state.json" ]] || [[ "$project_aoc_version" == "0" ]]; then
      echo "      - Run 'aoc-init' to initialize or migrate this project to the current AOC version."
    fi
    case "$project_pi_runtime_status" in
      invalid_missing_local_package|missing_settings|invalid_settings|warning_missing_local_package_reference)
        echo "      - Run 'aoc-init' to repair PI runtime package seeding and .pi/settings.json wiring."
        ;;
    esac
    if [[ -f ".aoc/init-state.json" ]] && [[ "$project_aoc_version" != "0" ]]; then
      echo "      - Inspect project state with 'aoc-init --status'."
    fi
  fi
  echo

  echo "Required Tools:"
  for tool in "${required[@]}"; do
    if have "$tool"; then
      echo "  [ok] $tool"
    else
      echo "  [missing] $tool"
      echo "    -> $(hint_for "$tool")"
    fi
  done
  if [[ -n "$zellij_ver" ]]; then
    echo "  Zellij version: $zellij_ver"
    if version_ge "$zellij_ver" "$zellij_recommended"; then
      echo "  [ok] Native pane/tab JSON inventory available (recommended baseline: >= $zellij_recommended)"
    else
      echo "  [warn] Native pane/tab JSON inventory not available; operator pane discovery/floating controls may be limited"
      echo "    -> Upgrade zellij to >= $zellij_recommended for explicit list-panes/list-tabs/current-tab-info support"
    fi
  fi
  echo
  echo "Managed Zellij Top Bar:"
  if [[ -f "$managed_plugin_dest" ]]; then
    echo "  [ok] installed plugin: $managed_plugin_dest"
  else
    echo "  [missing] installed plugin: $managed_plugin_dest"
    echo "    -> aoc-zellij-plugin install"
  fi
  if [[ -f "$managed_plugin_cache" ]]; then
    echo "  [ok] managed cache: $managed_plugin_cache"
  else
    echo "  [warn] managed cache missing: $managed_plugin_cache"
  fi
  if [[ -n "$managed_plugin_dest_sha" ]]; then
    echo "  Installed SHA256: $managed_plugin_dest_sha"
  fi
  if [[ -n "$managed_plugin_cache_sha" ]]; then
    echo "  Managed  SHA256: $managed_plugin_cache_sha"
  fi
  if ((${#managed_runtime_issues[@]} > 0)); then
    local_issue="${managed_runtime_issues[0]}"
    echo "  [missing] ${local_issue}"
  elif [[ -f "$managed_plugin_dest" ]]; then
    echo "  [ok] managed plugin matches bundled cache"
  fi
  if ((${#stale_layout_paths[@]} > 0)); then
    echo "  [warn] stale global layouts detected:"
    for layout_path in "${stale_layout_paths[@]}"; do
      echo "    - $layout_path"
    done
    echo "    -> rerun install.sh or remove deprecated managed layout files"
  fi
  if ((${#managed_runtime_warnings[@]} > 0)); then
    for warning in "${managed_runtime_warnings[@]}"; do
      echo "  [warn] $warning"
    done
  fi

  echo
  echo "Optional (features may degrade if missing):"
  for tool in "${optional[@]}"; do
    if [[ "$tool" == "bat" ]]; then
      if have bat; then
        echo "  [ok] bat"
      elif have batcat; then
        echo "  [ok] bat (via batcat)"
      else
        echo "  [missing] bat"
        echo "    -> $(hint_for "$tool")"
      fi
    elif [[ "$tool" == "task-master" ]]; then
      if [[ -n "$task_control_backend" ]]; then
        echo "  [ok] task control (via $task_control_backend)"
      else
        echo "  [missing] task control"
        echo "    -> $(hint_for "$tool")"
      fi
    elif have "$tool"; then
      echo "  [ok] $tool"
    else
      echo "  [missing] $tool"
      echo "    -> $(hint_for "$tool")"
    fi
  done

  if have aoc-yazi-preview; then
    echo
    echo "Preview Runtime:"
    preview_report="$(aoc-yazi-preview detect 2>/dev/null || true)"
    preview_get() {
      local key="$1"
      printf '%s\n' "$preview_report" | awk -F= -v k="$key" '$1==k { sub($1 "=", ""); print; exit }'
    }
    echo "  Mode override: $(preview_get preview_mode_override)"
    echo "  Effective mode: $(preview_get effective_mode)"
    echo "  Terminal family: $(preview_get terminal_family)"
    echo "  Multiplexer: tmux=$(preview_get in_tmux), zellij=$(preview_get in_zellij)"
    echo "  Native backend: $(preview_get native_backend)"
    echo "  Native ready: $(preview_get native_ready)"
    echo "  Quality note: $(preview_get quality_note)"
    blockers="$(preview_get blockers)"
    if [[ -n "$blockers" && "$blockers" != "none" ]]; then
      echo "  Blockers: $blockers"
    fi
  fi
fi

if [[ "${#missing_required[@]}" -gt 0 ]] || [[ "${#managed_runtime_issues[@]}" -gt 0 ]] || [[ "${#project_runtime_issues[@]}" -gt 0 ]]; then
  exit 1
fi
exit 0
