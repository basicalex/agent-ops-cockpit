#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: aoc-doctor [--quiet]

Checks for required and optional dependencies used by Agent Ops Cockpit.
Exit codes:
  0  All required tools are present.
  1  One or more required tools are missing.
EOF
}

quiet=0
case "${1:-}" in
  --quiet) quiet=1 ;;
  -h|--help) usage; exit 0 ;;
  "") ;;
  *) echo "Unknown option: $1" >&2; usage; exit 1 ;;
esac

have() { command -v "$1" >/dev/null 2>&1; }
have_bat() { have bat || have batcat; }

version_ge() {
  [[ "$1" == "$2" ]] && return 0
  local first
  first="$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n1)"
  [[ "$first" == "$2" ]]
}

zellij_version() {
  have zellij || return 1
  zellij --version 2>/dev/null | awk '{print $2}' | head -n1
}

detect_task_control_backend() {
  if have aoc-task; then
    echo "aoc-task"
    return 0
  fi
  if have aoc-cli && aoc-cli task --help >/dev/null 2>&1; then
    echo "aoc-cli task"
    return 0
  fi
  if have tm && (tm help >/dev/null 2>&1 || tm --help >/dev/null 2>&1); then
    echo "tm"
    return 0
  fi
  if have aoc-taskmaster-native; then
    echo "aoc-taskmaster-native"
    return 0
  fi
  if have aoc-taskmaster; then
    echo "aoc-taskmaster"
    return 0
  fi
  if have task-master; then
    echo "task-master"
    return 0
  fi
  if have task-master-ai; then
    echo "task-master-ai"
    return 0
  fi
  return 1
}

detect_pm() {
  if have apt-get; then echo "apt"; return; fi
  if have dnf; then echo "dnf"; return; fi
  if have pacman; then echo "pacman"; return; fi
  if have brew; then echo "brew"; return; fi
  if have apk; then echo "apk"; return; fi
  echo "unknown"
}

pm="$(detect_pm)"
task_control_backend="$(detect_task_control_backend || true)"

hint_for() {
  local tool="$1"
  case "$tool" in
    zellij)
      case "$pm" in
        apt) echo "sudo apt-get install -y zellij" ;;
        dnf) echo "sudo dnf install -y zellij" ;;
        pacman) echo "sudo pacman -S zellij" ;;
        brew) echo "brew install zellij" ;;
        apk) echo "sudo apk add zellij" ;;
        *) echo "Install zellij via your package manager." ;;
      esac
      ;;
    yazi)
      echo "cargo install --locked --force yazi-build"
      ;;
    fzf)
      case "$pm" in
        apt) echo "sudo apt-get install -y fzf" ;;
        dnf) echo "sudo dnf install -y fzf" ;;
        pacman) echo "sudo pacman -S fzf" ;;
        brew) echo "brew install fzf" ;;
        apk) echo "sudo apk add fzf" ;;
        *) echo "Install fzf via your package manager." ;;
      esac
      ;;
    tmux)
      case "$pm" in
        apt) echo "sudo apt-get install -y tmux" ;;
        dnf) echo "sudo dnf install -y tmux" ;;
        pacman) echo "sudo pacman -S tmux" ;;
        brew) echo "brew install tmux" ;;
        apk) echo "sudo apk add tmux" ;;
        *) echo "Install tmux via your package manager." ;;
      esac
      ;;
    pi)
      echo "Install the PI Agent CLI and ensure it is in PATH (or set AOC_PI_BIN)."
      ;;
    chafa)
      case "$pm" in
        apt) echo "sudo apt-get install -y chafa" ;;
        dnf) echo "sudo dnf install -y chafa" ;;
        pacman) echo "sudo pacman -S chafa" ;;
        brew) echo "brew install chafa" ;;
        apk) echo "sudo apk add chafa" ;;
        *) echo "Install chafa via your package manager." ;;
      esac
      ;;
    ffmpeg)
      case "$pm" in
        apt) echo "sudo apt-get install -y ffmpeg" ;;
        dnf) echo "sudo dnf install -y ffmpeg" ;;
        pacman) echo "sudo pacman -S ffmpeg" ;;
        brew) echo "brew install ffmpeg" ;;
        apk) echo "sudo apk add ffmpeg" ;;
        *) echo "Install ffmpeg via your package manager." ;;
      esac
      ;;
    resvg)
      case "$pm" in
        apt) echo "sudo apt-get install -y resvg" ;;
        dnf) echo "sudo dnf install -y resvg" ;;
        pacman) echo "sudo pacman -S resvg" ;;
        brew) echo "brew install resvg" ;;
        apk) echo "sudo apk add resvg" ;;
        *) echo "Install resvg via your package manager." ;;
      esac
      ;;
    file)
      case "$pm" in
        apt) echo "sudo apt-get install -y file" ;;
        dnf) echo "sudo dnf install -y file" ;;
        pacman) echo "sudo pacman -S file" ;;
        brew) echo "brew install file-formula" ;;
        apk) echo "sudo apk add file" ;;
        *) echo "Install file(1) via your package manager." ;;
      esac
      ;;
    ueberzugpp)
      case "$pm" in
        apt) echo "Install ueberzugpp from an upstream release/build (not usually in default Ubuntu repos), or use Kitty/kitten as the Yazi image backend." ;;
        pacman) echo "sudo pacman -S ueberzugpp" ;;
        brew) echo "brew install ueberzugpp" ;;
        apk) echo "sudo apk add ueberzugpp" ;;
        *) echo "Install ueberzugpp (recommended Linux backend for native Yazi image previews) or use a terminal with Kitty/Sixel support." ;;
      esac
      ;;
    pdftoppm)
      case "$pm" in
        apt) echo "sudo apt-get install -y poppler-utils" ;;
        dnf) echo "sudo dnf install -y poppler-utils" ;;
        pacman) echo "sudo pacman -S poppler" ;;
        brew) echo "brew install poppler" ;;
        apk) echo "sudo apk add poppler-utils" ;;
        *) echo "Install poppler-utils (pdftoppm) via your package manager." ;;
      esac
      ;;
    rg)
      case "$pm" in
        apt) echo "sudo apt-get install -y ripgrep" ;;
        dnf) echo "sudo dnf install -y ripgrep" ;;
        pacman) echo "sudo pacman -S ripgrep" ;;
        brew) echo "brew install ripgrep" ;;
        apk) echo "sudo apk add ripgrep" ;;
        *) echo "Install ripgrep via your package manager." ;;
      esac
      ;;
    bat)
      case "$pm" in
        apt) echo "sudo apt-get install -y bat # binary is batcat on Ubuntu" ;;
        dnf) echo "sudo dnf install -y bat" ;;
        pacman) echo "sudo pacman -S bat" ;;
        brew) echo "brew install bat" ;;
        apk) echo "sudo apk add bat" ;;
        *) echo "Install bat via your package manager." ;;
      esac
      ;;
    tectonic)
      case "$pm" in
        apt) echo "sudo apt-get install -y tectonic" ;;
        dnf) echo "sudo dnf install -y tectonic" ;;
        pacman) echo "sudo pacman -S tectonic" ;;
        brew) echo "brew install tectonic" ;;
        apk) echo "sudo apk add tectonic" ;;
        *) echo "cargo binstall tectonic (or cargo +1.78.0 install --locked tectonic --version 0.14.1)" ;;
      esac
      ;;
    task-master)
      echo "Install task control backend (task-master) or use built-in 'tm'/'aoc-task'."
      ;;
    python3)
      case "$pm" in
        apt) echo "sudo apt-get install -y python3" ;;
        dnf) echo "sudo dnf install -y python3" ;;
        pacman) echo "sudo pacman -S python" ;;
        brew) echo "brew install python" ;;
        apk) echo "sudo apk add python3" ;;
        *) echo "Install python3 via your package manager." ;;
      esac
      ;;
    git)
      case "$pm" in
        apt) echo "sudo apt-get install -y git" ;;
        dnf) echo "sudo dnf install -y git" ;;
        pacman) echo "sudo pacman -S git" ;;
        brew) echo "brew install git" ;;
        apk) echo "sudo apk add git" ;;
        *) echo "Install git via your package manager." ;;
      esac
      ;;
    *)
      echo "Install $tool via your package manager."
      ;;
  esac
}

required=(zellij yazi fzf pi)
optional=(tmux chafa ffmpeg resvg file pdftoppm rg bat tectonic task-master python3 git)
if [[ "$(uname -s)" == "Linux" ]]; then
  optional+=(ueberzugpp)
fi

missing_required=()
missing_optional=()
zellij_ver="$(zellij_version || true)"
zellij_recommended="0.44.0"
zellij_native_inventory="unknown"
if [[ -n "$zellij_ver" ]]; then
  if version_ge "$zellij_ver" "$zellij_recommended"; then
    zellij_native_inventory="yes"
  else
    zellij_native_inventory="fallback-only"
  fi
fi

for tool in "${required[@]}"; do
  if ! have "$tool"; then
    missing_required+=("$tool")
  fi
done

for tool in "${optional[@]}"; do
  if [[ "$tool" == "bat" ]]; then
    if ! have_bat; then
      missing_optional+=("$tool")
    fi
  elif [[ "$tool" == "task-master" ]]; then
    if [[ -z "$task_control_backend" ]]; then
      missing_optional+=("$tool")
    fi
  elif [[ "$tool" == "ueberzugpp" ]]; then
    if ! have ueberzugpp && ! have kitten && ! have kitty; then
      missing_optional+=("$tool")
    fi
  elif ! have "$tool"; then
    missing_optional+=("$tool")
  fi
done

if [[ "$quiet" -eq 0 ]]; then
  echo "AOC Doctor"
  echo "=========="
  
  echo "Project Integrity:"
  if [[ -d ".aoc" ]]; then
    echo "  [ok] .aoc/ directory found"
    if [[ -f ".aoc/context.md" ]]; then
      echo "    [ok] context.md present"
    else
      echo "    [missing] context.md"
    fi
    if [[ -f ".aoc/memory.md" ]]; then
      echo "    [ok] memory.md present"
    else
      echo "    [missing] memory.md"
    fi
  elif [[ -d ".gemini" ]]; then
    echo "  [warn] .gemini/ found (legacy). Run 'aoc-init' to migrate to .aoc/"
  else
    echo "  [missing] .aoc/ directory. Run 'aoc-init' to initialize."
  fi
  echo

  echo "Required Tools:"
  for tool in "${required[@]}"; do
    if have "$tool"; then
      echo "  [ok] $tool"
    else
      echo "  [missing] $tool"
      echo "    -> $(hint_for "$tool")"
    fi
  done
  if [[ -n "$zellij_ver" ]]; then
    echo "  Zellij version: $zellij_ver"
    if version_ge "$zellij_ver" "$zellij_recommended"; then
      echo "  [ok] Native pane/tab JSON inventory available (recommended baseline: >= $zellij_recommended)"
    else
      echo "  [warn] Native pane/tab JSON inventory not available; operator pane discovery/floating controls may be limited"
      echo "    -> Upgrade zellij to >= $zellij_recommended for explicit list-panes/list-tabs/current-tab-info support"
    fi
  fi
  echo
  echo "Optional (features may degrade if missing):"
  for tool in "${optional[@]}"; do
    if [[ "$tool" == "bat" ]]; then
      if have bat; then
        echo "  [ok] bat"
      elif have batcat; then
        echo "  [ok] bat (via batcat)"
      else
        echo "  [missing] bat"
        echo "    -> $(hint_for "$tool")"
      fi
    elif [[ "$tool" == "task-master" ]]; then
      if [[ -n "$task_control_backend" ]]; then
        echo "  [ok] task control (via $task_control_backend)"
      else
        echo "  [missing] task control"
        echo "    -> $(hint_for "$tool")"
      fi
    elif [[ "$tool" == "ueberzugpp" ]]; then
      if have ueberzugpp; then
        echo "  [ok] ueberzugpp"
      elif have kitten; then
        echo "  [ok] native Yazi image backend (via kitten)"
      elif have kitty; then
        echo "  [ok] native Yazi image backend (via kitty)"
      else
        echo "  [missing] native Yazi image backend"
        echo "    -> $(hint_for "$tool")"
      fi
    elif have "$tool"; then
      echo "  [ok] $tool"
    else
      echo "  [missing] $tool"
      echo "    -> $(hint_for "$tool")"
    fi
  done

  if have aoc-yazi-preview; then
    echo
    echo "Preview Runtime:"
    preview_report="$(aoc-yazi-preview detect 2>/dev/null || true)"
    preview_get() {
      local key="$1"
      printf '%s\n' "$preview_report" | awk -F= -v k="$key" '$1==k { sub($1 "=", ""); print; exit }'
    }
    echo "  Mode override: $(preview_get preview_mode_override)"
    echo "  Effective mode: $(preview_get effective_mode)"
    echo "  Terminal family: $(preview_get terminal_family)"
    echo "  Multiplexer: tmux=$(preview_get in_tmux), zellij=$(preview_get in_zellij)"
    echo "  Native backend: $(preview_get native_backend)"
    echo "  Native ready: $(preview_get native_ready)"
    echo "  Custom overlay ready: $(preview_get custom_overlay_ready)"
    echo "  Quality note: $(preview_get quality_note)"
    blockers="$(preview_get blockers)"
    if [[ -n "$blockers" && "$blockers" != "none" ]]; then
      echo "  Blockers: $blockers"
    fi
  fi
fi

if [[ "${#missing_required[@]}" -gt 0 ]]; then
  exit 1
fi
exit 0
