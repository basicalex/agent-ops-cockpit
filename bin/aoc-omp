#!/usr/bin/env bash
set -euo pipefail
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"


usage() {
  cat <<'EOF'
Usage: aoc-omp [OMP_ARGS...]

Launch OMP with the compact AOC startup capsule appended to the system prompt.
The capsule is metadata-only: it reports project/task/tool policy without broad
Mind memory or raw task-state injection.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

raw_omp="${AOC_RAW_OMP_BIN:-}"
if [[ -z "$raw_omp" ]]; then
  if command -v omp-raw >/dev/null 2>&1; then
    raw_omp="omp-raw"
  else
    raw_omp="omp"
  fi
fi
if ! command -v "$raw_omp" >/dev/null 2>&1; then
  if [[ -n "${AOC_RAW_OMP_BIN:-}" ]]; then
    echo "aoc-omp: raw OMP binary not found: $raw_omp" >&2
  else
    echo "aoc-omp: OMP is not installed or not on PATH" >&2
  fi
  exit 1
fi


runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
mkdir -p "$runtime_dir"
capsule="$(mktemp "$runtime_dir/aoc-omp-context.XXXXXX.md")"
aoc-omp-context > "$capsule"

exec "$raw_omp" --append-system-prompt "$capsule" "$@"
