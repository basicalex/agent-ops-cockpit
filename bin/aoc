#!/usr/bin/env bash
set -euo pipefail

# Forward known subcommands to the Rust CLI
if [[ "${1:-}" == "omp" ]]; then
  shift
  exec aoc-omp "$@"
fi

if [[ "${1:-}" == "omp-patch" ]]; then
  shift
  exec aoc-omp-patch "$@"
fi

if [[ "${1:-}" == "voxtype-setup" ]]; then
  shift
  exec aoc-voxtype-setup "$@"
fi

if [[ "${1:-}" == "state" ]]; then
  shift
  DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
  if [[ -x "$DIR/aoc-state" ]]; then
    exec "$DIR/aoc-state" "$@"
  fi
  exec aoc-state "$@"
fi

if [[ "${1:-}" == "services" ]]; then
  shift
  case "${1:-workspace}" in
    workspace|focus)
      shift || true
      exec aoc-herdr-services focus "$@"
      ;;
    ensure)
      shift
      exec aoc-herdr-services ensure "$@"
      ;;
    status|up|start|stop|doctor)
      exec aoc-services "$@"
      ;;
    -h|--help)
      echo "Usage: aoc services [workspace|status|up|start|stop|doctor]"
      exit 0
      ;;
    *)
      echo "Unknown services command: $1" >&2
      echo "Usage: aoc services [workspace|status|up|start|stop|doctor]" >&2
      exit 2
      ;;
  esac
fi

if [[ $# -gt 0 ]]; then
  case "$1" in
    task|mem|rlm|insight|overseer|map|see|--help|-h)
      # Assuming aoc-cli is in path or same directory
      DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
      if [[ -x "$DIR/aoc-cli" ]]; then
        exec "$DIR/aoc-cli" "$@"
      elif [[ -x "$DIR/../crates/target/debug/aoc-cli" ]]; then
        exec "$DIR/../crates/target/debug/aoc-cli" "$@"
      elif [[ -x "$DIR/../crates/target/release/aoc-cli" ]]; then
        exec "$DIR/../crates/target/release/aoc-cli" "$@"
      elif command -v aoc-cli >/dev/null 2>&1; then
        exec aoc-cli "$@"
      fi
      ;;
  esac
fi

aoc_zellij_bin() {
  if [[ -n "${AOC_ZELLIJ_BIN:-}" && -x "${AOC_ZELLIJ_BIN:-}" ]]; then
    printf '%s' "$AOC_ZELLIJ_BIN"
  elif [[ -x /usr/local/bin/zellij ]]; then
    printf '%s' /usr/local/bin/zellij
  else
    command -v zellij
  fi
}

aoc_fullscreen() {
  if [[ "${AOC_FULLSCREEN:-1}" == "0" ]]; then
    return 0
  fi

  if [[ "${XDG_SESSION_TYPE:-}" != "x11" ]]; then
    return 0
  fi

  local window_id="${ALACRITTY_WINDOW_ID:-${WINDOWID:-}}"
  if [[ -z "$window_id" ]]; then
    return 0
  fi

  if command -v wmctrl >/dev/null 2>&1; then
    wmctrl -ir "$window_id" -b add,fullscreen >/dev/null 2>&1 || true
    return 0
  fi

  if command -v xdotool >/dev/null 2>&1; then
    xdotool windowactivate "$window_id" >/dev/null 2>&1 || true
    xdotool windowstate --add FULLSCREEN "$window_id" >/dev/null 2>&1 || true
  fi
}

if [[ "${AOC_LEGACY_ZELLIJ:-0}" == "1" ]]; then
  if [[ -n "${ZELLIJ:-}" ]]; then
    exec aoc-new-tab "$@"
  fi

  if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    zellij_bin="$(aoc_zellij_bin)"
    if "$zellij_bin" action list-clients >/dev/null 2>&1; then
      exec aoc-new-tab "$@"
    fi
  fi

  aoc_fullscreen
  exec env -u AOC_SESSION_ID -u AOC_HUB_ADDR -u AOC_HUB_URL -u AOC_PULSE_CMD -u ZELLIJ_SESSION_NAME aoc-launch
fi

# Herdr-first launcher. The old Zellij cockpit remains available with:
#   AOC_LEGACY_ZELLIJ=1 aoc
exec aoc-herdr-launch "$@"
