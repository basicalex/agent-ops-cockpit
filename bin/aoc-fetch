#!/usr/bin/env python3
import argparse
import html
import html.parser
import json
import re
import sys
import urllib.request
import urllib.error


class TextExtractor(html.parser.HTMLParser):
    def __init__(self):
        super().__init__()
        self.skip = 0
        self.title_parts = []
        self.text_parts = []
        self.in_title = False
        self.links = []

    def handle_starttag(self, tag, attrs):
        tag = tag.lower()
        attrs_d = dict(attrs)
        if tag in {"script", "style", "noscript", "svg", "canvas"}:
            self.skip += 1
        if tag == "title":
            self.in_title = True
        if tag == "a" and attrs_d.get("href"):
            self.links.append({"text": "", "href": attrs_d.get("href")})
        if tag in {"p", "div", "section", "article", "header", "footer", "br", "li", "h1", "h2", "h3"}:
            self.text_parts.append("\n")

    def handle_endtag(self, tag):
        tag = tag.lower()
        if tag in {"script", "style", "noscript", "svg", "canvas"} and self.skip:
            self.skip -= 1
        if tag == "title":
            self.in_title = False
        if tag in {"p", "li", "h1", "h2", "h3"}:
            self.text_parts.append("\n")

    def handle_data(self, data):
        if self.skip:
            return
        text = data.strip()
        if not text:
            return
        if self.in_title:
            self.title_parts.append(text)
        self.text_parts.append(text + " ")

    @property
    def title(self):
        return clean_text(" ".join(self.title_parts))

    @property
    def text(self):
        return clean_text("".join(self.text_parts))


def clean_text(value: str) -> str:
    value = html.unescape(value)
    value = re.sub(r"[ \t\r\f\v]+", " ", value)
    value = re.sub(r"\n\s*\n\s*\n+", "\n\n", value)
    return value.strip()


def fetch(url: str, timeout: int):
    req = urllib.request.Request(url, headers={"User-Agent": "aoc-fetch/0.1 (+agent research extraction)"})
    with urllib.request.urlopen(req, timeout=timeout) as response:
        body = response.read()
        final_url = response.geturl()
        status = getattr(response, "status", 200)
        headers = dict(response.headers.items())
    ctype = headers.get("Content-Type", "")
    charset = "utf-8"
    m = re.search(r"charset=([^;]+)", ctype, re.I)
    if m:
        charset = m.group(1).strip()
    text = body.decode(charset, errors="replace")
    return status, final_url, headers, text


def as_markdown(title: str, url: str, text: str) -> str:
    out = []
    if title:
        out.append(f"# {title}\n")
    out.append(f"Source: {url}\n")
    out.append(text)
    return "\n".join(out).strip() + "\n"


def main():
    ap = argparse.ArgumentParser(prog="aoc-fetch", description="Fetch and extract static web pages cheaply before escalating to a renderer/browser.")
    ap.add_argument("url")
    ap.add_argument("--format", choices=["text", "markdown", "html", "json"], default="markdown")
    ap.add_argument("--timeout", type=int, default=15)
    ap.add_argument("--max-chars", type=int, default=12000)
    args = ap.parse_args()
    try:
        status, final_url, headers, raw = fetch(args.url, args.timeout)
    except Exception as exc:
        print(str(exc), file=sys.stderr)
        return 3

    content_type = headers.get("Content-Type", "")
    parser = TextExtractor()
    if "html" in content_type.lower() or raw.lstrip().startswith("<"):
        parser.feed(raw)
        title = parser.title
        text = parser.text
    else:
        title = ""
        text = clean_text(raw)

    truncated = False
    if args.max_chars > 0 and len(text) > args.max_chars:
        text = text[: args.max_chars].rstrip()
        truncated = True

    if args.format == "html":
        print(raw[: args.max_chars] if args.max_chars > 0 else raw)
    elif args.format == "text":
        print(text)
    elif args.format == "markdown":
        print(as_markdown(title, final_url, text), end="")
    else:
        print(json.dumps({
            "url": args.url,
            "finalUrl": final_url,
            "status": status,
            "contentType": content_type,
            "title": title,
            "text": text,
            "textLength": len(text),
            "truncated": truncated,
        }, indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
