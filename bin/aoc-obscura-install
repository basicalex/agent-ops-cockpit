#!/usr/bin/env python3
import json
import os
import platform
import shutil
import subprocess
import sys
import tarfile
import tempfile
import urllib.request
from pathlib import Path

RELEASE = "https://github.com/h4ckf0r0day/obscura/releases/latest/download"


def root() -> Path:
    cursor = Path.cwd().resolve()
    for c in [cursor, *cursor.parents]:
        if (c / ".aoc").exists() or (c / ".git").exists():
            return c
    return cursor


def asset_name() -> str:
    system = platform.system().lower()
    machine = platform.machine().lower()
    if system == "linux" and machine in {"x86_64", "amd64"}:
        return "obscura-x86_64-linux.tar.gz"
    if system == "darwin" and machine in {"arm64", "aarch64"}:
        return "obscura-aarch64-macos.tar.gz"
    raise RuntimeError(f"unsupported platform for managed Obscura install: {platform.system()} {platform.machine()}")


def main() -> int:
    as_json = "--json" in sys.argv
    project = root()
    target_dir = project / ".aoc" / "tools" / "obscura"
    target_dir.mkdir(parents=True, exist_ok=True)
    asset = asset_name()
    url = f"{RELEASE}/{asset}"
    with tempfile.TemporaryDirectory() as td:
        archive = Path(td) / asset
        urllib.request.urlretrieve(url, archive)
        with tarfile.open(archive, "r:gz") as tf:
            tf.extractall(target_dir)
    binary = target_dir / "obscura"
    binary.chmod(binary.stat().st_mode | 0o755)
    result = subprocess.run([str(binary), "--help"], capture_output=True, text=True, timeout=10, check=False)
    payload = {"status": "ok", "path": str(binary), "asset": asset, "url": url, "summary": (result.stdout or result.stderr).splitlines()[0] if (result.stdout or result.stderr) else "obscura installed"}
    if as_json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"installed Obscura: {binary}")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(str(exc), file=sys.stderr)
        raise SystemExit(1)
