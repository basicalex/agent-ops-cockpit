#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: aoc-agent-install <status|install|update> <agent>

Agents: pi

Examples:
  aoc-agent-install status pi
  aoc-agent-install install pi
EOF
}

normalize_agent() {
  local normalized
  normalized="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$normalized" in
    pi|pi-agent|pi_agent)
      printf '%s\n' "pi"
      ;;
    *)
      return 1
      ;;
  esac
}

agent_label() {
  printf '%s\n' "PI Agent (npm)"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

status_agent() {
  local bin_name="${AOC_PI_BIN:-pi}"
  if have "$bin_name" || have pi-raw; then
    printf '%s\n' "installed"
  else
    printf '%s\n' "missing"
  fi
}

default_install_cmd() {
  printf '%s\n' "if command -v pnpm >/dev/null 2>&1; then pnpm add -g @mariozechner/pi-coding-agent; elif command -v npm >/dev/null 2>&1; then npm install -g --prefix \"${AOC_NPM_GLOBAL_PREFIX:-$HOME/.local}\" @mariozechner/pi-coding-agent; elif command -v corepack >/dev/null 2>&1; then corepack enable && corepack prepare pnpm@latest --activate && pnpm add -g @mariozechner/pi-coding-agent; else echo 'pnpm/npm/corepack not found' >&2; exit 1; fi"
}

default_update_cmd() {
  printf '%s\n' "if command -v pnpm >/dev/null 2>&1; then pnpm add -g @mariozechner/pi-coding-agent@latest; elif command -v npm >/dev/null 2>&1; then npm install -g --prefix \"${AOC_NPM_GLOBAL_PREFIX:-$HOME/.local}\" @mariozechner/pi-coding-agent@latest; elif command -v corepack >/dev/null 2>&1; then corepack enable && corepack prepare pnpm@latest --activate && pnpm add -g @mariozechner/pi-coding-agent@latest; else echo 'pnpm/npm/corepack not found' >&2; exit 1; fi"
}

action_var_hint() {
  local action="$1"
  if [[ "$action" == "install" ]]; then
    printf '%s\n' "AOC_PI_INSTALL_CMD"
  else
    printf '%s\n' "AOC_PI_UPDATE_CMD"
  fi
}

resolve_action_cmd() {
  local action="$1"
  if [[ "$action" == "install" ]]; then
    printf '%s\n' "${AOC_PI_INSTALL_CMD:-$(default_install_cmd)}"
  else
    printf '%s\n' "${AOC_PI_UPDATE_CMD:-${AOC_PI_INSTALL_CMD:-$(default_update_cmd)}}"
  fi
}

install_aoc_pi_shim() {
  local bin_dir="${AOC_BIN_DIR:-$HOME/.local/bin}"
  local pi_path=""
  mkdir -p "$bin_dir"

  pi_path="$(command -v pi 2>/dev/null || true)"
  if [[ -n "$pi_path" && -x "$pi_path" ]]; then
    if [[ "$pi_path" != "$bin_dir/pi" ]]; then
      cp -p "$pi_path" "$bin_dir/pi-raw"
    elif ! grep -q "AOC-aware Pi shim" "$pi_path" 2>/dev/null; then
      cp -p "$pi_path" "$bin_dir/pi-raw"
    fi
  fi

  if [[ ! -x "$bin_dir/pi-raw" ]]; then
    echo "Could not install AOC pi shim: raw Pi binary not found. Set AOC_PI_BIN or install Pi first." >&2
    return 1
  fi

  cat > "$bin_dir/pi" <<'SHIM'
#!/usr/bin/env bash
set -euo pipefail

# AOC-aware Pi shim.
# - Inside an AOC-initialized project, route through aoc-pi so AOC presets,
#   layout/session metadata, Mind/project extensions, and wrapper defaults apply.
# - Outside AOC projects, preserve normal upstream Pi behavior via pi-raw.
# - Escape hatch: PI_NO_AOC_WRAPPER=1 pi ...

raw_pi="${AOC_RAW_PI_BIN:-pi-raw}"
aoc_pi="${AOC_PI_WRAPPER_BIN:-aoc-pi}"

find_aoc_root() {
  local dir="${PWD:-.}"
  dir="$(cd "$dir" 2>/dev/null && pwd -P)" || return 1

  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.aoc" && -f "$dir/.aoc/context.md" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  return 1
}

if [[ "${PI_NO_AOC_WRAPPER:-0}" != "1" ]]; then
  if aoc_root="$(find_aoc_root)"; then
    if [[ "${PI_AOC_WRAPPER_DRY_RUN:-0}" == "1" ]]; then
      printf 'aoc-pi --project-root %q' "$aoc_root"
      printf ' %q' "$@"
      printf '\n'
      exit 0
    fi

    # Manual `pi` should bind to the AOC project detected from the current
    # working directory, even if this pane inherited AOC_PROJECT_ROOT from a
    # different AOC tab/project.
    export AOC_PROJECT_ROOT="$aoc_root"
    export AOC_PI_BIN="${AOC_PI_BIN:-$raw_pi}"
    # Run the AOC wrapper in the current terminal. Without this, aoc-pi's
    # interactive launcher opens a new Zellij tab when already inside Zellij.
    export AOC_AGENT_RUN=1
    # Manual `pi` in an AOC project should visibly run the AOC startup
    # handshake. aoc-agent-wrap normally suppresses the bootloader for managed
    # panes, so force it on for this inline shim path unless overridden.
    export AOC_PI_USE_BOOTLOADER="${AOC_PI_USE_BOOTLOADER:-1}"
    export AOC_HANDSHAKE_MODE="${AOC_HANDSHAKE_MODE:-compact}"
    exec "$aoc_pi" "$@"
  fi
fi

exec "$raw_pi" "$@"
SHIM
  chmod +x "$bin_dir/pi"
  chmod +x "$bin_dir/pi-raw"
}

run_action() {
  local action="$1"
  local cmd=""
  local label=""
  local verb=""
  local output=""

  label="$(agent_label)"
  cmd="$(resolve_action_cmd "$action")"

  if [[ -z "${cmd// }" ]]; then
    echo "No $action command configured for $label. Set $(action_var_hint "$action")." >&2
    return 1
  fi

  if output="$(bash -lc "$cmd" 2>&1)"; then
    if [[ "$action" == "install" ]]; then
      verb="Installed"
    else
      verb="Updated"
    fi
    printf '%s\n' "$verb $label"
    if [[ -n "$output" ]]; then
      printf '%s\n' "$output"
    fi
    install_aoc_pi_shim
    return 0
  fi

  if [[ -n "$output" ]]; then
    printf '%s\n' "$output" >&2
  else
    echo "$action failed for $label" >&2
  fi
  return 1
}

if [[ $# -lt 2 ]]; then
  usage
  exit 1
fi

action="$1"
agent_raw="$2"

agent="$(normalize_agent "$agent_raw" 2>/dev/null || true)"
if [[ -z "$agent" ]]; then
  echo "Unsupported agent: $agent_raw" >&2
  usage
  exit 1
fi

case "$action" in
  status)
    status_agent
    ;;
  install|update)
    run_action "$action"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unsupported action: $action" >&2
    usage
    exit 1
    ;;
esac
