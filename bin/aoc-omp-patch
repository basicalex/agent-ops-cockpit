#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: aoc-omp-patch [--cache-root PATH] [--quiet]

Patch OMP after an upstream update so colocated jj workspaces show the desired
status summary in the existing git segment:
  Δ<files> +<added> -<removed> ⇢<bookmarks>

Contract for future agents:
- Patch the newest cached @oh-my-pi/pi-coding-agent dist/cli.js and active
  ~/.cache/.bun/bin/omp bundle.
- Use async cached jj refresh via Bun.spawn; never put spawnSync or synchronous
  jj commands on the status render path.
- Keep the first frame cheap ("jj..."), then refresh the segment.
- Configure ~/.omp/agent/config.yml for Nerd Font custom status line with the
  git segment present and upstream Git dirty counters disabled.
EOF
}

cache_root="${BUN_INSTALL_CACHE_DIR:-$HOME/.cache/.bun/install/cache}"
quiet=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --cache-root) cache_root="$2"; shift 2 ;;
    --quiet) quiet=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "aoc-omp-patch: unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
done

python3 - "$cache_root" "$quiet" <<'PY'
from __future__ import annotations
from pathlib import Path
import re, sys

cache_root = Path(sys.argv[1]).expanduser()
quiet = sys.argv[2] == "1"

def semver_key(path: Path):
    for part in path.parts:
        m = re.search(r"pi-coding-agent@(\d+)\.(\d+)\.(\d+)", part)
        if m:
            return tuple(map(int, m.groups()))
    return (-1, -1, -1)

candidates = sorted(cache_root.glob("@oh-my-pi/pi-coding-agent@*@@@*/dist/cli.js"), key=semver_key, reverse=True)
bundle_paths = [Path.home() / ".cache/.bun/install/global/node_modules/@oh-my-pi/pi-coding-agent/dist/cli.js"]
if candidates:
    bundle_paths.append(candidates[0])
bundle_paths.append(Path.home() / ".cache/.bun/bin/omp")

old_statuses = [
    '#getCurrentBranch(){let cwd=getProjectDir();if(this.#cachedBranch!==void 0&&this.#cachedBranchCwd===cwd)return this.#cachedBranch;let head2=head.resolveSync(cwd),gitHeadPath=head2?.headPath??null;if(this.#cachedBranchCwd=cwd,this.#cachedBranchRepoId=gitHeadPath,!head2)return this.#cachedBranch=null,null;return this.#cachedBranch=head2.kind==="ref"?head2.branchName??head2.ref:"detached",this.#cachedBranch??null}',
    '#getCurrentBranch(){if(this.#cachedBranch!==void 0)return this.#cachedBranch;let headState=head.resolveSync(getProjectDir());return this.#cachedBranch=headState===null?null:headState.kind==="ref"?headState.branchName??headState.ref:"detached",this.#cachedBranch}',
]
new_status = '#getCurrentBranch(){let cwd=getProjectDir(),jjRepoDir=aocFindJjRepoDirAsync(cwd);if(jjRepoDir){if(this._aocJjCwd!==cwd&&(this._aocJjCwd=cwd,this._aocJjSummary=void 0,this._aocJjLastFetch=0),!this._aocJjInFlight&&(this._aocJjSummary===void 0||Date.now()-(this._aocJjLastFetch??0)>2e3)){this._aocJjInFlight=!0;aocResolveJjSummaryAsync(jjRepoDir).then((summary)=>{this._aocJjCwd===cwd&&(this._aocJjSummary=summary,this._aocJjLastFetch=Date.now(),this.#onBranchChange&&this.#onBranchChange())}).finally(()=>{this._aocJjInFlight=!1})}return this._aocJjSummary??"jj..."}if(this.#cachedBranch!==void 0)return this.#cachedBranch;let headState=head.resolveSync(cwd);return this.#cachedBranch=headState===null?null:headState.kind==="ref"?headState.branchName??headState.ref:"detached",this.#cachedBranch}'
pr_old = 'branch === "detached" || this.#isDefaultBranch(branch) || this.#prLookupInFlight'
pr_new = 'branch === "detached" || branch === "jj?" || branch === "jj..." || branch.startsWith("Δ") || this.#isDefaultBranch(branch) || this.#prLookupInFlight'
old_sync_helper = re.compile(r'function aocFindJjRepoDir(?:Async)?\(cwd\).*?function aocResolveJjSummary(?:Sync|Async)\([^)]*\)\{.*?return`(?:\\u0394|Δ)\$\{files\} \+\$\{added\} -\$\{removed\} (?:\\u21E2|⇢)\$\{bookmarks\}`\}', re.S)
footer_import_re = re.compile(r'import\*as (fs\d+) from"fs";import\*as (path\d+) from"path";import\{stripVTControlCharacters as stripVTControlCharacters2\}from"util";class FooterComponent')
seen = set()
for path in bundle_paths:
    path = path.expanduser()
    if path in seen or not path.is_file():
        continue
    seen.add(path)
    text = path.read_text('utf-8')
    text = old_sync_helper.sub('', text, count=1)
    footer_match = footer_import_re.search(text)
    if not footer_match:
        print(f"aoc-omp-patch: warning: helper anchor missing in {path}", file=sys.stderr)
        continue
    fs_alias, path_alias = footer_match.groups()
    helper = f'''function aocFindJjRepoDirAsync(cwd){{let dir=cwd;for(;;){{if({fs_alias}.existsSync({path_alias}.join(dir,".jj","repo")))return dir;let parent={path_alias}.dirname(dir);if(parent===dir)return null;dir=parent}}}}async function aocRunJjAsync(repoDir,args){{try{{let proc=Bun.spawn(["jj","--no-pager","--color=never",...args],{{cwd:repoDir,stdin:"ignore",stdout:"pipe",stderr:"ignore"}}),stdout=await new Response(proc.stdout).text(),code=await proc.exited;if(code!==0)return null;return stdout.trim()}}catch{{return null}}}}function aocCountEditedFilesAsync(summary){{return summary.split("\\n").filter((line)=>line.trim()!=="").length}}function aocCountAddedRemovedAsync(stat){{let added=0,removed=0;for(let match of stat.matchAll(/([0-9]+)\\s+insertions?\\(\\+\\)/g))added+=Number(match[1]);for(let match of stat.matchAll(/([0-9]+)\\s+deletions?\\(-\\)/g))removed+=Number(match[1]);return{{added,removed}}}}function aocCountActiveBookmarksAsync(bookmarks){{return bookmarks.split("\\n").filter((line)=>{{let trimmed=line.trim();return trimmed!==""&&!/^\\s/.test(line)&&!line.includes("@origin")&&!line.includes("deleted")&&!line.includes("conflicted")}}).length}}async function aocResolveJjSummaryAsync(repoDir){{let[summary,stat,bookmarksText]=await Promise.all([aocRunJjAsync(repoDir,["diff","--summary"]),aocRunJjAsync(repoDir,["diff","--stat"]),aocRunJjAsync(repoDir,["bookmark","list"])]);if(summary===null||stat===null||bookmarksText===null)return"jj?";let files=aocCountEditedFilesAsync(summary),{{added,removed}}=aocCountAddedRemovedAsync(stat),bookmarks=aocCountActiveBookmarksAsync(bookmarksText);return`\\u0394${{files}} +${{added}} -${{removed}} \\u21E2${{bookmarks}}`}}'''
    if 'function aocFindJjRepoDirAsync' not in text:
        text = text[:footer_match.start()] + helper + text[footer_match.start():]
    if new_status not in text:
        for old_status in old_statuses:
            if old_status in text:
                text = text.replace(old_status, new_status, 1)
                break
        else:
            print(f"aoc-omp-patch: warning: status method anchor missing in {path}", file=sys.stderr)
            continue
    text = text.replace('"jj…"', '"jj..."')
    text = text.replace(pr_old, pr_new, 1)
    path.write_text(text, 'utf-8')
    if not quiet:
        print(f"aoc-omp-patch: patched {path}")

config_path = Path.home() / ".omp/agent/config.yml"
status_block = '''statusLine: 
  separator: powerline-thin
  preset: custom
  leftSegments: 
    - model
    - mode
    - path
    - git
  rightSegments: 
    - context_pct
    - session_name
  segmentOptions:
    git:
      showBranch: true
      showStaged: false
      showUnstaged: false
      showUntracked: false
  sessionAccent: true'''
if config_path.is_file():
    cfg = config_path.read_text('utf-8')
    if re.search(r'^symbolPreset:', cfg, flags=re.M):
        cfg = re.sub(r'^symbolPreset:.*$', 'symbolPreset: nerd', cfg, count=1, flags=re.M)
    else:
        cfg = 'symbolPreset: nerd\n' + cfg
    status_re = r'^statusLine:\s*\n(?:^[ \t].*\n?)*'
    if re.search(status_re, cfg, flags=re.M):
        cfg = re.sub(status_re, status_block + '\n', cfg, count=1, flags=re.M)
    else:
        cfg = cfg.rstrip() + '\n' + status_block + '\n'
    config_path.write_text(cfg, 'utf-8')
    if not quiet:
        print(f"aoc-omp-patch: configured {config_path}")
else:
    print(f"aoc-omp-patch: warning: config not found: {config_path}", file=sys.stderr)
PY
