#!/usr/bin/env python3
"""AOC startup handshake: metadata-only project/runtime orientation for agents.

The handshake intentionally does not inject broad Mind memories. It reports
availability, freshness/policy, and safe next-step commands so agents can ask
for focused Mind context only after user intent is known.
"""
from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import sys
from pathlib import Path
from typing import Any


def truthy(value: str | None) -> bool:
    return (value or "").strip().lower() in {"1", "true", "yes", "on"}


def find_project_root(start: Path) -> Path:
    current = start.resolve()
    for candidate in [current, *current.parents]:
        if (candidate / ".aoc").exists() or (candidate / "AGENTS.md").exists() or (candidate / ".git").exists():
            return candidate
    return current


def read_json(path: Path) -> dict[str, Any]:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def run(cmd: list[str], cwd: Path, timeout: float = 5.0) -> dict[str, Any]:
    try:
        proc = subprocess.Popen(
            cmd,
            cwd=str(cwd),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            start_new_session=True,
        )
    except FileNotFoundError as exc:
        return {"ok": False, "error": f"missing command: {exc.filename}"}
    except Exception as exc:
        return {"ok": False, "error": str(exc)}

    try:
        stdout, stderr = proc.communicate(timeout=timeout)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
        try:
            stdout, stderr = proc.communicate(timeout=0.5)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(proc.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            stdout, stderr = proc.communicate()
        return {
            "ok": False,
            "exitCode": proc.returncode,
            "stdout": stdout.strip(),
            "stderr": stderr.strip(),
            "error": f"timeout after {timeout}s",
        }

    return {
        "ok": proc.returncode == 0,
        "exitCode": proc.returncode,
        "stdout": stdout.strip(),
        "stderr": stderr.strip(),
    }


def first_line(value: Any) -> str | None:
    text = str(value or "").strip()
    if not text:
        return None
    return text.splitlines()[0][:240]


def detect_vcs(project_root: Path) -> dict[str, Any]:
    git_marker = project_root / ".git"
    git_present = git_marker.exists()

    git_root: str | None = None
    git_branch: str | None = None
    git_head: str | None = None
    if git_present:
        git_root_result = run(["git", "rev-parse", "--show-toplevel"], project_root, timeout=3.0)
        if git_root_result.get("ok"):
            git_root = first_line(git_root_result.get("stdout"))
        branch_result = run(["git", "branch", "--show-current"], project_root, timeout=3.0)
        if branch_result.get("ok"):
            git_branch = first_line(branch_result.get("stdout"))
        head_result = run(["git", "rev-parse", "--short", "HEAD"], project_root, timeout=3.0)
        if head_result.get("ok"):
            git_head = first_line(head_result.get("stdout"))

    kind = "git" if git_present else "none"
    preferred_tool = "git" if git_present else "none"
    root = git_root if git_root else str(project_root)
    git_label = git_branch or ("detached" if git_head else ("unknown" if git_present else None))

    if kind == "git":
        policy = {
            "inspect": ["git status --short", "git diff --stat", "git diff --cached --stat"],
            "commit": "Use explicit path staging for the intended atomic change.",
            "parallelism": "Do not mix unrelated parallel-agent changes in one commit.",
            "push": "Never push without explicit approval.",
        }
    else:
        policy = {
            "inspect": [],
            "commit": "No VCS detected; do not commit unless the operator configures a repository.",
            "parallelism": "Keep unrelated changes separated by task.",
            "push": "Never push without explicit approval.",
        }

    return {
        "kind": kind,
        "preferredTool": preferred_tool,
        "root": root,
        "git": {
            "present": bool(git_present),
            "root": git_root,
            "branch": git_label,
        },
        "agentPolicy": policy,
    }

def runnable(candidate: str | None) -> str | None:
    if not candidate:
        return None
    candidate = candidate.strip()
    if not candidate:
        return None
    if "/" in candidate or "\\" in candidate:
        return candidate if Path(candidate).exists() else None
    return candidate


def resolve_mind_launcher(project_root: Path) -> dict[str, Any]:
    xdg_config = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config")))
    project_cfg_path = project_root / ".aoc" / "mind-service.json"
    global_cfg_path = xdg_config / "aoc" / "mind-service.json"
    project_cfg = read_json(project_cfg_path)
    global_cfg = read_json(global_cfg_path)

    env_bin = runnable(os.environ.get("AOC_MIND_SERVICE_BIN"))
    env_manifest = os.environ.get("AOC_MIND_CARGO_MANIFEST")
    env_source = os.environ.get("AOC_MIND_SOURCE_ROOT")

    service_bin = next(
        (value for value in [env_bin, runnable(str(project_cfg.get("serviceBin") or "")), runnable(str(global_cfg.get("serviceBin") or "")), "aoc-mind-service"] if value),
        None,
    )
    manifest_candidates = [
        env_manifest,
        str(Path(env_source) / "crates" / "Cargo.toml") if env_source else None,
        str(project_cfg.get("cargoManifest") or "") or None,
        str(Path(str(project_cfg.get("sourceRoot"))) / "crates" / "Cargo.toml") if project_cfg.get("sourceRoot") else None,
        str(global_cfg.get("cargoManifest") or "") or None,
        str(Path(str(global_cfg.get("sourceRoot"))) / "crates" / "Cargo.toml") if global_cfg.get("sourceRoot") else None,
        str(project_root / "crates" / "Cargo.toml"),
    ]
    cargo_manifest = next((m for m in manifest_candidates if m and Path(m).exists()), None)
    return {
        "projectConfigPath": str(project_cfg_path),
        "projectConfigPresent": project_cfg_path.exists(),
        "globalConfigPath": str(global_cfg_path),
        "globalConfigPresent": global_cfg_path.exists(),
        "serviceBin": service_bin,
        "cargoManifest": cargo_manifest,
        "source": "env" if (env_bin or env_manifest or env_source) else ("project" if project_cfg_path.exists() else ("global" if global_cfg_path.exists() else "path-or-local")),
    }


def mind_status(project_root: Path, launcher: dict[str, Any]) -> dict[str, Any]:
    cmd = [str(launcher.get("serviceBin") or "aoc-mind-service"), "status", "--project-root", str(project_root), "--json"]
    result = run(cmd, project_root, timeout=8.0)
    if result.get("ok") and result.get("stdout"):
        try:
            parsed = json.loads(str(result["stdout"]))
        except Exception:
            parsed = None
        return {"available": True, "commandOk": True, "raw": parsed if isinstance(parsed, dict) else None}

    # Cargo fallback mirrors extension behavior when an installed binary is absent.
    manifest = launcher.get("cargoManifest")
    if manifest:
        cargo_cmd = ["cargo", "run", "--quiet", "--manifest-path", str(manifest), "--bin", "aoc-mind-service", "--", "status", "--project-root", str(project_root), "--json"]
        result = run(cargo_cmd, project_root, timeout=20.0)
        if result.get("ok") and result.get("stdout"):
            try:
                parsed = json.loads(str(result["stdout"]))
            except Exception:
                parsed = None
            return {"available": True, "commandOk": True, "via": "cargo", "raw": parsed if isinstance(parsed, dict) else None}

    return {
        "available": False,
        "commandOk": False,
        "error": result.get("error") or result.get("stderr") or result.get("stdout") or "mind status unavailable",
    }


def mind_sync(project_root: Path, launcher: dict[str, Any]) -> dict[str, Any]:
    cmd = [str(launcher.get("serviceBin") or "aoc-mind-service"), "sync-pi", "--project-root", str(project_root), "--agent-id", os.environ.get("AOC_AGENT_ID", "aoc-handshake"), "--json"]
    session_file = os.environ.get("AOC_PI_SESSION_FILE")
    if session_file:
        cmd.extend(["--session-file", session_file])
    result = run(cmd, project_root, timeout=10.0)
    if result.get("ok") and result.get("stdout"):
        try:
            parsed = json.loads(str(result["stdout"]))
        except Exception:
            parsed = None
        return {"attempted": True, "ok": True, "raw": parsed if isinstance(parsed, dict) else None}
    return {"attempted": True, "ok": False, "error": result.get("error") or result.get("stderr") or result.get("stdout") or "mind sync unavailable"}

def vcs_summary(vcs: dict[str, Any]) -> str:
    kind = str(vcs.get("kind") or "unknown")
    preferred = str(vcs.get("preferredTool") or "none")
    return f"{kind}; preferred={preferred}"


def vcs_policy_line(vcs: dict[str, Any]) -> str:
    kind = str(vcs.get("kind") or "unknown")
    if kind == "git":
        return "git explicit path staging; keep the commit atomic"
    return "no VCS detected; do not commit until configured"




def build_packet(project_root: Path, do_sync: bool) -> dict[str, Any]:
    aoc_dir = project_root / ".aoc"
    vcs = detect_vcs(project_root)
    launcher = resolve_mind_launcher(project_root)
    status = mind_status(project_root, launcher)
    active_tag_result = run(["tm", "tag", "current"], project_root, timeout=3.0)
    rtk_config_present = (aoc_dir / "rtk.toml").exists()

    packet: dict[str, Any] = {
        "schemaVersion": 1,
        "kind": "aoc.startup.handshake",
        "projectRoot": str(project_root),
        "mode": "metadata-only",
        "vcs": vcs,
        "aoc": {
            "initialized": aoc_dir.exists(),
            "contextPath": ".aoc/context.md",
            "contextPresent": (aoc_dir / "context.md").exists(),
            "agentsContractPresent": (project_root / "AGENTS.md").exists(),
            "stmPresent": (aoc_dir / "stm").exists(),
            "memoryPresent": (aoc_dir / "memory.md").exists(),
            "rtkStatusAvailable": rtk_config_present,
        },
        "taskmaster": {
            "available": bool(active_tag_result.get("ok")),
            "activeTag": active_tag_result.get("stdout") if active_tag_result.get("ok") else None,
        },
        "mind": {
            "available": bool(status.get("available")),
            "configured": bool(launcher.get("projectConfigPresent") or launcher.get("globalConfigPresent") or launcher.get("serviceBin") or launcher.get("cargoManifest")),
            "launcher": launcher,
            "status": status,
            "contextPolicy": {
                "startupInjection": "metadata-only",
                "defaultContextMode": "none",
                "ingestPolicy": "safe to sync/ingest at startup; do not inject broad memories",
                "retrievalPolicy": "request focused Mind evidence/provenance only after user intent is known",
            },
            "recommendedTriggers": [
                "user asks to resume or continue prior work",
                "user asks about previous decisions or provenance",
                "task/PRD grounding is needed",
                "debugging needs prior attempts",
                "targeted local inspection is insufficient",
            ],
            "focusedCommands": {
                "status": "aoc-mind-service status --project-root <root> --json",
                "sync": "aoc-mind-service sync-pi --project-root <root> --json",
                "serveOnce": "aoc-mind-service serve --project-root <root> --agent-id <agent-id> --once --json",
                "evidence": "aoc-mind-service evidence-pack --project-root <root> --mode focused --reason <explicit-reason> --json",
                "contextPack": "aoc-mind-service context-pack --project-root <root> --mode focused --reason <explicit-reason> --json",
                "resume": "aoc-mind-service context-pack --project-root <root> --mode resume --reason <explicit-resume-request> --json",
                "provenance": "aoc-mind-service provenance-query --project-root <root> --json",
                "mnemopiCandidates": "aoc-mind-service mnemopi-candidates --project-root <root> --reason <explicit-reason> --json",
            },
        },
        "agentGuidance": [
            "Use .aoc/context.md and AGENTS.md for startup orientation.",
            "Do not load broad Mind memories during startup.",
            "Use Mind as focused evidence/provenance for OMP/Mnemopi after task intent is clear.",
            "Prefer narrow searches, evidence packs, focused context packs, and concise summaries.",
        ],
        "warnings": [],
    }
    if do_sync:
        packet["mind"]["sync"] = mind_sync(project_root, launcher)
    if not packet["aoc"]["contextPresent"]:
        packet["warnings"].append("missing .aoc/context.md; run aoc-init")
    if not packet["mind"]["available"]:
        packet["warnings"].append("Mind unavailable; install aoc-mind-service or run aoc-init after ./install.sh")
    return packet


def print_text(packet: dict[str, Any]) -> None:
    print(f"AOC handshake: {packet['projectRoot']}")
    print(f"  mode: {packet['mode']}")
    print(f"  vcs: {vcs_summary(packet.get('vcs', {}))}")
    print(f"  context: {'present' if packet['aoc']['contextPresent'] else 'missing'}")
    print(f"  taskmaster: {'available' if packet['taskmaster']['available'] else 'unavailable'}")
    if packet['taskmaster'].get('activeTag'):
        print(f"  active_tag: {packet['taskmaster']['activeTag']}")
    print(f"  mind: {'available' if packet['mind']['available'] else 'unavailable'}")
    print("  mind_policy: metadata-only startup; retrieve focused context after intent is known")
    for warning in packet.get("warnings", []):
        print(f"  warning: {warning}")



def print_prompt_min(packet: dict[str, Any]) -> None:
    aoc = packet.get("aoc", {})
    taskmaster = packet.get("taskmaster", {})
    mind = packet.get("mind", {})
    warnings = packet.get("warnings", [])
    vcs = packet.get("vcs", {})
    parts = [
        "# AOC Startup Context",
        f"root={packet.get('projectRoot')}",
        f"vcs={vcs.get('kind', 'unknown')}; preferred={vcs.get('preferredTool', 'none')}; policy={vcs_policy_line(vcs)}",
        f"aoc={'yes' if aoc.get('initialized') else 'no'}",
        f"context={'present' if aoc.get('contextPresent') else 'missing'}",
        f"taskmaster={'yes' if taskmaster.get('available') else 'no'}",
        f"active_tag={taskmaster.get('activeTag') or 'none'}",
        f"mind={'yes' if mind.get('available') else 'no'}",
        "policy=metadata-only; no broad Mind/task/raw AGENTS injection; load focused context only after user intent",
    ]
    if warnings:
        parts.append("warnings=" + "; ".join(str(w) for w in warnings))
    print("\n".join(parts))


def print_prompt_compact(packet: dict[str, Any]) -> None:
    aoc = packet.get("aoc", {})
    taskmaster = packet.get("taskmaster", {})
    mind = packet.get("mind", {})
    warnings = packet.get("warnings", [])
    vcs = packet.get("vcs", {})
    print("# AOC Startup Context")
    print()
    print("- Mode: metadata-only startup capsule; do not inject broad Mind memories, raw task state, raw AGENTS chains, skills, prompts, extension source, or docs by default.")
    print(f"- Root: `{packet.get('projectRoot')}`")
    print(f"- AOC: {'initialized' if aoc.get('initialized') else 'not initialized'}; context `{aoc.get('contextPath', '.aoc/context.md')}` is {'present' if aoc.get('contextPresent') else 'missing'}; agent contract is {'present' if aoc.get('agentsContractPresent') else 'missing'}.")
    print(f"- VCS: {vcs_summary(vcs)}. Safety rule: {vcs_policy_line(vcs)}; never push without explicit approval.")
    active_tag = taskmaster.get("activeTag") or "none"
    print(f"- Taskmaster: {'available' if taskmaster.get('available') else 'unavailable'}; active tag `{active_tag}`. Use CLI commands for task/spec details; do not read task JSON directly.")
    print(f"- Mind: {'available' if mind.get('available') else 'unavailable'}. Retrieve focused context only after user intent is known and the reason is explicit.")
    print(f"- RTK status command: {'available' if aoc.get('rtkStatusAvailable') else 'unavailable'}; CodeGraph/RTK/details are lazy capability lookups, not startup prose.")
    print("- Protected direct reads: `.aoc/memory.md`, `.aoc/stm/current.md`, `.taskmaster/tasks/tasks.json`.")
    if warnings:
        print("- Warnings: " + "; ".join(str(w) for w in warnings))


def print_prompt_full(packet: dict[str, Any]) -> None:
    aoc = packet.get("aoc", {})
    taskmaster = packet.get("taskmaster", {})
    mind = packet.get("mind", {})
    warnings = packet.get("warnings", [])
    vcs = packet.get("vcs", {})
    print("# AOC Startup Context")
    print()
    print("This is a metadata-only startup capsule. It orients the agent without loading broad memory or raw task state.")
    print()
    print("## Project")
    print(f"- Root: `{packet.get('projectRoot')}`")
    print(f"- AOC initialized: {'yes' if aoc.get('initialized') else 'no'}")
    print(f"- Project context: `{aoc.get('contextPath', '.aoc/context.md')}` ({'present' if aoc.get('contextPresent') else 'missing'})")
    print(f"- Agent contract: {'present' if aoc.get('agentsContractPresent') else 'missing'}")
    print(f"- VCS: {vcs_summary(vcs)}")
    print(f"- VCS root: `{vcs.get('root') or packet.get('projectRoot')}`")
    print()
    print("## Taskmaster")
    print(f"- Available: {'yes' if taskmaster.get('available') else 'no'}")
    active_tag = taskmaster.get("activeTag")
    if active_tag:
        print(f"- Active tag: `{active_tag}`")
    print("- Use `tm tag current`, `tm list`, `tm show <id>`, and `aoc-task ...` commands for task/spec grounding.")
    print("- Do not read `.taskmaster/tasks/tasks.json` directly.")
    print()
    print("## Mind / recall policy")
    print(f"- Available: {'yes' if mind.get('available') else 'no'}")
    print("- Startup injection: metadata-only.")
    print("- Do not load broad Mind memories at startup.")
    print("- Request focused Mind evidence/provenance only after user intent is known, with an explicit reason.")
    print("- Good triggers: resume/continue, previous decisions, task/spec grounding, debugging prior attempts, provenance/audit, or targeted local inspection proving insufficient.")
    focused = mind.get("focusedCommands") if isinstance(mind.get("focusedCommands"), dict) else {}
    if focused:
        print("- Focused commands:")
        for name in ["status", "sync", "serveOnce", "evidence", "contextPack", "resume", "provenance", "mnemopiCandidates"]:
            command = focused.get(name)
            if command:
                print(f"  - {name}: `{command}`")
    print()
    print("## CodeGraph")
    print("- If `.codegraph/` exists and the OMP `aoc_codegraph` tool is available, use it before broad text scans for code discovery, architecture tracing, impact analysis, and affected-test selection.")
    print("- Treat CodeGraph as read-only inside the agent. Initialization, indexing, and sync are explicit operator actions.")
    print()
    print("## VCS policy")
    print(f"- Detected: {vcs_summary(vcs)}")
    print("- Git repositories: use `git status --short`, targeted diffs, explicit path staging, `git commit`, and report the observed SHA.")
    print("- Never push without explicit approval.")
    print()
    print("## Slash commands")
    print("- `/commit [scope]` is the AOC/OMP safe atomic commit workflow. Treat it as approval to inspect changes, run targeted validation, commit only the intended atomic work with Git, and report the observed Git SHA. Never push without explicit approval.")
    print()
    print("## RTK")
    print(f"- Status command available: {'yes' if aoc.get('rtkStatusAvailable') else 'no'}")
    print("- RTK is for allowlisted noisy commands only; native fallback and raw output preservation remain required.")
    print()
    print("## Protected direct reads")
    print("- Do not directly read `.aoc/memory.md`, `.aoc/stm/current.md`, or `.taskmaster/tasks/tasks.json`; use the AOC CLIs.")
    if warnings:
        print()
        print("## Warnings")
        for warning in warnings:
            print(f"- {warning}")


def print_prompt(packet: dict[str, Any], level: str = "compact") -> None:
    if level == "min":
        print_prompt_min(packet)
    elif level == "full":
        print_prompt_full(packet)
    else:
        print_prompt_compact(packet)

def main() -> int:
    parser = argparse.ArgumentParser(description="Print metadata-only AOC startup handshake for agents")
    parser.add_argument("path", nargs="?", default=os.getcwd())
    parser.add_argument("--json", action="store_true", help="print JSON packet")
    parser.add_argument("--prompt", action="store_true", help="print markdown suitable for OMP --append-system-prompt")
    parser.add_argument("--prompt-level", choices=["min", "compact", "full"], default=os.environ.get("AOC_OMP_CONTEXT_LEVEL", "compact"), help="prompt verbosity for --prompt")
    parser.add_argument("--sync", action="store_true", help="attempt Mind sync-pi but still do not inject memories")
    args = parser.parse_args()
    project_root = find_project_root(Path(args.path))
    packet = build_packet(project_root, args.sync or truthy(os.environ.get("AOC_HANDSHAKE_SYNC")))
    if args.json:
        print(json.dumps(packet, indent=2))
    elif args.prompt:
        print_prompt(packet, args.prompt_level)
    else:
        print_text(packet)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
