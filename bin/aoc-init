  "pnpm test",
  "pnpm run",
  "pnpm exec",
  "bun test",
  "bun run",
  "aoc-task",
  "tm list",
  "aoc-mind-service status",
  "aoc-rtk doctor",
  "journalctl",
  "systemctl status",
]
denylist = [
  "git add",
  "git commit",
  "git checkout",
  "git switch",
  "git restore",
  "git stash",
  "git merge",
  "git rebase",
  "git push",
