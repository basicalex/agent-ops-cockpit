      log "Seeded fallback project PRD template: $project_prd"
    fi
  fi

  local project_prd_txt="$task_dir/docs/prd.txt"
  if [[ -f "$project_prd" && ! -f "$project_prd_txt" ]]; then
    cp "$project_prd" "$project_prd_txt"
    log "Seeded Taskmaster-compatible project PRD copy: $project_prd_txt"
  fi

  # Config Seeding (Preserve existing logic, but ensure Gemini preference)
  local local_conf="$task_dir/config.json"
  
  if [[ -f "$global_task_conf" ]]; then
    if [[ ! -f "$local_conf" ]]; then
      log "Seeding Taskmaster config from global defaults..."
      cp "$global_task_conf" "$local_conf"
    else
      # Advanced: We could merge JSON here, but for now we trust the local config
      # if it exists, assuming the user might have customized it for this specific repo.
      log "Local Taskmaster config exists. Preserving."
    fi
  else
    warn "No global Taskmaster config found at $global_task_conf. Skipping seed."
  fi
}

# 3. Environment Checks
setup_env() {
  if [[ ! -f "$project_root/.env" && -f "$project_root/.env.example" ]]; then
    log "Copying .env.example to .env..."
    cp "$project_root/.env.example" "$project_root/.env"
  fi
}

setup_aoc_map() {
  local map_dir="$project_root/.aoc/map"
  local aoc_map_skill="$project_root/.pi/skills/aoc-map/SKILL.md"
  local aoc_map_skill_dir="$project_root/.pi/skills/aoc-map"
  local canonical_skill_src="$script_dir/../.pi/skills/aoc-map/SKILL.md"
  local output=""
  local -a init_args=(init)

  if (( aoc_init_force == 1 )); then
    init_args+=(--force)
  fi

  if [[ -f "$aoc_map_skill" && $aoc_init_force -eq 0 ]]; then
    log "AOC Map skill exists ($aoc_map_skill). Preserving."
  elif [[ -f "$canonical_skill_src" ]]; then
    mkdir -p "$aoc_map_skill_dir"
    cp "$canonical_skill_src" "$aoc_map_skill"
    if (( aoc_init_force == 1 )); then
      log "Refreshed AOC Map skill ($aoc_map_skill)."
    else
      log "Seeded AOC Map skill ($aoc_map_skill)."
    fi
  fi

  if command -v aoc-map >/dev/null 2>&1; then
    if output="$(cd "$project_root" && aoc-map "${init_args[@]}" 2>&1)"; then
      log "AOC Map workspace ready ($map_dir)."
      if [[ -f "$aoc_map_skill" ]]; then
        log "AOC Map skill ready ($aoc_map_skill)."
      else
        warn "AOC Map skill missing after aoc-map init ($aoc_map_skill)."
      fi
    else
      warn "aoc-map init failed; unable to seed $map_dir."
      [[ -n "$output" ]] && warn "$output"
    fi
  elif [[ -x "$script_dir/aoc-map" ]]; then
    if output="$(cd "$project_root" && "$script_dir/aoc-map" "${init_args[@]}" 2>&1)"; then
      log "AOC Map workspace ready ($map_dir)."
      if [[ -f "$aoc_map_skill" ]]; then
        log "AOC Map skill ready ($aoc_map_skill)."
      else
        warn "AOC Map skill missing after aoc-map init ($aoc_map_skill)."
      fi
    else
      warn "aoc-map init failed; unable to seed $map_dir."
      [[ -n "$output" ]] && warn "$output"
    fi
  else
    warn "aoc-map not found; skipping AOC Map workspace seeding."
  fi
}

repair_managed_zellij_plugin_wiring() {
  local zellij_config="${ZELLIJ_CONFIG_DIR:-$HOME/.config/zellij}/aoc.config.kdl"
  local zellij_layout="${ZELLIJ_CONFIG_DIR:-$HOME/.config/zellij}/layouts/aoc.kdl"
  local managed_wasm="${ZELLIJ_CONFIG_DIR:-$HOME/.config/zellij}/plugins/zjstatus-aoc.wasm"

  python3 - "$zellij_config" "$zellij_layout" "$managed_wasm" <<'PY'
import sys
from pathlib import Path

config = Path(sys.argv[1])
layout = Path(sys.argv[2])
managed_wasm = sys.argv[3]

if config.exists():
    text = config.read_text(encoding="utf-8")
    changed = False
    alias = f'    aoc-tab-bar location="file:{managed_wasm}"\n'
    if "aoc-tab-bar location=" not in text and '    tab-bar location="zellij:tab-bar"\n' in text:
        text = text.replace('    tab-bar location="zellij:tab-bar"\n', '    tab-bar location="zellij:tab-bar"\n' + alias, 1)
        changed = True
    if "load_plugins {" in text:
        before, rest = text.split("load_plugins {", 1)
        body, after = rest.split("}", 1)
        lines = [line for line in body.splitlines() if "aoc-tab-bar" not in line]
        next_body = "\n".join(lines)
        if next_body.strip():
            next_text = before + "load_plugins {" + next_body + "\n}" + after
        else:
            next_text = before.rstrip() + "\n\n" + after.lstrip()
        if next_text != text:
            text = next_text
            changed = True
    if changed:
        config.write_text(text, encoding="utf-8")

if layout.exists():
    text = layout.read_text(encoding="utf-8")
    next_text = text.replace(f'plugin location="file:{managed_wasm}" {{', 'plugin location="aoc-tab-bar" {')
    next_text = next_text.replace('plugin location="file:{{HOME}}/.config/zellij/plugins/zjstatus-aoc.wasm" {', 'plugin location="aoc-tab-bar" {')
    if next_text != text:
        layout.write_text(next_text, encoding="utf-8")
PY
}

setup_managed_zellij_plugin() {
  local plugin_cmd=""

  if [[ -x "$script_dir/aoc-zellij-plugin" ]]; then
    plugin_cmd="$script_dir/aoc-zellij-plugin"
  elif command -v aoc-zellij-plugin >/dev/null 2>&1; then
    plugin_cmd="$(command -v aoc-zellij-plugin)"
  fi

  if [[ -z "$plugin_cmd" ]]; then
    warn "aoc-zellij-plugin not found; managed Zellij top-bar plugin may be missing."
    return
  fi

  if "$plugin_cmd" install; then
    repair_managed_zellij_plugin_wiring || true
    log "Managed AOC Zellij plugin ready (~/.config/zellij/plugins/zjstatus-aoc.wasm)."
  else
    warn "Managed AOC Zellij plugin install failed."
  fi
}

# 4. Ensure AOC Rust binaries are available
setup_binaries() {
  if [[ "${AOC_INIT_SKIP_BUILD:-0}" == "1" ]]; then
    log "Skipping Rust binary build (AOC_INIT_SKIP_BUILD=1)."
    return
  fi

  local manifest_path=""
  if [[ -f "$project_root/crates/Cargo.toml" ]]; then
    manifest_path="$project_root/crates/Cargo.toml"
  elif [[ -f "$script_dir/../crates/Cargo.toml" ]]; then
    manifest_path="$script_dir/../crates/Cargo.toml"
  fi

  local required=(aoc-hub-rs aoc-agent-wrap-rs aoc-mission-control aoc-taskmaster aoc-control)
  local missing=()
  local bin=""
  local manifest_dir=""
  if [[ -n "$manifest_path" ]]; then
    manifest_dir="$(dirname "$manifest_path")"
  fi

  for bin in "${required[@]}"; do
    if command -v "$bin" >/dev/null 2>&1; then
      continue
    fi
    if [[ -n "$manifest_dir" ]]; then
      if [[ -x "$manifest_dir/target/release/$bin" || -x "$manifest_dir/target/debug/$bin" ]]; then
        continue
      fi
    fi
    missing+=("$bin")
  done

  if ((${#missing[@]} == 0)); then
    log "Rust binaries already available. Skipping build."
    return
  fi

  if [[ -z "$manifest_path" ]]; then
    warn "Rust workspace not found. Missing binaries: ${missing[*]}"
    return
  fi

  if ! command -v cargo >/dev/null 2>&1; then
    warn "cargo not found; unable to build binaries: ${missing[*]}"
    return
  fi

  log "Building AOC Rust binaries: ${required[*]}"
  cargo build --manifest-path "$manifest_path" -p aoc-hub-rs -p aoc-agent-wrap-rs -p aoc-mission-control -p aoc-taskmaster -p aoc-control
}

main() {
  if [[ "$aoc_init_check_managed_only" == "1" ]]; then
    refresh_aoc_managed_manifest
    print_project_aoc_status
    return 0
  fi

  if [[ "$aoc_init_status_only" == "1" ]]; then
    print_project_aoc_status
    return 0
  fi

  refuse_nested_hyperframes_init
  log "Initializing AOC in: $project_root"
  setup_memory
  prepare_project_aoc_state
  apply_project_version_migrations
  setup_project_mind_service_config
  setup_project_mind_runtime
  setup_pi_packages
  setup_pi_settings
  cleanup_global_pi_multi_auth
  cleanup_deprecated_pi_skills
  setup_pi_extensions
  setup_pi_extension_families
  setup_pi_agents
  setup_search_assets
  migrate_legacy_pi_assets
  setup_pi_prompts
  setup_pi_skills
  setup_aoc_preset_assets
  setup_skills
  setup_aoc_map
  setup_tasks
  ensure_git_tracking_policy
  setup_env
  setup_managed_zellij_plugin
  setup_binaries
  refresh_aoc_managed_manifest
  write_project_aoc_state
  if ! validate_project_pi_runtime_contract; then
    warn "AOC initialization finished with PI runtime validation errors."
    exit 1
  fi
  log "AOC Initialization Complete. Ready to launch."
}

main
