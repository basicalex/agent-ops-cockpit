#!/usr/bin/env bash
set -euo pipefail

# AOC Initialization Script
# Usage: aoc-init [--force] [path]
#
# This script standardizes a project for the Agent Ops Cockpit.
# It is IDEMPOTENT: safe to run multiple times. It respects existing data.

usage() {
  cat <<'EOF'
Usage: aoc-init [--force] [--status] [--check-managed] [path]

Options:
  --force          Refresh canonical AOC Map seed files and pass --force to aoc-map init
  --status         Print AOC init/version/runtime status for the target project and exit
  --check-managed  Refresh managed asset manifest/status and exit
  -h, --help       Show this help text
EOF
}

aoc_init_force=0
aoc_init_status_only=0
aoc_init_check_managed_only=0
project_root="$PWD"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      aoc_init_force=1
      shift
      ;;
    --status)
      aoc_init_status_only=1
      shift
      ;;
    --check-managed)
      aoc_init_check_managed_only=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      if [[ $# -gt 0 ]]; then
        project_root="$1"
        shift
      fi
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      project_root="$1"
      shift
      ;;
  esac
done

if [[ $# -gt 0 ]]; then
  echo "Unexpected extra arguments: $*" >&2
  usage >&2
  exit 1
fi

aoc_dir="$project_root/.aoc"
gemini_dir="$project_root/.gemini"
task_dir="$project_root/.taskmaster"
global_task_conf="$HOME/.taskmaster/config.json"
aoc_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/aoc"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
aoc_init_state_file="$aoc_dir/init-state.json"
aoc_managed_assets_file="$aoc_dir/managed-assets.json"
aoc_omp_seed_cache_dir="$aoc_config_dir/omp"

AOC_PROJECT_LAYOUT_VERSION=3
AOC_INIT_STATE_SCHEMA_VERSION=1

aoc_project_version_before=0
aoc_project_version_after="$AOC_PROJECT_LAYOUT_VERSION"
aoc_project_migrations_applied=()

log() { echo ">> $1"; }
warn() { echo "!! $1"; }

refuse_nested_hyperframes_init() {
  [[ "${AOC_INIT_ALLOW_NESTED_HYPERFRAMES:-0}" == "1" ]] && return 0
  python3 - "$project_root" <<'PY'
import sys
from pathlib import Path
root = Path(sys.argv[1]).resolve()
parent = root.parent
if root.name == "hyperframes" and (parent / ".aoc").is_dir():
    print(f"Refusing nested aoc-init inside HyperFrames workspace: {root}", file=sys.stderr)
    print(f"Run aoc-init from project root instead: {parent}", file=sys.stderr)
    raise SystemExit(2)
PY
}

is_truthy() {
  local value="${1:-}"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
  case "$value" in
    1|true|yes|on) return 0 ;;
    *) return 1 ;;
  esac
}

aoc_omp_seed_root() {
  local repo_seed_root="$script_dir/../.omp"
  if [[ -d "$repo_seed_root" ]]; then
    printf '%s\n' "$repo_seed_root"
  else
    printf '%s\n' "$aoc_omp_seed_cache_dir"
  fi
}

read_omp_manifest_list() {
  local key="$1"
  python3 - "$(aoc_omp_seed_root)/manifest.toml" "$key" <<'PY'
import sys
import tomllib
from pathlib import Path

manifest = Path(sys.argv[1])
key = sys.argv[2]
try:
    data = tomllib.loads(manifest.read_text())
    values = data[key]
    if not isinstance(values, list) or not all(isinstance(value, str) for value in values):
        raise TypeError(f"{key} must be a list of strings")
except Exception as exc:
    print(f"invalid OMP manifest {manifest}: {exc}", file=sys.stderr)
    sys.exit(2)
for value in values:
    print(value)
PY
}

read_omp_active_list() {
  local kind="$1"
  local manifest
  manifest="$(aoc_omp_seed_root)/manifest.toml"
  if [[ -x "$script_dir/aoc-profile" ]]; then
    "$script_dir/aoc-profile" active --kind "$kind" --root "$project_root" --manifest "$manifest"
  elif command -v aoc-profile >/dev/null 2>&1; then
    aoc-profile active --kind "$kind" --root "$project_root" --manifest "$manifest"
  else
    read_omp_manifest_list "$kind"
  fi
}

load_omp_active_array() {
  local array_name="$1"
  local kind="$2"
  local tmp
  tmp="$(mktemp)"
  read_omp_active_list "$kind" > "$tmp"
  mapfile -t "$array_name" < "$tmp"
  rm -f "$tmp"
}

load_omp_manifest_array() {
  local array_name="$1"
  local kind="$2"
  local tmp
  tmp="$(mktemp)"
  read_omp_manifest_list "$kind" > "$tmp"
  mapfile -t "$array_name" < "$tmp"
  rm -f "$tmp"
}

array_contains() {
  local needle="$1"
  shift
  local item=""
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

positive_int_or_default() {
  local candidate="$1"
  local fallback="$2"
  if [[ "$candidate" =~ ^[0-9]+$ ]] && (( candidate > 0 )); then
    printf '%s' "$candidate"
  else
    printf '%s' "$fallback"
  fi
}

copy_tree_force() {
  local source_dir="$1"
  local target_dir="$2"
  python3 - "$source_dir" "$target_dir" <<'PY'
import shutil
import sys
from pathlib import Path

src = Path(sys.argv[1])
dst = Path(sys.argv[2])
if dst.exists():
    shutil.rmtree(dst)
dst.parent.mkdir(parents=True, exist_ok=True)
shutil.copytree(src, dst, dirs_exist_ok=True)
PY
}

managed_path_sha256() {
  local target_path="$1"
  python3 - "$target_path" <<'PY'
import hashlib
import sys
from pathlib import Path

path = Path(sys.argv[1])
if not path.exists():
    print("")
    raise SystemExit(0)

ignored = {".aoc-managed"}

def digest_file(p: Path) -> str:
    h = hashlib.sha256()
    with p.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

if path.is_file():
    print(digest_file(path))
    raise SystemExit(0)

h = hashlib.sha256()
for item in sorted(p for p in path.rglob("*") if p.is_file()):
    rel = item.relative_to(path).as_posix()
    if rel in ignored or rel.endswith(".aoc-managed") or "/.aoc-backups/" in f"/{rel}/":
        continue
    h.update(rel.encode("utf-8"))
    h.update(b"\0")
    h.update(digest_file(item).encode("ascii"))
    h.update(b"\n")
print(h.hexdigest())
PY
}

rel_to_project_root() {
  local target_path="$1"
  python3 - "$project_root" "$target_path" <<'PY'
import os
import sys
from pathlib import Path
root = Path(sys.argv[1]).resolve()
path = Path(sys.argv[2]).resolve()
try:
    print(path.relative_to(root).as_posix())
except ValueError:
    print(os.path.relpath(path, root).replace(os.sep, "/"))
PY
}

rel_to_source_root() {
  local target_path="$1"
  python3 - "$script_dir/.." "$target_path" <<'PY'
import os
import sys
from pathlib import Path
root = Path(sys.argv[1]).resolve()
path = Path(sys.argv[2]).resolve()
try:
    print(path.relative_to(root).as_posix())
except ValueError:
    print(os.path.relpath(path, root).replace(os.sep, "/"))
PY
}

write_aoc_managed_marker() {
  local target_path="$1"
  local asset_id="$2"
  local source_path="${3:-}"
  local checksum="${4:-}"
  local marker_path="$target_path/.aoc-managed"
  local source_label="agent-ops-cockpit"
  if [[ -n "$source_path" ]]; then
    source_label="$(rel_to_source_root "$source_path")"
  fi
  if [[ -z "$checksum" && -e "$target_path" ]]; then
    checksum="$(managed_path_sha256 "$target_path")"
  fi
  if [[ ! -d "$target_path" ]]; then
    marker_path="$target_path.aoc-managed"
    mkdir -p "$(dirname "$target_path")"
  fi
  cat > "$marker_path" <<EOF
aoc-managed: true
asset: $asset_id
asset-version: $AOC_PROJECT_LAYOUT_VERSION
source: $source_label
sha256: $checksum
updated-at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
}

is_aoc_managed_target() {
  local target_path="$1"
  [[ -f "$target_path/.aoc-managed" || -f "$target_path.aoc-managed" ]]
}

backup_unmarked_aoc_target() {
  local target_path="$1"
  local reason="$2"
  [[ -e "$target_path" ]] || return 0
  if is_aoc_managed_target "$target_path"; then return 0; fi
  local backup_root
  backup_root="$(dirname "$target_path")/.aoc-backups"
  mkdir -p "$backup_root"
  local backup_path="$backup_root/$(basename "$target_path").aoc-unmanaged-backup.$(date -u +%Y%m%dT%H%M%SZ)"
  mv "$target_path" "$backup_path"
  warn "Backed up unmarked AOC target before managed refresh ($reason): $backup_path"
}

manifest_sha_for_target() {
  local target_path="$1"
  [[ -f "$aoc_managed_assets_file" ]] || return 0
  local rel
  rel="$(rel_to_project_root "$target_path")"
  python3 - "$aoc_managed_assets_file" "$rel" <<'PY'
import json
import sys
from pathlib import Path
path = Path(sys.argv[1])
rel = sys.argv[2]
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)
entry = data.get("assets", {}).get(rel, {})
sha = entry.get("expectedSha256") or entry.get("sha256")
if isinstance(sha, str):
    print(sha)
PY
}

backup_dirty_managed_target() {
  local target_path="$1"
  local asset_id="$2"
  [[ -e "$target_path" ]] || return 0
  local backup_root
  backup_root="$(dirname "$target_path")/.aoc-backups"
  mkdir -p "$backup_root"
  local backup_path="$backup_root/$(basename "$target_path").aoc-dirty-backup.$(date -u +%Y%m%dT%H%M%SZ)"
  mv "$target_path" "$backup_path"
  warn "Backed up locally modified managed AOC target before refresh ($asset_id): $backup_path"
}

copy_tree_force_managed() {
  local source_dir="$1"
  local target_dir="$2"
  local asset_id="$3"
  local source_sha=""
  local target_sha=""
  local previous_sha=""

  source_sha="$(managed_path_sha256 "$source_dir")"

  if [[ -e "$target_dir" ]]; then
    if ! is_aoc_managed_target "$target_dir"; then
      backup_unmarked_aoc_target "$target_dir" "$asset_id"
    else
      target_sha="$(managed_path_sha256 "$target_dir")"
      previous_sha="$(manifest_sha_for_target "$target_dir" || true)"
      if [[ "$target_sha" == "$source_sha" ]]; then
        write_aoc_managed_marker "$target_dir" "$asset_id" "$source_dir" "$source_sha"
        return 0
      fi
      if [[ -z "$previous_sha" || "$target_sha" != "$previous_sha" ]]; then
        backup_dirty_managed_target "$target_dir" "$asset_id"
      fi
    fi
  fi

  copy_tree_force "$source_dir" "$target_dir"
  write_aoc_managed_marker "$target_dir" "$asset_id" "$source_dir" "$source_sha"
}

copy_file_force_managed() {
  local source_file="$1"
  local target_file="$2"
  local asset_id="$3"
  local source_sha=""
  local target_sha=""
  local previous_sha=""

  source_sha="$(managed_path_sha256 "$source_file")"

  if [[ -e "$target_file" ]]; then
    if ! is_aoc_managed_target "$target_file"; then
      if cmp -s "$source_file" "$target_file"; then
        write_aoc_managed_marker "$target_file" "$asset_id" "$source_file" "$source_sha"
        return 0
      fi
      backup_unmarked_aoc_target "$target_file" "$asset_id"
    else
      target_sha="$(managed_path_sha256 "$target_file")"
      previous_sha="$(manifest_sha_for_target "$target_file" || true)"
      if [[ "$target_sha" == "$source_sha" ]]; then
        write_aoc_managed_marker "$target_file" "$asset_id" "$source_file" "$source_sha"
        return 0
      fi
      if [[ -z "$previous_sha" || "$target_sha" != "$previous_sha" ]]; then
        backup_dirty_managed_target "$target_file" "$asset_id"
      fi
    fi
  fi

  mkdir -p "$(dirname "$target_file")"
  cp "$source_file" "$target_file"
  write_aoc_managed_marker "$target_file" "$asset_id" "$source_file" "$source_sha"
}

remove_pi_multi_auth_mutable_dirs() {
  local package_dir="$1"
  local debug_dir="$package_dir/debug"

  if [[ -d "$debug_dir" ]]; then
    rm -rf "$debug_dir"
  fi
}

copy_tree_missing_only() {
  local source_dir="$1"
  local target_dir="$2"
  python3 - "$source_dir" "$target_dir" <<'PY'
import shutil
import sys
from pathlib import Path

src = Path(sys.argv[1])
dst = Path(sys.argv[2])
if not src.is_dir():
    raise SystemExit(1)

dst.mkdir(parents=True, exist_ok=True)
for path in sorted(src.rglob('*')):
    rel = path.relative_to(src)
    target = dst / rel
    if path.is_dir():
        target.mkdir(parents=True, exist_ok=True)
        continue
    if target.exists():
        continue
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(path, target)
PY
}

directories_match() {
  local left_dir="$1"
  local right_dir="$2"
  python3 - "$left_dir" "$right_dir" <<'PY'
import hashlib
import sys
from pathlib import Path

left = Path(sys.argv[1])
right = Path(sys.argv[2])

if not left.is_dir() or not right.is_dir():
    raise SystemExit(1)


def digest_tree(root: Path):
    files = []
    for path in sorted(p for p in root.rglob('*') if p.is_file()):
        rel = path.relative_to(root).as_posix()
        h = hashlib.sha256(path.read_bytes()).hexdigest()
        files.append((rel, h))
    return files

raise SystemExit(0 if digest_tree(left) == digest_tree(right) else 1)
PY
}

get_project_mind_service_config_path() {
  printf '%s\n' "$aoc_dir/mind-service.json"
}

get_global_mind_service_config_path() {
  printf '%s\n' "$aoc_config_dir/mind-service.json"
}

read_project_aoc_version() {
  python3 - "$aoc_init_state_file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
if not path.exists():
    print(0)
    raise SystemExit(0)

try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print(0)
    raise SystemExit(0)

if not isinstance(data, dict):
    print(0)
    raise SystemExit(0)

value = data.get("projectAocVersion", data.get("version", 0))
print(value if isinstance(value, int) and value >= 0 else 0)
PY
}

note_project_migration() {
  local migration_id="$1"
  local message="$2"
  aoc_project_migrations_applied+=("$migration_id")
  log "$message"
}

prepare_project_aoc_state() {
  aoc_project_version_before="$(read_project_aoc_version)"
  aoc_project_version_after="$AOC_PROJECT_LAYOUT_VERSION"
}

apply_project_version_migrations() {
  if (( aoc_project_version_before > AOC_PROJECT_LAYOUT_VERSION )); then
    aoc_project_version_after="$aoc_project_version_before"
    warn "Project AOC version $aoc_project_version_before is newer than this aoc-init supports (current $AOC_PROJECT_LAYOUT_VERSION). Preserving newer version marker."
    return 0
  fi

  if (( aoc_project_version_before < 1 )); then
    note_project_migration \
      "v1-versioned-init-state" \
      "Applying AOC project migration v1: initialize versioned AOC project state."
  fi

  if (( aoc_project_version_before < 2 )); then
    note_project_migration \
      "v2-presets-runtime-seeding" \
      "Applying AOC project migration v2: seed reusable preset runtime and design preset assets."
  fi

  if (( aoc_project_version_before < 3 )); then
    note_project_migration \
      "v3-managed-asset-version-markers" \
      "Applying AOC project migration v3: mark managed skills, presets, and OMP assets for safe updates."
  fi
}

write_project_aoc_state() {
  local joined_migrations=""
  local migration=""

  for migration in "${aoc_project_migrations_applied[@]:-}"; do
    if [[ -n "$migration" ]]; then
      if [[ -n "$joined_migrations" ]]; then
        joined_migrations+=$'\n'
      fi
      joined_migrations+="$migration"
    fi
  done

  python3 - "$aoc_init_state_file" "$aoc_project_version_before" "$aoc_project_version_after" "$AOC_INIT_STATE_SCHEMA_VERSION" "$script_dir" "$joined_migrations" <<'PY'
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

state_path = Path(sys.argv[1])
previous_version = int(sys.argv[2])
project_version = int(sys.argv[3])
schema_version = int(sys.argv[4])
script_dir = sys.argv[5]
migrations_raw = sys.argv[6]
migrations = [line for line in migrations_raw.splitlines() if line]

state_path.parent.mkdir(parents=True, exist_ok=True)
payload = {
    "schemaVersion": schema_version,
    "projectAocVersion": project_version,
    "previousProjectAocVersion": previous_version,
    "lastInitializedAt": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    "lastInitScriptDir": script_dir,
    "runtime": {"canonical": "omp"},
    "migrationsApplied": migrations,
}
state_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
PY
}

refresh_aoc_managed_manifest() {
  mkdir -p "$aoc_dir"
  python3 - "$project_root" "$aoc_managed_assets_file" "$AOC_PROJECT_LAYOUT_VERSION" <<'PY'
import hashlib
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

root = Path(sys.argv[1]).resolve()
manifest_path = Path(sys.argv[2])
asset_version = int(sys.argv[3])


def parse_marker(path: Path) -> dict:
    data = {}
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except Exception:
        return data
    for line in lines:
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        data[key.strip()] = value.strip()
    return data


def file_sha(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def path_sha(path: Path) -> str:
    if not path.exists():
        return ""
    if path.is_file():
        return file_sha(path)
    h = hashlib.sha256()
    for item in sorted(p for p in path.rglob("*") if p.is_file()):
        rel = item.relative_to(path).as_posix()
        if rel == ".aoc-managed" or rel.endswith(".aoc-managed") or "/.aoc-backups/" in f"/{rel}/":
            continue
        h.update(rel.encode("utf-8"))
        h.update(b"\0")
        h.update(file_sha(item).encode("ascii"))
        h.update(b"\n")
    return h.hexdigest()

assets = {}
for marker in sorted(root.rglob(".aoc-managed")):
    target = marker.parent
    if "/.aoc-backups/" in f"/{marker.relative_to(root).as_posix()}/":
        continue
    info = parse_marker(marker)
    rel = target.relative_to(root).as_posix()
    expected = info.get("sha256", "")
    actual = path_sha(target)
    status = "current" if expected and actual == expected else ("dirty" if expected else "unknown")
    assets[rel] = {
        "asset": info.get("asset", rel),
        "assetVersion": int(info.get("asset-version", asset_version) or asset_version),
        "source": info.get("source", "agent-ops-cockpit"),
        "sha256": actual,
        "expectedSha256": expected,
        "status": status,
        "marker": marker.relative_to(root).as_posix(),
    }

for marker in sorted(root.rglob("*.aoc-managed")):
    if marker.name == ".aoc-managed" or "/.aoc-backups/" in f"/{marker.relative_to(root).as_posix()}/":
        continue
    target = marker.with_name(marker.name[: -len(".aoc-managed")])
    if not target.exists():
        continue
    info = parse_marker(marker)
    rel = target.relative_to(root).as_posix()
    expected = info.get("sha256", "")
    actual = path_sha(target)
    status = "current" if expected and actual == expected else ("dirty" if expected else "unknown")
    assets[rel] = {
        "asset": info.get("asset", rel),
        "assetVersion": int(info.get("asset-version", asset_version) or asset_version),
        "source": info.get("source", "agent-ops-cockpit"),
        "sha256": actual,
        "expectedSha256": expected,
        "status": status,
        "marker": marker.relative_to(root).as_posix(),
    }

counts = {"current": 0, "dirty": 0, "unknown": 0, "stale": 0}
for entry in assets.values():
    counts[entry["status"]] = counts.get(entry["status"], 0) + 1

payload = {
    "schemaVersion": 1,
    "aocAssetVersion": asset_version,
    "updatedAt": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    "counts": counts,
    "assets": assets,
}
manifest_path.parent.mkdir(parents=True, exist_ok=True)
manifest_path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

managed_manifest_summary() {
  [[ -f "$aoc_managed_assets_file" ]] || return 0
  python3 - "$aoc_managed_assets_file" <<'PY'
import json
import sys
from pathlib import Path
path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)
counts = data.get("counts", {})
print(f"  managed_assets_manifest: present")
print(f"  managed_assets_current: {counts.get('current', 0)}")
print(f"  managed_assets_dirty: {counts.get('dirty', 0)}")
print(f"  managed_assets_unknown: {counts.get('unknown', 0)}")
PY
}

aoc_vcs_status_line() {
  python3 - "$project_root" <<'PY'
import subprocess
import sys
from pathlib import Path

root = Path(sys.argv[1])
git_present = (root / ".git").exists()
if git_present:
    print("git")
else:
    print("none")
PY
}

aoc_vcs_context_lines() {
  python3 - "$project_root" <<'PY'
import subprocess
import sys
from pathlib import Path

root = Path(sys.argv[1])
git_present = (root / ".git").exists()

def run(cmd):
    try:
        proc = subprocess.run(cmd, cwd=str(root), text=True, capture_output=True, timeout=3)
    except Exception:
        return None
    if proc.returncode != 0:
        return None
    text = proc.stdout.strip()
    return text.splitlines()[0] if text else None

git_branch = None
if git_present:
    git_branch = run(["git", "branch", "--show-current"]) or run(["git", "rev-parse", "--short", "HEAD"]) or "unknown"

vcs = "git" if git_present else "none"

print(f"- VCS: {vcs}")
if git_branch:
    print(f"- Git branch: {git_branch}")
PY
}


print_project_aoc_status() {
  local current_version="0"
  local state_path="$aoc_init_state_file"
  local has_context="no"
  local has_memory="no"
  local has_stm="no"
  local has_rtk="no"
  local has_omp_extensions="no"
  local has_omp_agents="no"
  local has_omp_skills="no"
  local migration_lines=""

  current_version="$(read_project_aoc_version)"

  if [[ -f "$project_root/.aoc/context.md" ]]; then has_context="yes"; fi
  if [[ -f "$project_root/.aoc/memory.md" ]]; then has_memory="yes"; fi
  if [[ -f "$project_root/.aoc/stm/current.md" ]]; then has_stm="yes"; fi
  if [[ -f "$project_root/.aoc/rtk.toml" ]]; then has_rtk="yes"; fi
  if [[ -d "$project_root/.omp/extensions" ]]; then has_omp_extensions="yes"; fi
  if [[ -d "$project_root/.omp/agents" ]]; then has_omp_agents="yes"; fi
  if [[ -d "$project_root/.omp/skills" ]]; then has_omp_skills="yes"; fi

  migration_lines="$(python3 - "$state_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
if not path.exists():
    raise SystemExit(0)
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(0)
for item in data.get('migrationsApplied', []):
    if isinstance(item, str) and item.strip():
        print(item)
PY
)"

  printf '%s
' "AOC Init Status"
  printf '%s
' "  project_root: $project_root"
  printf '%s
' "  vcs: $(aoc_vcs_status_line)"
  printf '%s
' "  target_project_aoc_version: $AOC_PROJECT_LAYOUT_VERSION"
  printf '%s
' "  project_aoc_version: $current_version"
  printf '%s
' "  init_state: $([[ -f "$state_path" ]] && echo present || echo missing)"
  printf '%s
' "  aoc_context: $has_context"
  printf '%s
' "  aoc_memory: $has_memory"
  printf '%s
' "  aoc_stm: $has_stm"
  printf '%s
' "  aoc_rtk: $has_rtk"
  printf '%s
' "  omp_extensions: $has_omp_extensions"
  printf '%s
' "  omp_agents: $has_omp_agents"
  printf '%s
' "  omp_skills: $has_omp_skills"
  printf '%s
' "  design_contract: $([[ -f "$project_root/DESIGN.md" ]] && echo present || echo missing)"
  managed_manifest_summary
  if [[ -n "$migration_lines" ]]; then
    printf '%s
' "  migrations_applied:"
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      printf '%s
' "    - $line"
    done <<< "$migration_lines"
  fi
}

write_aoc_agents_contract() {
  local target_file="$1"
  cat <<'EOF' > "$target_file"
# AOC Architecture & Agent Guidelines

This file defines the always-on rules for agents in this repo. Procedural playbooks live in AOC skills.

## Always-on rules
- Use `.aoc/context.md` for orientation; run `aoc-init` if it is missing or stale.
- Use root `DESIGN.md` as the visual/product design contract before UI, docs-site, marketing, HyperFrames, or other product-facing work.
- **DO NOT manually read these files** - use the Bash tool to run CLI commands instead (see below).
- Run AOC commands via Bash tool - do NOT use Read tool for `.aoc/memory.md`, `.aoc/stm/current.md`, or `.taskmaster/tasks/tasks.json`.
- RTK routing is default-on for new AOC projects (`.aoc/rtk.toml` mode=`on`); existing explicit mode=`off` is preserved.
- RTK exists to improve context health: allowlisted noisy commands are condensed for better signal density, with fail-open native fallback.

## Startup handshake
- `aoc-handshake --json` is the metadata-only startup packet for agents: AOC status, Taskmaster tag, Mind availability, Git repository state, and usage policy.
- Startup must not load broad Mind memories or context packs by default; use the handshake to discover Mind, not to prime direction.
- Mind may sync/ingest in the background, but retrieval should be lazy and intent-bound.
- Request focused Mind context only after user intent is known, for resume/continuation, prior decisions, task/spec grounding, debugging previous attempts, provenance/audit, or when targeted local inspection is insufficient.
- Always pass an explicit reason when requesting Mind context; prefer focused/provenance/resume modes over broad recall.

## Low-Token Default Mode
- Keep responses concise by default; do not print full files or raw logs unless explicitly requested.
- Start with the smallest viable step; use narrow, path-scoped searches before broad scans.
- When `.codegraph/` exists and the OMP `aoc_codegraph` tool is available, use it before broad text/file scans for code discovery, call-flow mapping, impact probes, and affected-test selection.
- Read files in bounded chunks and avoid rereading unchanged large files.
- Summarize command/tool output with actionable lines only (key errors, next actions).
- Run targeted checks/tests first; run full-suite commands only when required.
- If targeted inspection fails, escalate scope gradually and state why.
- Use fresh sessions after major milestones or context drift to reduce replay overhead.
- For narrow diagnostics/Q&A, use at most 3 tool calls before first answer; ask before broader escalation.
- Do not open/read image binaries unless the user explicitly asks to view/open one now.
- Use one narrow diagnostic path first; avoid retry spray with variant commands unless first attempt fails.

## Lightweight Validation
- Prefer OMP `lsp diagnostics` on touched files/globs for edit-loop validation before running build, lint, or typecheck commands.
- Use `lsp references` before changing exported symbols, and `lsp code_actions` for language-server fixes/imports when available.
- Do not run full project build/lint/test as a routine sanity check during active edits.
- In delegated multi-agent work, subagents should skip project-wide validation unless explicitly assigned.
- Final verification is still required; choose the smallest targeted command that proves the changed behavior.

## AOC CLI Commands (run via Bash tool - NOT Read tool)
These commands are in PATH and work without loading any skill:
- Startup/repair: `aoc-handshake --json`, `aoc-init`
- Memory: `aoc-mem read`, `aoc-mem search "query"`, `aoc-mem add "decision"`
- STM directed handoff only: `aoc-stm status`, `aoc-stm template --purpose <kind>`, `aoc-stm`, `aoc-stm add "note"`, `aoc-stm handoff --purpose <kind> --to <recipient> --focus <focus>`, `aoc-stm resume <archive>`
- Tasks: `tm tag current`, `tm tag spec show`, `aoc-task tag spec show --tag <tag>`, `aoc-task spec show <id> --tag <tag>`
- RTK: `aoc-rtk status`, `aoc-rtk doctor`, `aoc-rtk install --auto`, `aoc-rtk enable|disable`
- VCS: inspect detected mode with `aoc-handshake --json`; use `git status`/`git diff` in Git repositories.

STM is for deliberate directed in-progress handoff packets only; it is not a mailbox and does not notify another agent by itself. Pass the printed next-agent brief or exact archive explicitly. In Pi, `/handoff <focus>` asks the agent to generate a clean purpose-matched packet for the current work; `/rresume [archive]` asks the agent to load a sealed handoff into context safely. Do not use STM for durable decisions, generic logs, raw command output, or every minor task.

## Core files
- `.aoc/context.md`: auto-generated project snapshot.
- `.aoc/rtk.toml`: project-local RTK routing policy and install contract.
- `.aoc/mind-service.json`: optional project-local launcher metadata for the standalone Mind service.
- `.aoc/layouts/`: legacy-only Zellij layouts, created only when `AOC_INIT_LEGACY_ZELLIJ=1`.
- `DESIGN.md`: project-wide visual/product design contract; subsystem design docs extend it.
- `.taskmaster/docs/specs/`: spec documents linked to tags and tasks; `.taskmaster/docs/prds/` remains legacy-compatible.
- Tag default specs are currently stored via legacy key `aocPrd`; resolve with `aoc-task tag spec show --tag <tag>`.
- Task spec overrides are currently stored via legacy key `aocPrd`; resolve with `aoc-task spec show <id> --tag <tag>`.
- Effective precedence is task spec override -> tag default spec.
- Keep task specs in git: `.taskmaster/docs/specs/**` and legacy `.taskmaster/docs/prds/**` should always be tracked.
- Keep AOC/task/config/source state in git: `.aoc/**`, `.taskmaster/**`, `.omp/extensions/**`, `.omp/agents/**`, `.omp/skills/**`, `AGENTS.md`, and `DESIGN.md` should not be ignored except explicit high-churn runtime artifacts such as logs, locks, caches, debug output, and live Mind databases.

## Task Management
- `.taskmaster/tasks/tasks.json` is task state; use the Taskmaster TUI, `aoc-task`, or `tm` (alias for `aoc-task`). Do not edit the file directly.
- Record major decisions and constraints in memory (`aoc-mem add "..."`).

## Skills (load when needed)
Load a skill only when its description matches the user request. Keep always-on guidance here minimal; procedural playbooks belong in skill files.

Note: `aoc-mem`, `aoc-stm`, and `tm` are basic CLI commands (see above) - no skill needed.
EOF
}

