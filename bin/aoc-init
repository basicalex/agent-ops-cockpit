}

read_rtk_mode() {
  local rtk_file="$1"
  if ! command -v python3 >/dev/null 2>&1; then
    return
  fi

  python3 - "$rtk_file" <<'PY'
import sys
from pathlib import Path

try:
    import tomllib
except Exception:
    tomllib = None

path = Path(sys.argv[1])
if tomllib is None or not path.exists():
    raise SystemExit(0)

mode = ""
try:
    data = tomllib.loads(path.read_text(encoding="utf-8"))
    mode = str(data.get("mode", "")).strip().lower()
except Exception:
    mode = ""

if mode in {"on", "off"}:
    print(mode)
PY
}

ensure_rtk_config() {
  local rtk_file="$aoc_dir/rtk.toml"
  if [[ ! -f "$rtk_file" ]]; then
    write_default_rtk_config "$rtk_file"
    log "Seeded RTK routing config ($rtk_file, mode=on default)."
  else
    local existing_mode=""
    existing_mode="$(read_rtk_mode "$rtk_file" || true)"
    if [[ "$existing_mode" == "off" ]]; then
      log "RTK routing config exists with mode=off ($rtk_file). Preserving explicit disable."
    elif [[ "$existing_mode" == "on" ]]; then
      log "RTK routing config exists with mode=on ($rtk_file). Preserving."
    else
      log "RTK routing config exists ($rtk_file). Preserving."
    fi
  fi
}

ensure_git_tracking_policy() {
  local ignore_file="$project_root/.gitignore"
  local changed=0
  local line=""

  if [[ ! -f "$ignore_file" ]]; then
    log "Creating .gitignore..."
    : > "$ignore_file"
  fi

  if [[ -s "$ignore_file" ]]; then
    local last_char=""
    last_char="$(tail -c 1 "$ignore_file" 2>/dev/null || true)"
    if [[ "$last_char" != $'\n' ]]; then
      printf '\n' >> "$ignore_file"
    fi
  fi

  local rules=(
    "# AOC tracking policy (managed by aoc-init)"
    "!/.aoc/"
    "!/.aoc/**"
    "!/.taskmaster/"
    "!/.taskmaster/**"
    "!/.pi/"
    "!/.pi/**"
  )

  for line in "${rules[@]}"; do
    if ! grep -Fqx "$line" "$ignore_file"; then
      printf '%s\n' "$line" >> "$ignore_file"
      changed=1
    fi
  done

  if [[ "$changed" == "1" ]]; then
    log "Updated .gitignore to keep .aoc/, .taskmaster/, and .pi/ tracked."
  else
    log ".gitignore already keeps .aoc/, .taskmaster/, and .pi/ tracked."
  fi
}

# 1. Setup Context & Memory (.aoc/)
setup_memory() {
  # Migration Logic
  if [[ -d "$gemini_dir" && ! -d "$aoc_dir" ]]; then
    log "Migrating .gemini/ to .aoc/..."
    mv "$gemini_dir" "$aoc_dir"
    if [[ -f "$aoc_dir/GEMINI.md" ]]; then
      mv "$aoc_dir/GEMINI.md" "$aoc_dir/context.md"
    fi
  fi

  if [[ ! -d "$aoc_dir" ]]; then
    log "Creating .aoc/ directory..."
    mkdir -p "$aoc_dir"
  fi

  # Memory File
  local mem_file="$aoc_dir/memory.md"
  if [[ ! -f "$mem_file" ]]; then
    log "Initializing empty memory ($mem_file)..."
    cat <<EOF > "$mem_file"
# Agent Memory for Project: $(basename "$project_root")
This file contains persistent context, decisions, and knowledge for the AI agent.
Agents should read this to understand project history and append new decisions here.

## Core Decisions
EOF
  else
    log "Memory file exists ($mem_file). Skipping."
  fi

  # Project lexicon template
  local lexicon_file="$aoc_dir/lexicon.md"
  if [[ ! -f "$lexicon_file" ]]; then
    log "Seeding project lexicon template ($lexicon_file)..."
    cat <<EOF > "$lexicon_file"
# Project Lexicon

Canonical human-agent project language for this repository.

Use this file as a semantic consistency layer, not a requirements source or memory dump. Keep entries concise. Add only grounded project-specific terms, aliases, conflicts, or relationships that improve future agent work.

## Governance

Agents may update this file only for high-confidence, low-risk terminology changes. Propose instead of editing when a term is ambiguous, broad, political, disruptive, or conflicts with existing usage.

Authority order for implementation work:
1. Explicit current user instruction.
2. Active spec / PRD / task acceptance criteria.
3. Current repo behavior.
4. Existing project lexicon.
5. Existing memory.
6. Agent inference.

## Entry format

\`\`\`md
### Canonical Term

Definition: Concise definition.
Aliases: accepted alternate terms, if any.
Avoid: confusing or deprecated terms, if any.
Relationships: related commands, artifacts, workflows, states, owners, or lifecycle notes.
Evidence: path, command, task, spec, or implemented behavior that grounds the entry.
\`\`\`

## Core terms
EOF
  else
    log "Project lexicon exists ($lexicon_file). Preserving."
  fi

  # Short-term memory workspace
  local stm_dir="$aoc_dir/stm"
  local stm_current="$stm_dir/current.md"
  local stm_archive="$stm_dir/archive"
  mkdir -p "$stm_archive"
  if [[ ! -f "$stm_current" ]]; then
    log "Initializing short-term memory ($stm_current)..."
    : > "$stm_current"
  else
    log "Short-term memory exists ($stm_current). Preserving."
  fi

  # Shared project layouts
  local layouts_dir="$aoc_dir/layouts"
  if [[ ! -d "$layouts_dir" ]]; then
    log "Creating shared layouts directory ($layouts_dir)..."
    mkdir -p "$layouts_dir"
  fi

  # AGENTS.md (project-level agent contract)
  local agents_file="$project_root/AGENTS.md"
  ensure_agents_contract "$agents_file"

  # DESIGN.md (project-level visual/product design contract)
  local design_file="$project_root/DESIGN.md"
  if [[ ! -f "$design_file" ]]; then
    log "Seeding root design contract (DESIGN.md)..."
    write_root_design_contract "$design_file"
  else
    log "Root design contract exists (DESIGN.md). Preserving."
  fi

  ensure_rtk_config

  # PI default prompt contract
  local prompts_dir="$aoc_dir/prompts"
  local pi_low_token_prompt="$prompts_dir/pi-low-token.md"
  if [[ ! -d "$prompts_dir" ]]; then
    log "Creating prompts directory ($prompts_dir)..."
    mkdir -p "$prompts_dir"
  fi
  if [[ ! -f "$pi_low_token_prompt" ]]; then
    log "Seeding PI low-token prompt ($pi_low_token_prompt)..."
    write_pi_low_token_prompt "$pi_low_token_prompt"
  else
    log "PI low-token prompt exists ($pi_low_token_prompt). Preserving."
  fi

  # Context Generation (project-specific, concise, full injection safe)
  local context_file="$aoc_dir/context.md"
  local context_tmp
  local context_line_budget
  local context_tree_depth
  local context_tree_line_budget
  local readme_heading_limit
  local project_name
  local current_branch="unknown"
  local tree_output=""
  local tree_lines=0
  local context_lines=0
  local readme_headings=""

  project_name="$(basename "$project_root")"
  context_tmp="$(mktemp)"
  context_line_budget="$(positive_int_or_default "${AOC_CONTEXT_LINE_BUDGET:-320}" 320)"
  context_tree_depth="$(positive_int_or_default "${AOC_CONTEXT_TREE_DEPTH:-2}" 2)"
  context_tree_line_budget="$(positive_int_or_default "${AOC_CONTEXT_TREE_LINE_BUDGET:-40}" 40)"
  readme_heading_limit="$(positive_int_or_default "${AOC_CONTEXT_README_HEADING_LIMIT:-40}" 40)"

  if command -v git >/dev/null 2>&1 && git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    current_branch="$(git -C "$project_root" branch --show-current 2>/dev/null || true)"
    if [[ -z "$current_branch" ]]; then
      current_branch="$(git -C "$project_root" rev-parse --short HEAD 2>/dev/null || echo "detached")"
    fi
  fi

  if command -v tree >/dev/null 2>&1; then
    tree_output="$(tree -L "$context_tree_depth" --gitignore -I '.git|.taskmaster|.aoc|.gemini|node_modules|target|dist|archive|deprecated|.venv|venv|__pycache__' "$project_root" 2>/dev/null || true)"
  else
    tree_output="$(cd "$project_root" && find . -maxdepth "$context_tree_depth" \( -path './.git' -o -path './.taskmaster' -o -path './.aoc' -o -path './.gemini' -o -path './node_modules' -o -path './target' -o -path './dist' -o -path './archive' -o -path './deprecated' -o -path './.venv' -o -path './venv' -o -path './__pycache__' \) -prune -o -print 2>/dev/null | sort || true)"
  fi
  tree_lines="$(printf '%s\n' "$tree_output" | wc -l | tr -d ' ')"

  if [[ -f "$project_root/README.md" ]]; then
    readme_headings="$(grep -E '^#{1,6} ' "$project_root/README.md" | head -n "$readme_heading_limit" || true)"
  fi

  log "Generating/Updating Context ($context_file)..."

  {
    echo "# Project Context Snapshot"
    echo
    echo "## Repository"
    echo "- Name: $project_name"
    echo "- Root: $project_root"
    echo "- Git branch: $current_branch"

    echo
    echo "## Key Files"
    local found_key_file=0
    local key_file
    for key_file in \
      "README.md" \
      "DESIGN.md" \
      "Makefile" \
      "justfile" \
      "package.json" \
      "pnpm-lock.yaml" \
      "yarn.lock" \
      "bun.lockb" \
      "Cargo.toml" \
      "go.mod" \
      "pyproject.toml" \
      "requirements.txt" \
      "Dockerfile" \
      "docker-compose.yml" \
      "docker-compose.yaml"; do
      if [[ -f "$project_root/$key_file" ]]; then
        echo "- $key_file"
        found_key_file=1
      fi
    done
    if [[ "$found_key_file" == "0" ]]; then
      echo "- No common manifest files detected."
    fi

    echo
    echo "## Project Structure (tree -L $context_tree_depth)"
    echo '```'
    if [[ -n "$tree_output" ]]; then
      if (( tree_lines > context_tree_line_budget )); then
        printf '%s\n' "$tree_output" | head -n "$context_tree_line_budget"
        echo "... [tree truncated to ${context_tree_line_budget} lines]"
      else
        printf '%s\n' "$tree_output"
      fi
    else
      echo "No project structure entries detected."
    fi
    echo '```'

    if [[ -n "$readme_headings" ]]; then
      echo
      echo "## README Headings"
      printf '%s\n' "$readme_headings"
    fi

    echo
    echo "## Design Contract"
    if [[ -f "$project_root/DESIGN.md" ]]; then
      echo "- Root DESIGN.md: present"
      echo "- Use as visual/product design source before product-facing UI, docs-site, marketing, or media changes."
    else
      echo "- Root DESIGN.md: missing (run aoc-init to seed)"
    fi

    echo
    echo "## Current Task Tag"
    echo '```'
    if command -v tm >/dev/null 2>&1; then
      (cd "$project_root" && tm tag current 2>/dev/null || echo "unknown")
    elif command -v aoc-task >/dev/null 2>&1; then
      (cd "$project_root" && aoc-task tag current 2>/dev/null || echo "unknown")
    elif command -v aoc-cli >/dev/null 2>&1; then
      (cd "$project_root" && aoc-cli task tag current 2>/dev/null || echo "unknown")
    elif command -v task-master >/dev/null 2>&1; then
      echo "task-master does not expose current tag"
    else
      echo "Task command not found."
    fi
    echo '```'

    echo
    echo "## Active Workstreams (Tags)"
    echo '```'
    if command -v tm >/dev/null 2>&1; then
      (cd "$project_root" && tm tag list 2>/dev/null || echo "No tags found.")
    elif command -v aoc-task >/dev/null 2>&1; then
      (cd "$project_root" && aoc-task tag list 2>/dev/null || echo "No tags found.")
    elif command -v aoc-cli >/dev/null 2>&1; then
      (cd "$project_root" && aoc-cli task tag list 2>/dev/null || echo "No tags found.")
    elif command -v task-master >/dev/null 2>&1; then
      (cd "$project_root" && task-master tags 2>/dev/null || echo "No tags found.")
    else
      echo "Task command not found."
    fi
    echo '```'

    echo
    echo "## Task spec Location"
    echo "- Directory: .taskmaster/docs/specs"
    echo "- Resolve tag spec default with: aoc-task tag spec show --tag <tag>"
    echo "- Resolve task spec override with: aoc-task spec show <id> --tag <tag>"
    echo "- Effective precedence: task spec override -> tag spec default"
  } > "$context_tmp"

  context_lines="$(wc -l < "$context_tmp" | tr -d ' ')"
  if (( context_lines > context_line_budget )); then
    {
      head -n "$context_line_budget" "$context_tmp"
      echo
      echo "... [context capped at ${context_line_budget} lines; adjust AOC_CONTEXT_LINE_BUDGET if needed]"
    } > "$context_file"
    rm -f "$context_tmp"
    log "Context exceeded budget (${context_lines} lines); wrote capped context (${context_line_budget} lines)."
  else
    mv "$context_tmp" "$context_file"
  fi

}

# 1b. Setup skill sync (PI-first)
setup_skills() {
  local pi_skills_dir="$project_root/.pi/skills"
  local legacy_target=""
  local legacy_targets=(
    "$project_root/.codex/skills"
    "$project_root/.claude/skills"
    "$project_root/.opencode/skills"
    "$project_root/.agents/skills"
  )

  upgrade_stm_skill_guidance "$pi_skills_dir"

  if [[ -x "$script_dir/aoc-skill" ]]; then
    log "Ensuring PI skill baseline (.pi/skills)..."
    (cd "$project_root" && "$script_dir/aoc-skill" sync --agent pi --root "$project_root" || true)
  elif command -v aoc-skill >/dev/null 2>&1; then
    log "Ensuring PI skill baseline (.pi/skills)..."
    (cd "$project_root" && aoc-skill sync --agent pi --root "$project_root" || true)
  else
    warn "aoc-skill not found; .pi/skills baseline may be incomplete."
  fi

  for legacy_target in "${legacy_targets[@]}"; do
    if [[ -d "$legacy_target" ]]; then
      warn "Legacy non-PI skill target detected ($legacy_target); aoc-init no longer syncs it automatically in PI-first mode."
    fi
  done
}

upgrade_stm_skill_guidance() {
  local skills_dir="$1"
  local stm_skill="$skills_dir/stm-ops/SKILL.md"
  local memory_skill="$skills_dir/memory-ops/SKILL.md"
  local workflow_skill="$skills_dir/aoc-workflow/SKILL.md"
  local init_ops_skill="$skills_dir/aoc-init-ops/SKILL.md"

  if [[ -f "$stm_skill" ]] && (
    grep -Fq 'aoc-stm --last' "$stm_skill" ||
    grep -Fq 'aoc-stm use <archive>' "$stm_skill" ||
    grep -Fq 'fresh tab/session' "$stm_skill" ||
    grep -Fq 'aoc-stm handoff` (read current draft, fallback to latest archive)' "$stm_skill" ||
    ! grep -Fq 'template --purpose' "$stm_skill"
  ); then
    cat <<'EOF' > "$stm_skill"
---
name: stm-ops
description: Capture deliberate in-progress agent/session handoff packets with aoc-stm.
---

## When to use
- Another agent/session needs to continue in-progress work.
- Multiple agents may touch nearby files and need coordination context.
- Context window is getting tight and work is incomplete.
- Switching from builder to reviewer/tester/documenter.

## Do not use STM for
- Durable decisions or project conventions; use `aoc-mem add`.
- Generic progress logs, raw command output, or every minor task.
- Information already captured cleanly in Taskmaster, specs, commits, or Mind.

## Commands
- `aoc-stm status`
- `aoc-stm template --purpose <continue|review|test|debug|docs|commit>`
- `aoc-stm add "<note>"`
- `aoc-stm edit`
- `aoc-stm` (default read current handoff draft)
- `aoc-stm read-current`
- `aoc-stm handoff --purpose <kind> --to <recipient> --focus <focus>` (archive current draft and print directed packet)
- `aoc-stm resume <archive>` (read a specific archived handoff packet)
- `aoc-stm archive`
- `aoc-stm read <archive>`
- `aoc-stm history`

## Handoff format (recommended)
Use `aoc-stm template --purpose <kind>` and keep packets concise. Pick a purpose so the packet matches the next session:
- `continue`: current status, touched areas, validation, next safe actions
- `review`: review target, intended behavior, known risks, review questions
- `test`: behavior under test, commands, fixtures, suspected gaps
- `debug`: symptom, evidence, hypotheses tried, next diagnostics
- `docs`: user-facing behavior, examples, caveats
- `commit`: files changed, rationale, validation, task/spec refs

## Guardrails
- Keep STM as a short-lived handoff draft, then seal clean checkpoints with directed `aoc-stm handoff`.
- STM is not a mailbox and does not notify another agent; pass the printed next-agent brief or exact archive explicitly.
- Prefer a specific archive on resume; do not blindly trust latest if stale warnings appear.
- Promote durable decisions to `aoc-mem add`, not STM.
- Do not edit `tasks.json` directly while preparing handoff state.
EOF
    log "Updated stm-ops skill with draft-seal-resume STM guidance."
  fi

  if [[ -f "$memory_skill" ]] && (
    grep -Fq 'aoc-stm handoff` (read current draft, fallback to latest archive)' "$memory_skill" ||
    ! grep -Fq 'template --purpose' "$memory_skill"
  ); then
    cat <<'EOF' > "$memory_skill"
---
name: memory-ops
description: Use aoc-mem to read, search, and record project decisions.
---

## Commands
- `aoc-mem read`
- `aoc-mem search "<term>"`
- `aoc-mem add "<decision>"`
- `aoc-stm status`
- `aoc-stm template --purpose <kind>`
- `aoc-stm add "<handoff note>"`
- `aoc-stm edit`
- `aoc-stm` (read current handoff draft)
- `aoc-stm handoff --purpose <kind> --to <recipient> --focus <focus>` (archive current draft and print directed packet)
- `aoc-stm resume <archive>` (read a specific archived handoff packet)
- `aoc-stm archive`
- `aoc-stm read <archive>`
- `aoc-stm history`

## Recording guidelines
- Capture the "why" behind decisions.
- Keep entries short and scoped.
- Record one decision per line.

## Guardrail
- Never edit `.aoc/memory.md` directly.
- Keep `.aoc/stm/current.md` as a short-lived in-progress handoff draft only; archive deliberate directed handoff packets with `aoc-stm handoff --purpose <kind> --to <recipient> --focus <focus>`, pass the printed brief/archive explicitly, and promote durable decisions to `aoc-mem`.
EOF
    log "Updated memory-ops skill with STM command guidance."
  fi

  if [[ -f "$workflow_skill" ]] && (
    grep -Fq 'aoc task list' "$workflow_skill" ||
    grep -Fq 'aoc task add' "$workflow_skill" ||
    grep -Fq 'aoc task status' "$workflow_skill" ||
    grep -Fq 'review current draft with `aoc-stm`' "$workflow_skill" ||
    ! grep -Fq 'aoc-stm resume' "$workflow_skill"
  ); then
    cat <<'EOF' > "$workflow_skill"
---
name: aoc-workflow
description: Standard AOC workflow using context, memory, and tasks.
---

## When to use
Use this when you start a new task or need to re-orient inside a project.

## Steps
1. If AOC files are missing or stale, run `aoc-init` from the project root.
2. Read memory: `aoc-mem read` and `aoc-mem search "<topic>"` as needed.
3. Resolve active tag at session start with `tm tag current` (or `aoc-task tag current`).
4. Review tasks: `tm list`, `aoc-task list`, or the Taskmaster TUI.
5. Check spec linkage for scope and task:
   - Tag default: `aoc-task tag spec show --tag <tag>`
   - Task override: `aoc-task spec show <id> --tag <tag>`
6. Plan: add or refine tasks with `aoc-task add "<task>"` and set status.
7. Execute changes and run tests.
8. If context gets tight or another agent/session needs to continue, capture state (`aoc-stm template --purpose <kind>`, `aoc-stm add/edit`), seal a directed checkpoint with `aoc-stm handoff --purpose <kind> --to <recipient> --focus <focus>`, and pass the printed next-agent brief or exact archive to the next session for `aoc-stm resume <archive>`.
9. Update tasks and record decisions: `aoc-task status <id> done`, `aoc-mem add "<decision>"`.

## Guardrails
- Do not edit `.aoc/memory.md` directly.
- Do not keep long-term decisions in `.aoc/stm/current.md`; promote durable decisions to `aoc-mem`.
- Do not edit `.taskmaster/tasks/tasks.json` directly.
- Do not add spec links to subtasks.
- Use tag-level spec defaults with task-level overrides (`aocPrd`), with precedence task -> tag.
EOF
    log "Updated aoc-workflow skill with draft-seal-resume STM guidance."
  fi

  if [[ -f "$init_ops_skill" ]] && (
    ! grep -Fq '.aoc/stm/current.md' "$init_ops_skill" ||
    ! grep -Fq '.pi/prompts/' "$init_ops_skill" ||
    ! grep -Fq '/tm-cc' "$init_ops_skill" ||
    ! grep -Fq 'aoc-stm handoff' "$init_ops_skill" ||
    ! grep -Fq 'aoc-stm resume' "$init_ops_skill" ||
    ! grep -Fq '.pi/extensions/' "$init_ops_skill" ||
    grep -Fq 'Syncs skills for existing agent targets' "$init_ops_skill"
  ); then
    cat <<'EOF' > "$init_ops_skill"
---
name: aoc-init-ops
description: Initialize or repair AOC context, memory, and tasks safely.
---

## When to use
- New repository setup
- Missing `.aoc/` or `.taskmaster/`
- Stale or inconsistent context

## Run
- `aoc-init`
- To skip Rust builds: `AOC_INIT_SKIP_BUILD=1 aoc-init`

## What it does
- Creates `.aoc/` and `.taskmaster/` if missing
- Generates `.aoc/context.md`
- Seeds `.aoc/memory.md`
- Seeds `.aoc/stm/current.md` and `.aoc/stm/archive/` without overwriting existing STM files
- Ensures spec directory `.taskmaster/docs/specs/` is available for tag/task links
- Seeds `.pi/settings.json` when missing
- Seeds and refreshes managed core PI prompt templates in `.pi/prompts/` (`/aoc-ops`, `/tm-cc`, `/implement`, `/lexicon`, `/handoff`, `/rresume`, `/commit`)
- Keeps optional video prompts in `.pi/prompts-optional/production-hidden/`; legacy teach prompts are not seeded (use `aoc-understand`)
- Seeds PI default extensions in `.pi/extensions/` (`minimal.ts`, `themeMap.ts`, `mind-ingest.ts`, `mind-ops.ts`, `mind-context.ts`, `mind-focus.ts`, `aoc-models.ts`, `aoc-agent-presence.ts`, `aoc-codegraph.ts`, `aoc-compaction.ts`, `subagent.ts`, plus `lib/mind.ts` and `lib/caveman.ts`) when missing
- Seeds the preset runtime family in `.pi/extensions/aoc-presets/` when missing
- Seeds reusable preset assets in `.aoc/presets/{design,hyperframes,ops,research,test}/` and `.aoc/layouts/design.kdl` when missing
- Seeds `.aoc/init-state.json` with the current AOC project version and applies version-specific migrations on older repos
- Seeds the vendored local PI multi-auth package at `.pi/packages/pi-multi-auth-aoc` and wires `.pi/settings.json` to load it only when the package is available
- Removes legacy global npm `pi-multi-auth` package entries from `~/.pi/agent/settings.json` to avoid duplicate extension loading
- Installs the managed AOC Zellij top-bar plugin to `~/.config/zellij/plugins/zjstatus-aoc.wasm`
- Migrates missing legacy project-local PI prompts/skills from `.aoc/prompts/pi/` and `.aoc/skills/` into `.pi/**` (non-destructive), and cleans safe `tmcc` prompt alias duplicates
- Ensures `.pi/skills` baseline (PI-first canonical)
EOF
    log "Updated aoc-init-ops skill with STM seeding guidance."
  fi
}

setup_project_mind_service_config() {
  local target_config
  local global_config
  local installed_bin=""
  local local_manifest="$project_root/crates/Cargo.toml"
  local source_root=""
  local config_status=""

  target_config="$(get_project_mind_service_config_path)"
  global_config="$(get_global_mind_service_config_path)"

  if command -v aoc-mind-service >/dev/null 2>&1; then
    installed_bin="$(command -v aoc-mind-service)"
  elif [[ -x "$HOME/.local/bin/aoc-mind-service" ]]; then
    installed_bin="$HOME/.local/bin/aoc-mind-service"
  fi

  if [[ -f "$local_manifest" ]]; then
    source_root="$project_root"
  fi

  config_status="$(python3 - "$target_config" "$global_config" "$installed_bin" "$local_manifest" "$source_root" <<'PY'
import json
import sys
from pathlib import Path


def read_json(path: Path):
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def as_path(value):
    if not isinstance(value, str):
        return None
    value = value.strip()
    return value or None


target_path = Path(sys.argv[1])
global_path = Path(sys.argv[2])
installed_bin = as_path(sys.argv[3])
local_manifest = Path(sys.argv[4])
local_source_root = as_path(sys.argv[5])
global_data = read_json(global_path)
existing_data = read_json(target_path)

service_bin = installed_bin or as_path(global_data.get("serviceBin"))
cargo_manifest = str(local_manifest) if local_manifest.is_file() else as_path(global_data.get("cargoManifest"))
source_root = local_source_root or as_path(global_data.get("sourceRoot"))

if cargo_manifest and not Path(cargo_manifest).is_file():
    cargo_manifest = None
if service_bin and not Path(service_bin).exists():
    service_bin = None
if source_root and not Path(source_root).exists():
    source_root = None

if local_manifest.is_file():
    source = "project-local-workspace"
elif global_path.exists() and (service_bin or cargo_manifest or source_root):
    source = "global-install"
elif service_bin:
    source = "path"
else:
    source = None

payload = {
    "schemaVersion": 1,
    "serviceBin": service_bin,
    "cargoManifest": cargo_manifest,
    "sourceRoot": source_root,
    "source": source,
}

if not any(payload.get(key) for key in ("serviceBin", "cargoManifest", "sourceRoot")):
    if target_path.exists():
        print("preserved-unresolved")
    else:
        print("unavailable")
    raise SystemExit(0)

if existing_data == payload:
    print("unchanged")
    raise SystemExit(0)

target_path.parent.mkdir(parents=True, exist_ok=True)
target_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
print("updated" if existing_data else "seeded")
PY
)"

  case "$config_status" in
    seeded)
      log "Seeded project Mind service config: .aoc/mind-service.json"
      ;;
    updated)
      log "Updated project Mind service config: .aoc/mind-service.json"
      ;;
    unchanged)
      log "Project Mind service config already current (.aoc/mind-service.json)."
      ;;
    preserved-unresolved)
      log "Project Mind service config exists but no newer resolved source was found. Preserving."
      ;;
    unavailable)
      warn "Mind service is not globally installed/configured yet; project Mind config was not seeded. Run ./install.sh to install aoc-mind-service."
      ;;
    *)
      warn "Unexpected project Mind service config status '$config_status'"
      ;;
  esac
}

setup_project_mind_runtime() {
  if ! command -v aoc-mind-service >/dev/null 2>&1; then
    warn "Mind runtime not available; skipping project Mind store setup. Run ./install.sh first."
    return 0
  fi

  local status_file
  status_file="$(mktemp)"
  if aoc-mind-service status --project-root "$project_root" --json >"$status_file" 2>/dev/null; then
    log "Initialized project Mind store/status for this repo."
  else
    warn "Mind status check failed during init; continuing. Run: aoc-mind-service doctor --project-root \"$project_root\" --json"
  fi
  rm -f "$status_file"

  if [[ "${AOC_INIT_MIND_BACKFILL:-0}" == "1" ]]; then
    log "AOC_INIT_MIND_BACKFILL=1; backfilling Pi sessions into project Mind store..."
    if aoc-mind-service sync-pi --project-root "$project_root" --all --json >/dev/null 2>&1; then
      log "Mind Pi session backfill complete."
    else
      warn "Mind Pi session backfill reported errors. Run: aoc-mind-service doctor --project-root \"$project_root\" --json"
    fi
  else
    log "Mind Pi session backfill skipped by default. Set AOC_INIT_MIND_BACKFILL=1 to backfill during init."
  fi
}

# 1c. Setup PI settings + baseline directories (.pi/)
setup_pi_settings() {
  local pi_dir="$project_root/.pi"
  local pi_settings="$pi_dir/settings.json"
  local local_package_dir="$(get_project_pi_multi_auth_package_dir)"
  local settings_status=""

  if [[ ! -d "$pi_dir" ]]; then
    mkdir -p "$pi_dir"
  fi

  # Deterministic PI-first baseline directory contract.
  mkdir -p "$pi_dir/prompts" "$pi_dir/skills" "$pi_dir/extensions" "$pi_dir/packages"

  settings_status="$(python3 - "$pi_settings" "$local_package_dir" "$AOC_LOCAL_MULTI_AUTH_PACKAGE" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
local_package_dir = Path(sys.argv[2])
local_multi_auth_package = sys.argv[3]
include_local_multi_auth_package = local_package_dir.is_dir()
pi_defaults = {
    "defaultProvider": "openai-codex",
    "defaultModel": "gpt-5.5",
    "defaultThinkingLevel": "low",
}
seeded_enabled_models = [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
]
previous_seeded_enabled_models = [
    "openai-codex/gpt-5.5",
    "opencode/glm-5",
    "opencode/gemini-3-flash",
    "opencode/gemini-3.1-pro",
    "openrouter/alibaba/qwen3.6-plus",
]
older_previous_seeded_enabled_models = [
    "openai-codex/gpt-5.5",
    "opencode/glm-5",
    "opencode/gemini-3-flash",
    "opencode/gemini-3.1-pro",
    "alibaba/qwen3.6-plus",
]
previous_seeded_enabled_models_with_openrouter = [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
    "opencode/glm-5",
    "opencode/gemini-3-flash",
    "opencode/gemini-3.1-pro",
    "openrouter/anthropic/claude-sonnet-4",
    "openrouter/openai/gpt-5.1-codex",
    "openrouter/google/gemini-2.5-pro",
    "openrouter/google/gemini-2.5-flash",
    "openrouter/qwen/qwen3.6-plus",
]
legacy_seeded_enabled_models_with_gpt55 = [
    *previous_seeded_enabled_models_with_openrouter,
    "kimi-coding/kimi-for-coding",
]
previous_pi_defaults = {
    "defaultProvider": "openai-codex",
    "defaultModel": "gpt-5.5",
    "defaultThinkingLevel": "medium",
}
older_pi_defaults = {
    "defaultProvider": "openai-codex",
    "defaultModel": "gpt-5.4",
    "defaultThinkingLevel": "medium",
}
legacy_seeded_defaults = {
    "defaultProvider": "opencode",
    "defaultModel": "gpt-5.3-codex",
    "defaultThinkingLevel": "medium",
}
legacy_seeded_enabled_models = [
    "opencode/gpt-5.3-codex:medium",
    "opencode/claude-sonnet-4-6:medium",
    "opencode/gemini-3.1-pro:medium",
    "opencode/kimi-k2.5:medium",
]
default_extensions = [
    "extensions/minimal.ts",
    "extensions/mind-ingest.ts",
    "extensions/mind-ops.ts",
    "extensions/mind-context.ts",
    "extensions/mind-focus.ts",
    "extensions/aoc-models.ts",
    "extensions/aoc-agent-presence.ts",
    "extensions/aoc-codegraph.ts",
    "extensions/aoc-compaction.ts",
    "extensions/aoc-presets/index.ts",
    "extensions/subagent.ts",
]
default_skill_filters = [
    "!skills/prd-rpg-authoring",
    "!skills/tmcc",
    "!skills/teach-workflow",
    "!skills/understand",
    "!skills/understand-*",
    "!skills/agent-browser",
    "!skills/custom-layout-ops",
    "!skills/zellij-theme-ops",
    "!skills/architecture-design",
    "!skills/design-*",
    "!skills/enforce-dashboard-ux-guardrails",
    "!skills/frontend-design",
    "!skills/funnel-design",
    "!skills/motion-director",
    "!skills/safe-gamification",
    "!skills/animejs-*",
    "!skills/aoc-hyperframes",
    "!skills/hyperframes",
    "!skills/hyperframes-cli",
    "!skills/website-to-hyperframes",
    "!skills/gsap",
]
defaults = {
    "extensions": default_extensions,
    "skills": default_skill_filters,
    "packages": ([local_multi_auth_package] if include_local_multi_auth_package else []),
    **pi_defaults,
    "enabledModels": seeded_enabled_models,
}
legacy_package_prefixes = ("npm:pi-multi-auth",)
legacy_package_values = {"pi-multi-auth", local_multi_auth_package}


def source_value(entry):
    if isinstance(entry, str):
        return entry
    if isinstance(entry, dict) and isinstance(entry.get("source"), str):
        return entry["source"]
    return ""


def is_legacy_multi_auth(entry):
    value = source_value(entry)
    if value in legacy_package_values:
        return value != local_multi_auth_package
    return value.startswith(legacy_package_prefixes)


if not path.exists():
    path.write_text(json.dumps(defaults, indent=2) + "\n", encoding="utf-8")
    print("seeded")
    raise SystemExit(0)

try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("invalid")
    raise SystemExit(0)

if not isinstance(data, dict):
    print("invalid")
    raise SystemExit(0)

changed = False
if not isinstance(data.get("extensions"), list):
    data["extensions"] = []
    changed = True
for extension in default_extensions:
    if extension not in data["extensions"]:
        data["extensions"].append(extension)
        changed = True

if not isinstance(data.get("skills"), list):
    data["skills"] = []
    changed = True
for skill_filter in default_skill_filters:
    if skill_filter not in data["skills"]:
        data["skills"].append(skill_filter)
        changed = True

packages = data.get("packages")
if not isinstance(packages, list):
    packages = []
    data["packages"] = packages
    changed = True

normalized_packages = [entry for entry in packages if not is_legacy_multi_auth(entry)]
if normalized_packages != packages:
    data["packages"] = normalized_packages
    packages = normalized_packages
    changed = True

package_sources = [source_value(entry) for entry in packages]
if include_local_multi_auth_package:
    if local_multi_auth_package not in package_sources:
        packages.append(local_multi_auth_package)
        changed = True
elif local_multi_auth_package in package_sources:
    packages = [entry for entry in packages if source_value(entry) != local_multi_auth_package]
    data["packages"] = packages
    changed = True

has_provider = "defaultProvider" in data
has_model = "defaultModel" in data
has_thinking = "defaultThinkingLevel" in data

if not has_provider and not has_model:
    for key, value in defaults.items():
        if key not in data:
            data[key] = value
            changed = True
elif all(data.get(key) == value for key, value in legacy_seeded_defaults.items()):
    for key, value in pi_defaults.items():
        if data.get(key) != value:
            data[key] = value
            changed = True
    if data.get("enabledModels") != seeded_enabled_models:
        data["enabledModels"] = seeded_enabled_models
        changed = True
elif all(data.get(key) == value for key, value in pi_defaults.items()):
    if "enabledModels" not in data:
        data["enabledModels"] = seeded_enabled_models
        changed = True
elif (
    data.get("defaultProvider") == pi_defaults["defaultProvider"]
    and data.get("defaultModel") == pi_defaults["defaultModel"]
    and not has_thinking
):
    data["defaultThinkingLevel"] = pi_defaults["defaultThinkingLevel"]
    changed = True
    if "enabledModels" not in data:
        data["enabledModels"] = seeded_enabled_models
        changed = True
elif all(data.get(key) == value for key, value in previous_pi_defaults.items()):
    for key, value in pi_defaults.items():
        if data.get(key) != value:
            data[key] = value
            changed = True
    if data.get("enabledModels") != seeded_enabled_models:
        data["enabledModels"] = seeded_enabled_models
        changed = True
elif all(data.get(key) == value for key, value in older_pi_defaults.items()):
    for key, value in pi_defaults.items():
        if data.get(key) != value:
            data[key] = value
            changed = True
    if data.get("enabledModels") != seeded_enabled_models:
        data["enabledModels"] = seeded_enabled_models
        changed = True

if data.get("enabledModels") == legacy_seeded_enabled_models:
    data["enabledModels"] = seeded_enabled_models
    changed = True

if data.get("enabledModels") == legacy_seeded_enabled_models_with_gpt55:
    data["enabledModels"] = seeded_enabled_models
    changed = True

if data.get("enabledModels") == previous_seeded_enabled_models_with_openrouter:
    data["enabledModels"] = seeded_enabled_models
    changed = True

if data.get("enabledModels") == previous_seeded_enabled_models:
    data["enabledModels"] = seeded_enabled_models
    changed = True

if data.get("enabledModels") == older_previous_seeded_enabled_models:
    data["enabledModels"] = seeded_enabled_models
    changed = True

if changed:
    path.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
    print("updated")
else:
    print("unchanged")
PY
)"

  case "$settings_status" in
    seeded)
      log "Seeded PI settings: $pi_settings"
      ;;
    updated)
      log "Updated PI settings with GPT-5.5 low reasoning defaults: $pi_settings"
      ;;
    unchanged)
      log "PI settings exist ($pi_settings). Preserving."
      ;;
    invalid)
      warn "PI settings exist but are not valid JSON ($pi_settings). Preserving."
      ;;
    *)
      warn "Unexpected PI settings status '$settings_status' for $pi_settings"
      ;;
  esac
}

setup_pi_packages() {
  local pi_packages_dir="$project_root/.pi/packages"
  local target_package_dir="$pi_packages_dir/pi-multi-auth-aoc"
  local seed_package_dir=""

  mkdir -p "$pi_packages_dir"
  aoc_local_multi_auth_available=0
  aoc_local_multi_auth_seed_source="unresolved"

  seed_package_dir="$(resolve_pi_multi_auth_seed_dir || true)"

  if [[ ! -d "$target_package_dir" ]]; then
    if [[ -z "$seed_package_dir" ]]; then
      warn "Missing PI package seed for pi-multi-auth-aoc; leaving project settings unwired until a seed is available."
      return 0
    fi

    copy_tree_force_managed "$seed_package_dir" "$target_package_dir" "pi-package/pi-multi-auth-aoc"
    remove_pi_multi_auth_mutable_dirs "$target_package_dir"
    write_aoc_managed_marker "$target_package_dir" "pi-package/pi-multi-auth-aoc" "$seed_package_dir" "$(managed_path_sha256 "$target_package_dir")"
    aoc_local_multi_auth_available=1
    aoc_local_multi_auth_seed_source="$seed_package_dir"
    log "Seeded PI package: .pi/packages/pi-multi-auth-aoc"
    return 0
  fi

  aoc_local_multi_auth_available=1
  aoc_local_multi_auth_seed_source="existing-project-copy"

  if [[ -z "$seed_package_dir" ]]; then
    log "PI package exists (.pi/packages/pi-multi-auth-aoc). Preserving."
    return 0
  fi

  if [[ "$(cd "$seed_package_dir" && pwd)" == "$(cd "$target_package_dir" && pwd)" ]]; then
    aoc_local_multi_auth_seed_source="$seed_package_dir"
    log "Bundled PI package already present at target path (.pi/packages/pi-multi-auth-aoc)."
    return 0
  fi

  if [[ -f "$target_package_dir/.aoc-managed" ]]; then
    copy_tree_force_managed "$seed_package_dir" "$target_package_dir" "pi-package/pi-multi-auth-aoc"
    remove_pi_multi_auth_mutable_dirs "$target_package_dir"
    write_aoc_managed_marker "$target_package_dir" "pi-package/pi-multi-auth-aoc" "$seed_package_dir" "$(managed_path_sha256 "$target_package_dir")"
    aoc_local_multi_auth_seed_source="$seed_package_dir"
    log "Refreshed managed PI package: .pi/packages/pi-multi-auth-aoc"
    return 0
  fi

  remove_pi_multi_auth_mutable_dirs "$target_package_dir"
  log "PI package exists (.pi/packages/pi-multi-auth-aoc). Preserving."
}

cleanup_global_pi_multi_auth() {
  local enabled="${AOC_INIT_CLEANUP_GLOBAL_PI_MULTI_AUTH:-1}"
  local global_settings="$HOME/.pi/agent/settings.json"
  local cleanup_status=""

  if ! is_truthy "$enabled"; then
    log "Skipping global PI multi-auth cleanup (AOC_INIT_CLEANUP_GLOBAL_PI_MULTI_AUTH=$enabled)."
    return 0
  fi

  cleanup_status="$(python3 - "$global_settings" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])

if not path.exists():
    print("missing")
    raise SystemExit(0)

try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("invalid")
    raise SystemExit(0)

if not isinstance(data, dict):
    print("invalid")
    raise SystemExit(0)

packages = data.get("packages")
if not isinstance(packages, list):
    print("missing")
    raise SystemExit(0)


def source_value(entry):
    if isinstance(entry, str):
        return entry
    if isinstance(entry, dict) and isinstance(entry.get("source"), str):
        return entry["source"]
    return ""

filtered = []
removed = 0
for entry in packages:
    value = source_value(entry)
    if value == "pi-multi-auth" or value.startswith("npm:pi-multi-auth"):
        removed += 1
        continue
    filtered.append(entry)

if removed == 0:
    print("unchanged")
    raise SystemExit(0)

data["packages"] = filtered
path.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
print("removed")
PY
)"

  case "$cleanup_status" in
    removed)
      log "Removed legacy global npm PI multi-auth package entry from ~/.pi/agent/settings.json"
      ;;
    unchanged)
      log "Global PI settings already avoid legacy npm PI multi-auth package entries."
      ;;
    missing)
      log "Global PI settings missing or have no package list. Nothing to clean."
      ;;
    invalid)
      warn "Global PI settings are invalid ($global_settings); skipping legacy npm PI multi-auth cleanup."
      ;;
    *)
      warn "Unexpected global PI multi-auth cleanup status '$cleanup_status' for $global_settings"
      ;;
  esac
}

discover_pi_extension_template() {
  local extension_file="$1"
  local -a search_roots=(
    "$HOME/dev"
    "$HOME"
  )

  local root=""
  local found=""
  for root in "${search_roots[@]}"; do
    [[ -d "$root" ]] || continue
    found="$(find "$root" -maxdepth 6 -type f -path "*/.pi/extensions/$extension_file" 2>/dev/null | head -n 1 || true)"
    if [[ -n "$found" ]]; then
      printf '%s' "$found"
      return 0
    fi
  done

  return 1
}

write_builtin_pi_extension_template() {
  local extension_file="$1"
  local target_file="$2"

  case "$extension_file" in
    minimal.ts)
      cat <<'EOF' > "$target_file"
import type { ExtensionAPI } from "@mariozechner/pi-coding-agent";
import { applyExtensionDefaults } from "./themeMap.ts";

export default function ({ pi }: ExtensionAPI) {
  pi.on("session_start", async (_event, ctx) => {
    applyExtensionDefaults(import.meta.url, ctx);
  });
}
EOF
      ;;
    themeMap.ts)
      cat <<'EOF' > "$target_file"
import type { ExtensionContext } from "@mariozechner/pi-coding-agent";
import { basename } from "path";
import { fileURLToPath } from "url";

export const THEME_MAP: Record<string, string> = {
  "minimal": "synthwave",
};

function extensionName(fileUrl: string): string {
  const filePath = fileUrl.startsWith("file://") ? fileURLToPath(fileUrl) : fileUrl;
  return basename(filePath).replace(/\.[^.]+$/, "");
}

function primaryExtensionName(): string | null {
  const argv = process.argv;
  for (let i = 0; i < argv.length - 1; i++) {
    if (argv[i] === "-e" || argv[i] === "--extension") {
      return basename(argv[i + 1]).replace(/\.[^.]+$/, "");
    }
  }
  return null;
}

export function applyExtensionTheme(fileUrl: string, ctx?: ExtensionContext): boolean {
  if (!ctx || !ctx.hasUI || !(ctx as any).ui) return false;

  const name = extensionName(fileUrl);
  const primaryExt = primaryExtensionName();
  if (primaryExt && primaryExt !== name) return true;

  const setTheme = (ctx as any).ui?.setTheme;
  if (typeof setTheme !== "function") return false;

  const aocThemeName = (process.env.AOC_PI_THEME_NAME || "").trim();
  const aocThemeLocked = /^(1|true|yes|on)$/i.test((process.env.AOC_PI_THEME_LOCKED || "").trim());

  if (aocThemeName.length > 0) {
    const aocResult = setTheme(aocThemeName);
    if (aocResult?.success) return true;
    if (aocThemeLocked) return false;
  }

  if (aocThemeLocked) return false;

  const themeName = THEME_MAP[name] || "synthwave";
  const result = setTheme(themeName);
  return !!result?.success;
}

export function applyExtensionDefaults(fileUrl: string, ctx?: ExtensionContext): void {
  applyExtensionTheme(fileUrl, ctx);
}

export default function (): void {}
EOF
      ;;
    *)
      return 1
      ;;
  esac

  return 0
}

is_legacy_pi_extension_template() {
  local extension_file="$1"
  local target_file="$2"

  [[ -f "$target_file" ]] || return 1

  case "$extension_file" in
    minimal.ts)
      if grep -Fq 'const mindPart = `✦ [${bar(mindLoadPct)}] ${Math.round(mindLoadPct * 100)}%`;' "$target_file" 2>/dev/null; then
        return 0
      fi
      ;;
  esac

  return 1
}

cleanup_deprecated_pi_extensions() {
  local pi_extensions_dir="$1"
  local global_template_dir="$2"
  local deprecated_project_extension="$pi_extensions_dir/alibaba-model-studio.ts"
  local deprecated_global_template="$global_template_dir/alibaba-model-studio.ts"
  local deprecated_archive=""

  if [[ -f "$deprecated_project_extension" ]]; then
    if grep -Fq 'DEFAULT_ALIBABA_MODEL_STUDIO_BASE_URL' "$deprecated_project_extension" 2>/dev/null \
      && grep -Fq 'pi.registerProvider("alibaba"' "$deprecated_project_extension" 2>/dev/null; then
      rm -f "$deprecated_project_extension"
      log "Removed deprecated PI extension: alibaba-model-studio.ts"
    else
      deprecated_archive="$pi_extensions_dir/alibaba-model-studio.ts.disabled"
      if [[ -e "$deprecated_archive" ]]; then
        deprecated_archive="$pi_extensions_dir/alibaba-model-studio.ts.disabled.$(date +%s)"
      fi
      mv "$deprecated_project_extension" "$deprecated_archive"
      warn "Archived deprecated PI extension: .pi/extensions/alibaba-model-studio.ts -> $(basename "$deprecated_archive")"
    fi
  fi

  if [[ -f "$deprecated_global_template" ]]; then
    rm -f "$deprecated_global_template"
    log "Removed deprecated global PI extension template: alibaba-model-studio.ts"
  fi
}

# 1d. Setup PI default extensions (.pi/extensions)
setup_pi_extensions() {
  local pi_extensions_dir="$project_root/.pi/extensions"
  local global_template_dir="$aoc_config_dir/pi/extensions"
  local candidate=""
  local canonical_seed_dirs=(
    "$script_dir/../.pi/extensions"
    "$global_template_dir"
  )
  local required_extensions=(
    "minimal.ts"
    "themeMap.ts"
    "mind-ingest.ts"
    "mind-ops.ts"
    "mind-context.ts"
    "mind-focus.ts"
    "aoc-models.ts"
    "aoc-agent-presence.ts"
    "aoc-codegraph.ts"
    "aoc-compaction.ts"
    "subagent.ts"
    "lib/mind.ts"
    "lib/caveman.ts"
  )

  mkdir -p "$pi_extensions_dir" "$global_template_dir"

  local seeded_any=0
  local extension_file=""
  local preferred_seed_file=""
  local discovered_file=""
  local target_file=""
  local cache_file=""
  local managed_target=""
  for extension_file in "${required_extensions[@]}"; do
    target_file="$pi_extensions_dir/$extension_file"
    cache_file="$global_template_dir/$extension_file"
    mkdir -p "$(dirname "$target_file")" "$(dirname "$cache_file")"

    preferred_seed_file=""
    for candidate in "${canonical_seed_dirs[@]}"; do
      if [[ -f "$candidate/$extension_file" ]]; then
        preferred_seed_file="$candidate/$extension_file"
        break
      fi
    done

    discovered_file=""
    if [[ -z "$preferred_seed_file" ]]; then
      discovered_file="$(discover_pi_extension_template "$extension_file" || true)"
      if [[ -n "$discovered_file" ]]; then
        preferred_seed_file="$discovered_file"
      fi
    fi

    if [[ -f "$target_file" ]]; then
      if [[ -n "$preferred_seed_file" ]] && ! cmp -s "$target_file" "$preferred_seed_file"; then
        managed_target="0"
        for candidate in "${canonical_seed_dirs[@]}"; do
          if [[ -f "$candidate/$extension_file" ]] && cmp -s "$target_file" "$candidate/$extension_file"; then
            managed_target="1"
            break
          fi
        done

        if [[ "$managed_target" != "1" ]] && is_legacy_pi_extension_template "$extension_file" "$target_file"; then
          managed_target="1"
        fi

        if [[ "$managed_target" != "1" ]] && managed_pi_extension_name "$extension_file"; then
          managed_target="1"
        fi

        if [[ "$managed_target" == "1" ]]; then
          cp "$preferred_seed_file" "$target_file"
          log "Updated PI extension from current template: $extension_file"
          seeded_any=1
        else
          log "PI extension $extension_file already present. Preserving."
        fi
      else
        log "PI extension $extension_file already present. Preserving."
      fi

      if [[ -n "$preferred_seed_file" && "$preferred_seed_file" != "$cache_file" ]]; then
        if [[ ! -f "$cache_file" ]] || ! cmp -s "$preferred_seed_file" "$cache_file"; then
          cp "$preferred_seed_file" "$cache_file" || true
          log "Refreshed global PI extension template: $extension_file"
        fi
      fi
      continue
    fi

    if [[ -n "$preferred_seed_file" ]]; then
      cp "$preferred_seed_file" "$target_file"
      log "Seeded PI extension: $extension_file"
      seeded_any=1
      if [[ -n "$preferred_seed_file" && "$preferred_seed_file" != "$cache_file" ]]; then
        if [[ ! -f "$cache_file" ]] || ! cmp -s "$preferred_seed_file" "$cache_file"; then
          cp "$preferred_seed_file" "$cache_file" || true
          log "Refreshed global PI extension template: $extension_file"
        fi
      fi
      continue
    fi

    if write_builtin_pi_extension_template "$extension_file" "$target_file"; then
      log "Seeded PI extension (builtin fallback): $extension_file"
      seeded_any=1
      if [[ ! -f "$cache_file" ]]; then
        cp "$target_file" "$cache_file" || true
      fi
      continue
    fi

    warn "Missing PI extension template: $extension_file"
  done

  cleanup_deprecated_pi_extensions "$pi_extensions_dir" "$global_template_dir"

  if [[ "$seeded_any" != "1" ]]; then
    log "PI default extensions already present in .pi/extensions. Preserving."
  fi
}

setup_search_assets() {
  local search_file="$project_root/.aoc/search.toml"
  local searxng_dir="$project_root/.aoc/services/searxng"
  local compose_file="$searxng_dir/docker-compose.yml"
  local settings_file="$searxng_dir/settings.yml"
  local global_search_dir="$aoc_config_dir/search"
  local global_services_dir="$aoc_config_dir/services/searxng"

  mkdir -p "$project_root/.aoc" "$searxng_dir" "$global_search_dir" "$global_services_dir"

  if [[ ! -f "$search_file" ]]; then
    cat > "$search_file" <<'EOF'
version = 1

[search]
enabled = true
provider = "searxng"
managed = true
auto_start = true

[search.runtime]
base_url = "http://127.0.0.1:8888"
healthcheck_url = "http://127.0.0.1:8888/search?q=python+documentation&format=json&engines=bing%2Cgoogle%2Cbrave%2Cpresearch%2Cduckduckgo%2Cstartpage%2Cmojeek%2Cqwant%2Cyahoo%2Cwiby"
compose_file = ".aoc/services/searxng/docker-compose.yml"
service_name = "searxng"

[search.query_defaults]
format = "json"
language = "en"
categories = "general"
safe_search = 0
engines = "bing,google,brave,presearch,duckduckgo,startpage,mojeek,qwant,yahoo,wiby"

[search.agent_policy]
allow_auto_start = true
prompt_when_missing = true
prompt_when_unhealthy = true
EOF
    log "Seeded AOC search config: .aoc/search.toml"
  fi

  if [[ ! -f "$compose_file" ]]; then
    cat > "$compose_file" <<'EOF'
services:
  searxng:
    image: docker.io/searxng/searxng:latest
    container_name: aoc-searxng
    ports:
      - "127.0.0.1:8888:8080"
    volumes:
      - ./settings.yml:/etc/searxng/settings.yml
    restart: unless-stopped
EOF
    log "Seeded AOC SearXNG compose file."
  fi

  if [[ ! -f "$settings_file" ]]; then
    cat > "$settings_file" <<'EOF'
use_default_settings: true
server:
  secret_key: "aoc-searxng-local-dev-key"
  bind_address: "0.0.0.0"
  port: 8080
  limiter: false
search:
  safe_search: 0
  autocomplete: ""
  formats:
    - html
    - json
    - csv
    - rss
engines:
  - name: duckduckgo
    disabled: true
  - name: startpage
    disabled: true
  - name: mojeek
    disabled: true
  - name: qwant
    disabled: true
  - name: yahoo
    disabled: true
  - name: ahmia
    disabled: true
  - name: torch
    disabled: true
EOF
    log "Seeded AOC SearXNG settings."
  fi

  cp "$search_file" "$global_search_dir/search.toml" || true
  cp "$compose_file" "$global_services_dir/docker-compose.yml" || true
  cp "$settings_file" "$global_services_dir/settings.yml" || true
}

setup_pi_agents() {
  local pi_agents_dir="$project_root/.pi/agents"
  local global_agents_dir="$aoc_config_dir/pi/agents"
  local canonical_seed_dirs=(
    "$script_dir/../.pi/agents"
    "$global_agents_dir"
  )
  local required_agent_files=(
    "explorer-agent.md"
    "planner-agent.md"
    "builder-agent.md"
    "code-review-agent.md"
    "documenter-agent.md"
    "red-team-agent.md"
    "testing-agent.md"
    "scout-web-agent.md"
    "insight-t1-observer.md"
    "insight-t2-reflector.md"
    "insight-t3-aligner.md"
    "teams.yaml"
    "agent-chain.yaml"
  )

  mkdir -p "$pi_agents_dir" "$global_agents_dir"

  local seeded_any=0
  local agent_file=""
  local candidate=""
  local seed_file=""
  local target_file=""
  local cache_file=""

  for agent_file in "${required_agent_files[@]}"; do
    seed_file=""
    for candidate in "${canonical_seed_dirs[@]}"; do
      if [[ -f "$candidate/$agent_file" ]]; then
        seed_file="$candidate/$agent_file"
        break
      fi
    done

    if [[ -z "$seed_file" ]]; then
      warn "Missing PI agent template: $agent_file"
      continue
    fi

    target_file="$pi_agents_dir/$agent_file"
    cache_file="$global_agents_dir/$agent_file"

    if [[ ! -f "$target_file" ]]; then
      cp "$seed_file" "$target_file"
      log "Seeded PI agent: $agent_file"
      seeded_any=1
    else
      log "PI agent $agent_file already present. Preserving."
    fi

    if [[ "$seed_file" != "$cache_file" ]]; then
      if [[ ! -f "$cache_file" ]] || ! cmp -s "$seed_file" "$cache_file"; then
        cp "$seed_file" "$cache_file" || true
        log "Refreshed global PI agent template: $agent_file"
      fi
    fi
  done

  if [[ "$seeded_any" != "1" ]]; then
    log "PI default agents already present in .pi/agents. Preserving."
  fi
}

setup_pi_extension_families() {
  local pi_extensions_dir="$project_root/.pi/extensions"
  local global_template_dir="$aoc_config_dir/pi/extensions"
  local canonical_seed_dirs=(
    "$script_dir/../.pi/extensions"
    "$global_template_dir"
  )
  local required_families=(
    "aoc-presets"
    "subagent"
  )

  mkdir -p "$pi_extensions_dir" "$global_template_dir"

  local family_name=""
  local seed_dir=""
  local target_dir=""
  local cache_dir=""
  local candidate=""
  local seeded_any=0

  for family_name in "${required_families[@]}"; do
    seed_dir=""
    for candidate in "${canonical_seed_dirs[@]}"; do
      if [[ -d "$candidate/$family_name" ]]; then
        seed_dir="$candidate/$family_name"
        break
      fi
    done

    if [[ -z "$seed_dir" ]]; then
      warn "Missing PI extension family template: $family_name"
      continue
    fi

    target_dir="$pi_extensions_dir/$family_name"
    cache_dir="$global_template_dir/$family_name"

    if [[ ! -d "$target_dir" ]]; then
      copy_tree_force_managed "$seed_dir" "$target_dir" "pi-extension-family/$family_name"
      log "Seeded PI extension family: $family_name"
      seeded_any=1
    else
      copy_tree_force_managed "$seed_dir" "$target_dir" "pi-extension-family/$family_name"
      log "Refreshed managed PI extension family: $family_name"
      seeded_any=1
    fi

    if [[ ! -d "$cache_dir" ]] || ! directories_match "$seed_dir" "$cache_dir"; then
      copy_tree_force "$seed_dir" "$cache_dir"
      log "Refreshed global PI extension family template: $family_name"
    fi
  done

  if [[ "$seeded_any" != "1" ]]; then
    log "PI extension families already present in .pi/extensions. Preserving existing files."
  fi
}

setup_aoc_preset_assets() {
  local presets_dir="$project_root/.aoc/presets"
  local layouts_dir="$project_root/.aoc/layouts"
  local global_presets_dir="$aoc_config_dir/presets"
  local global_layouts_dir="$aoc_config_dir/layouts"
  local canonical_preset_seed_dirs=(
    "$script_dir/../.aoc/presets"
    "$global_presets_dir"
  )
  local canonical_layout_seed_dirs=(
    "$script_dir/../.aoc/layouts"
    "$global_layouts_dir"
  )
  local candidate=""
  local layout_name="design.kdl"
  local layout_seed_file=""
  local target_layout_file="$layouts_dir/$layout_name"
  local cache_layout_file="$global_layouts_dir/$layout_name"

  mkdir -p "$presets_dir" "$layouts_dir" "$global_presets_dir" "$global_layouts_dir"

  seed_aoc_preset_asset() {
    local preset_name="$1"
    local preset_seed_dir=""
    local target_preset_dir="$presets_dir/$preset_name"
    local cache_preset_dir="$global_presets_dir/$preset_name"

    for candidate in "${canonical_preset_seed_dirs[@]}"; do
      if [[ -d "$candidate/$preset_name" ]]; then
        preset_seed_dir="$candidate/$preset_name"
        break
      fi
    done

    if [[ -n "$preset_seed_dir" ]]; then
      if [[ ! -d "$target_preset_dir" ]]; then
        copy_tree_force_managed "$preset_seed_dir" "$target_preset_dir" "preset/$preset_name"
        log "Seeded AOC preset assets: $preset_name"
      else
        copy_tree_force_managed "$preset_seed_dir" "$target_preset_dir" "preset/$preset_name"
        log "Refreshed managed AOC preset assets: $preset_name"
      fi

      if [[ ! -d "$cache_preset_dir" ]] || ! directories_match "$preset_seed_dir" "$cache_preset_dir"; then
        copy_tree_force "$preset_seed_dir" "$cache_preset_dir"
        log "Refreshed global AOC preset template: $preset_name"
      fi
    else
      warn "Missing AOC preset template: $preset_name"
    fi
  }

  # Seed the compact production preset surface used by Alt+X. Presets are
  # cognitive positioning layers; mode-specific skills remain lazy/filtered.
  seed_aoc_preset_asset "design"
  seed_aoc_preset_asset "hyperframes"
  seed_aoc_preset_asset "ops"
  seed_aoc_preset_asset "research"
  seed_aoc_preset_asset "test"

  if [[ -d "$project_root/${AOC_HYPERFRAMES_DIR:-hyperframes}" ]]; then
    ensure_hyperframes_workspace_package
  fi

  for candidate in "${canonical_layout_seed_dirs[@]}"; do
    if [[ -f "$candidate/$layout_name" ]]; then
      layout_seed_file="$candidate/$layout_name"
      break
    fi
  done

  if [[ -n "$layout_seed_file" ]]; then
    if [[ ! -f "$target_layout_file" ]]; then
      cp "$layout_seed_file" "$target_layout_file"
      write_aoc_managed_marker "$target_layout_file" "layout/${layout_name%.kdl}" "$layout_seed_file" "$(managed_path_sha256 "$target_layout_file")"
      log "Seeded AOC layout: ${layout_name%.kdl}"
    else
      cp "$layout_seed_file" "$target_layout_file"
      write_aoc_managed_marker "$target_layout_file" "layout/${layout_name%.kdl}" "$layout_seed_file" "$(managed_path_sha256 "$target_layout_file")"
      log "Refreshed managed AOC layout: ${layout_name%.kdl}"
    fi

    if [[ ! -f "$cache_layout_file" ]] || ! cmp -s "$layout_seed_file" "$cache_layout_file"; then
      cp "$layout_seed_file" "$cache_layout_file"
      log "Refreshed global AOC layout template: ${layout_name%.kdl}"
    fi
  else
    warn "Missing AOC layout template: $layout_name"
  fi
}

ensure_hyperframes_workspace_package() {
  local hf_dir="${AOC_HYPERFRAMES_DIR:-hyperframes}"
  local hf_root="$project_root/$hf_dir"
  local pkg="$hf_root/package.json"
  [[ -d "$hf_root" ]] || return 0
  mkdir -p "$hf_root"
  python3 - "$pkg" <<'PY'
import json
import sys
from pathlib import Path

pkg = Path(sys.argv[1])
changed = False
if pkg.exists():
    try:
        data = json.loads(pkg.read_text())
    except Exception:
        raise SystemExit(f"Refusing to edit invalid HyperFrames package.json: {pkg}")
else:
    data = {"private": True, "type": "module"}
    changed = True

if data.get("private") is not True:
    data["private"] = True
    changed = True
if data.get("type") != "module":
    data["type"] = "module"
    changed = True
if data.get("packageManager") != "bun@1.3.9":
    data["packageManager"] = "bun@1.3.9"
    changed = True
scripts = data.setdefault("scripts", {})
for key, value in {"hf:lint": "hyperframes lint", "hf:doctor": "hyperframes doctor"}.items():
    if scripts.get(key) != value:
        scripts[key] = value
        changed = True

dev = data.setdefault("devDependencies", {})
if dev.get("hyperframes") != "0.4.33":
    dev["hyperframes"] = "0.4.33"
    changed = True

if changed:
    pkg.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n")
PY
  log "Confirmed $hf_dir/package.json pins HyperFrames CLI for bun install."
  if command -v aoc-hf >/dev/null 2>&1 && command -v aoc-hf-u >/dev/null 2>&1; then
    log "Confirmed HyperFrames convenience aliases: aoc-hf, aoc-hf-u"
  else
    warn "HyperFrames convenience aliases missing from PATH. Run AOC install.sh to install aoc-hf and aoc-hf-u."
  fi
}

# 1d. Migrate legacy PI runtime assets from project-local .aoc paths
cleanup_deprecated_pi_skills() {
  local pi_skills_dir="$project_root/.pi/skills"
  local deprecated_skill_dir="$pi_skills_dir/aoc-commit"

  if [[ -d "$deprecated_skill_dir" ]]; then
    if [[ -f "$deprecated_skill_dir/.aoc-managed" ]]; then
      rm -rf "$deprecated_skill_dir"
      log "Removed deprecated managed PI skill: .pi/skills/aoc-commit (use /commit prompt)."
    else
      warn "Deprecated PI skill .pi/skills/aoc-commit is unmanaged; preserving for manual review. Use /commit instead."
    fi
  fi
}

migrate_legacy_pi_assets() {
  local pi_prompts_dir="$project_root/.pi/prompts"
  local pi_skills_dir="$project_root/.pi/skills"
  local legacy_prompts_dir="$aoc_dir/prompts/pi"
  local legacy_skills_dir="$aoc_dir/skills"

  local legacy_prompt=""
  local legacy_prompt_name=""
  local canonical_prompt_name=""
  local target_prompt=""

  if [[ -d "$legacy_prompts_dir" ]]; then
    shopt -s nullglob
    local legacy_prompts=("$legacy_prompts_dir"/*.md)
    shopt -u nullglob
    for legacy_prompt in "${legacy_prompts[@]}"; do
      legacy_prompt_name="$(basename "$legacy_prompt")"
      canonical_prompt_name="$legacy_prompt_name"
      if [[ "$legacy_prompt_name" == "tmcc.md" ]]; then
        canonical_prompt_name="tm-cc.md"
      fi
      target_prompt="$pi_prompts_dir/$canonical_prompt_name"
      if [[ ! -f "$target_prompt" ]]; then
        cp "$legacy_prompt" "$target_prompt"
        log "Migrated legacy PI prompt: .aoc/prompts/pi/$legacy_prompt_name -> .pi/prompts/$canonical_prompt_name"
      elif ! cmp -s "$legacy_prompt" "$target_prompt"; then
        warn "Legacy prompt differs from canonical (.aoc/prompts/pi/$legacy_prompt_name vs .pi/prompts/$canonical_prompt_name). Preserving canonical file."
      fi
    done
  fi

  local alias_prompt="$pi_prompts_dir/tmcc.md"
  local canonical_tmcc_prompt="$pi_prompts_dir/tm-cc.md"
  if [[ -f "$alias_prompt" ]]; then
    if [[ ! -f "$canonical_tmcc_prompt" ]]; then
      mv "$alias_prompt" "$canonical_tmcc_prompt"
      log "Migrated legacy PI prompt alias: .pi/prompts/tmcc.md -> .pi/prompts/tm-cc.md"
    elif cmp -s "$alias_prompt" "$canonical_tmcc_prompt"; then
      rm -f "$alias_prompt"
      log "Removed legacy PI prompt alias duplicate: .pi/prompts/tmcc.md"
    else
      warn "Legacy PI prompt alias .pi/prompts/tmcc.md differs from .pi/prompts/tm-cc.md; preserving both for manual merge."
    fi
  fi

  local legacy_skill_dir=""
  local legacy_skill_name=""
  local canonical_skill_name=""
  local target_skill_dir=""
  if [[ -d "$legacy_skills_dir" ]]; then
    shopt -s nullglob
    local legacy_skill_entries=("$legacy_skills_dir"/*)
    shopt -u nullglob
    for legacy_skill_dir in "${legacy_skill_entries[@]}"; do
      [[ -d "$legacy_skill_dir" ]] || continue
      [[ -f "$legacy_skill_dir/SKILL.md" ]] || continue
      legacy_skill_name="$(basename "$legacy_skill_dir")"
      canonical_skill_name="$legacy_skill_name"
      if [[ "$legacy_skill_name" == "tmcc" ]]; then
        canonical_skill_name="tm-cc"
      fi
      target_skill_dir="$pi_skills_dir/$canonical_skill_name"
      if [[ ! -e "$target_skill_dir" ]]; then
        mkdir -p "$target_skill_dir"
        cp -R "$legacy_skill_dir"/. "$target_skill_dir"/
        log "Migrated legacy PI skill: .aoc/skills/$legacy_skill_name -> .pi/skills/$canonical_skill_name"
      elif [[ -f "$target_skill_dir/SKILL.md" ]] && ! cmp -s "$legacy_skill_dir/SKILL.md" "$target_skill_dir/SKILL.md"; then
        warn "Legacy skill differs from canonical (.aoc/skills/$legacy_skill_name vs .pi/skills/$canonical_skill_name). Preserving canonical skill."
      fi
    done
  fi
}

# 1f. Setup PI Prompt Templates (.pi/prompts)
setup_pi_prompts() {
  local pi_prompts_dir="$project_root/.pi/prompts"
  local candidate=""
  local canonical_seed_dirs=(
    "$aoc_config_dir/pi/prompts"
    "$script_dir/../.pi/prompts"
  )
  local required_prompts=(
    "aoc-ops"
    "tm-cc"
    "implement"
    "lexicon"
    "handoff"
    "rresume"
    "commit"
  )

  if [[ ! -d "$pi_prompts_dir" ]]; then
    mkdir -p "$pi_prompts_dir"
  fi

  local legacy_resume_prompt="$pi_prompts_dir/resume.md"
  if [[ -f "$legacy_resume_prompt" ]] && grep -Fq 'safe_to_resume_latest' "$legacy_resume_prompt" && grep -Fq 'Operator resume target or focus:' "$legacy_resume_prompt"; then
    rm -f "$legacy_resume_prompt"
    log "Removed legacy AOC /resume prompt to avoid clashing with Pi native /resume; use /rresume."
  fi

  local seeded_any=0
  local prompt_name=""
  local seed_file=""
  local target_file=""
  for prompt_name in "${required_prompts[@]}"; do
    seed_file=""

    for candidate in "${canonical_seed_dirs[@]}"; do
      if [[ -f "$candidate/${prompt_name}.md" ]]; then
        seed_file="$candidate/${prompt_name}.md"
        break
      fi
    done

    if [[ -z "$seed_file" ]]; then
      warn "Missing PI prompt template: /$prompt_name"
      continue
    fi

    target_file="$pi_prompts_dir/${prompt_name}.md"
    if [[ ! -f "$target_file" ]]; then
      copy_file_force_managed "$seed_file" "$target_file" "prompt/$prompt_name"
      log "Seeded PI prompt: /$prompt_name"
    elif is_aoc_managed_target "$target_file"; then
      if cmp -s "$seed_file" "$target_file"; then
        copy_file_force_managed "$seed_file" "$target_file" "prompt/$prompt_name"
        log "PI prompt /$prompt_name already current."
      else
        copy_file_force_managed "$seed_file" "$target_file" "prompt/$prompt_name"
        log "Refreshed managed PI prompt: /$prompt_name"
      fi
    elif cmp -s "$seed_file" "$target_file"; then
      copy_file_force_managed "$seed_file" "$target_file" "prompt/$prompt_name"
      log "Adopted PI prompt as managed: /$prompt_name"
    else
      copy_file_force_managed "$seed_file" "$target_file" "prompt/$prompt_name"
      log "Refreshed PI prompt from AOC seed: /$prompt_name"
    fi
    seeded_any=1
  done

  if [[ "$seeded_any" != "1" ]]; then
    warn "No PI prompt templates found; skipping PI prompt seeding."
  fi

  local optional_hidden_dir="$project_root/.pi/prompts-optional/production-hidden"
  local optional_seed_dirs=(
    "$aoc_config_dir/pi/prompts-optional/production-hidden"
    "$script_dir/../.pi/prompts-optional/production-hidden"
  )
  local optional_prompt=""
  local optional_seed_file=""
  mkdir -p "$optional_hidden_dir"
  for optional_prompt in "hyperframes"; do
    optional_seed_file=""
    for candidate in "${optional_seed_dirs[@]}"; do
      if [[ -f "$candidate/${optional_prompt}.md" ]]; then
        optional_seed_file="$candidate/${optional_prompt}.md"
        break
      fi
    done
    if [[ -n "$optional_seed_file" && ! -f "$optional_hidden_dir/${optional_prompt}.md" ]]; then
      cp "$optional_seed_file" "$optional_hidden_dir/${optional_prompt}.md"
      log "Seeded optional hidden PI prompt: /$optional_prompt"
    fi
  done

  for optional_prompt in "hyperframes"; do
    if [[ -f "$pi_prompts_dir/${optional_prompt}.md" && ! -f "$optional_hidden_dir/${optional_prompt}.md" ]]; then
      mv "$pi_prompts_dir/${optional_prompt}.md" "$optional_hidden_dir/${optional_prompt}.md"
      log "Moved optional PI prompt out of production surface: /$optional_prompt"
    fi
  done

  for deprecated_prompt in "teach" "teach-full" "teach-dive" "teach-ask"; do
    if [[ -f "$pi_prompts_dir/${deprecated_prompt}.md" ]]; then
      rm -f "$pi_prompts_dir/${deprecated_prompt}.md"
      log "Removed deprecated legacy teach PI prompt: /$deprecated_prompt (use aoc-understand)"
    fi
    if [[ -f "$optional_hidden_dir/${deprecated_prompt}.md" ]]; then
      rm -f "$optional_hidden_dir/${deprecated_prompt}.md"
      log "Removed deprecated hidden legacy teach PI prompt: /$deprecated_prompt (use aoc-understand)"
    fi
  done

  if [[ -f "$pi_prompts_dir/tmcc.md" ]]; then
    log "Legacy PI prompt alias /tmcc detected; preserving file but alias is no longer seeded."
  fi
}

# 1g. Setup PI Skill Templates (.pi/skills)
setup_pi_skills() {
  local pi_skills_dir="$project_root/.pi/skills"
  local candidate=""
  local canonical_seed_dirs=(
    "$script_dir/../.pi/skills"
    "$aoc_config_dir/pi/skills"
  )

  mkdir -p "$pi_skills_dir"

  local seed_dir=""
  local skill_list=()

  for candidate in "${canonical_seed_dirs[@]}"; do
    [[ -d "$candidate" ]] || continue
    shopt -s nullglob
    skill_list=("$candidate"/*/SKILL.md)
    shopt -u nullglob
    if ((${#skill_list[@]} > 0)); then
      seed_dir="$candidate"
      break
    fi
  done

  if [[ -z "$seed_dir" ]]; then
    warn "No PI skill templates found; skipping PI skill seeding."
    return
  fi

  local copied_any=0
  local seed_skill_dir=""
  local skill_name=""
  local target_skill_dir=""

  shopt -s nullglob
  local seed_entries=("$seed_dir"/*)
  shopt -u nullglob
  for seed_skill_dir in "${seed_entries[@]}"; do
    [[ -d "$seed_skill_dir" ]] || continue
    [[ -f "$seed_skill_dir/SKILL.md" ]] || continue
    skill_name="$(basename "$seed_skill_dir")"
    if [[ "$skill_name" == "aoc-commit" ]]; then
      continue
    fi
    target_skill_dir="$pi_skills_dir/$skill_name"
    if [[ ! -e "$target_skill_dir" ]]; then
      copy_tree_force_managed "$seed_skill_dir" "$target_skill_dir" "skill/$skill_name"
      copied_any=1
      continue
    fi

    if managed_pi_skill_name "$skill_name"; then
      copy_tree_force_managed "$seed_skill_dir" "$target_skill_dir" "skill/$skill_name"
      copied_any=1
      continue
    fi

    copy_tree_missing_only "$seed_skill_dir" "$target_skill_dir"
  done

  if [[ "$copied_any" == "1" ]]; then
    log "Seeded/refreshed PI skills into .pi/skills."
  else
    log "PI skills already present in .pi/skills. Seeded missing support files only."
  fi
}

# 2. Setup Taskmaster (.taskmaster/)
setup_tasks() {
  log "Initializing Taskmaster..."

  mkdir -p "$task_dir/tasks" "$task_dir/docs/specs" "$task_dir/docs/prds" "$task_dir/reports" "$task_dir/templates"

  local native_init_ok=0
  if command -v aoc-task >/dev/null 2>&1; then
    if (cd "$project_root" && aoc-task init >/dev/null 2>&1); then
      native_init_ok=1
    else
      warn "aoc-task init failed; using shell fallback for task scaffolding."
    fi
  elif command -v aoc-cli >/dev/null 2>&1; then
    if (cd "$project_root" && aoc-cli task init >/dev/null 2>&1); then
      native_init_ok=1
    else
      warn "aoc-cli task init failed; using shell fallback for task scaffolding."
    fi
  fi

  if [[ "$native_init_ok" != "1" ]]; then
    if [[ ! -f "$task_dir/tasks/tasks.json" ]]; then
      cat <<EOF > "$task_dir/tasks/tasks.json"
{
  "master": {
    "tasks": []
  }
}
EOF
    fi

    if [[ ! -f "$task_dir/state.json" ]]; then
      now_stamp="$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)"
      cat <<EOF > "$task_dir/state.json"
{
  "currentTag": "master",
  "lastUpdated": "${now_stamp}",
  "lastSwitched": "${now_stamp}",
  "branchTagMapping": {},
  "migrationNoticeShown": true
}
EOF
    fi
  fi

  local template_name=""
  local template_src=""
  local candidate=""
  local template_candidates=(
    "$aoc_config_dir/taskmaster/templates"
    "$script_dir/../.taskmaster/templates"
  )

  for template_name in "example_prd.txt" "example_prd_rpg.txt"; do
    if [[ -f "$task_dir/templates/$template_name" ]]; then
      continue
    fi
    template_src=""
    for candidate in "${template_candidates[@]}"; do
      if [[ -f "$candidate/$template_name" ]]; then
        template_src="$candidate/$template_name"
        break
      fi
    done
    if [[ -n "$template_src" ]]; then
      cp "$template_src" "$task_dir/templates/$template_name"
      log "Seeded Taskmaster template: $task_dir/templates/$template_name"
    else
      warn "No upstream template found for $template_name."
    fi
  done

  local project_prd="$task_dir/docs/prd.md"
  if [[ ! -f "$project_prd" ]]; then
    if [[ -f "$task_dir/templates/example_prd.txt" ]]; then
      cp "$task_dir/templates/example_prd.txt" "$project_prd"
      log "Seeded project PRD from upstream template: $project_prd"
    else
      cat <<'EOF' > "$project_prd"
# Product Requirements Document

## Problem
Describe the core user problem this project solves.

